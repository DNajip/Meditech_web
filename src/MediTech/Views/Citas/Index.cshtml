@{
    ViewData["Title"] = "Agenda de Citas";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.14/index.global.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/citas-calendar.css" asp-append-version="true" />
}

<!-- Calendar Wrapper: Calendar + Agenda Panel -->
<div class="calendar-wrapper">

    <!-- Center: Calendar Area -->
    <div class="calendar-main">

        <!-- Custom Calendar Header -->
        <div class="calendar-header">
            <div class="calendar-header-left">
                <div class="brand-title">
                    <i class="fas fa-calendar-alt"></i>
                    MediTech Agenda
                </div>
                <button class="btn-today" id="btnToday">Hoy</button>
                <div class="calendar-nav-buttons">
                    <button class="btn-nav" id="btnPrev"><i class="fas fa-chevron-left"></i></button>
                    <button class="btn-nav" id="btnNext"><i class="fas fa-chevron-right"></i></button>
                </div>
                <span class="calendar-title" id="calendarTitle">Marzo 2026</span>
            </div>

            <div class="calendar-header-right">
                <div class="calendar-search">
                    <i class="fas fa-search"></i>
                    <input type="text" id="calendarSearchInput" placeholder="Buscar pacientes o citas..." autocomplete="off" />
                    <div class="search-results-dropdown" id="searchResultsDropdown"></div>
                </div>

                <div class="view-switcher">
                    <button data-view="timeGridDay">Día</button>
                    <button data-view="timeGridWeek" class="active">Semana</button>
                    <button data-view="dayGridMonth">Mes</button>
                    <button data-view="listWeek">Agenda</button>
                </div>

                <button class="btn-create-cita" id="btnCreateCita">
                    <i class="fas fa-plus"></i> Crear
                </button>
            </div>
        </div>

        <!-- FullCalendar Grid -->
        <div class="calendar-body">
            <div id="fullcalendar"></div>
        </div>
    </div>

    <!-- Right Panel: Today's Agenda -->
    <aside class="agenda-panel">
        <div class="agenda-panel-header">
            <div class="agenda-title">
                Agenda de Hoy
                <span class="count-badge" id="agendaCount">0 citas</span>
            </div>
            <div class="agenda-subtitle" id="agendaDate">Cargando...</div>
        </div>
        <div class="agenda-panel-body" id="agendaPanelBody">
            <div class="agenda-empty">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Cargando agenda...</p>
            </div>
        </div>
    </aside>
</div>

<!-- Event Popover -->
<div class="event-popover" id="eventPopover">
    <div class="event-popover-header">
        <div class="event-color-bar" id="popoverColorBar"></div>
        <div class="event-info">
            <div class="event-title" id="popoverTitle">Paciente</div>
            <div class="event-treatment" id="popoverTreatment">Tratamiento</div>
        </div>
        <button class="event-popover-close" id="popoverClose"><i class="fas fa-times"></i></button>
    </div>
    <div class="event-popover-body">
        <div class="detail-row"><i class="fas fa-clock"></i> <span id="popoverTime"></span></div>
        <div class="detail-row"><i class="fas fa-calendar"></i> <span id="popoverDate"></span></div>
        <div class="detail-row"><i class="fas fa-phone"></i> <span id="popoverPhone"></span></div>
        <div class="detail-row"><i class="fas fa-sticky-note"></i> <span id="popoverObs"></span></div>
    </div>
    <div class="event-popover-footer" id="popoverFooter">
        <a href="#" class="popover-btn" id="popoverBtnView"><i class="fas fa-eye"></i> Ver</a>
        <a href="#" class="popover-btn" id="popoverBtnEdit"><i class="fas fa-edit"></i> Editar</a>
        <a href="#" class="popover-btn" id="popoverBtnPatient"><i class="fas fa-user-circle"></i> Expediente</a>
    </div>
    <div class="event-popover-footer mt-2" id="popoverActionFooter">
        <form method="post" id="formMarcarAtendida" style="display:none; width:100%;">
            <input type="hidden" name="id" id="popoverAtendidaId" value="" />
            <button type="submit" class="btn btn-sm btn-success w-100" style="border-radius: 8px;">
                <i class="fas fa-check-circle"></i> Confirmar Llegada
            </button>
        </form>
    </div>
</div>

<!-- Create Appointment Modal -->
<div class="modal-backdrop-citas" id="createModalBackdrop"></div>
<div class="modal-citas" id="createModal">
    <div class="modal-citas-header">
        <h3><i class="fas fa-calendar-plus"></i> Agendar Nueva Cita</h3>
        <button class="modal-close-btn" id="btnCloseModal"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-citas-body">
        <div class="modal-alert" id="modalAlert"></div>
        <form id="createCitaForm">
            @Html.AntiForgeryToken()

            <div class="form-group position-relative">
                <label for="modalPacienteSearch">Paciente</label>
                <input type="text" id="modalPacienteSearch" class="form-control" placeholder="Buscar por nombre o identificación..." autocomplete="off" required>
                <input type="hidden" name="IdPaciente" id="modalPaciente" required>
                <div id="pacienteSearchResults" class="list-group position-absolute w-100 shadow" style="display: none; z-index: 1050; max-height: 200px; overflow-y: auto;"></div>
            </div>

            <div class="form-group">
                <label for="modalTratamiento">Tratamiento / Servicio</label>
                <select name="IdTratamiento" id="modalTratamiento">
                    <option value="">-- Seleccione un Tratamiento --</option>
                    @if (ViewBag.Tratamientos != null)
                    {
                        @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Tratamientos)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="modalFecha">Fecha</label>
                    <input type="date" name="Fecha" id="modalFecha" required />
                </div>
                <div class="form-group">
                    <label for="modalHoraInicio">Hora Inicio</label>
                    <input type="time" name="HoraInicio" id="modalHoraInicio" required />
                </div>
                <div class="form-group">
                    <label for="modalHoraFin">Hora Fin</label>
                    <input type="time" name="HoraFin" id="modalHoraFin" required />
                </div>
            </div>

            <div class="form-group">
                <label for="modalTelefono">Teléfono de Contacto <span class="text-danger">*</span></label>
                <input type="tel" name="Telefono" id="modalTelefono" class="form-control" placeholder="Ej: 8888-8888" required />
            </div>

            <div class="form-group">
                <label for="modalObs">Observaciones</label>
                <textarea name="Observaciones" id="modalObs" rows="2" placeholder="Detalles adicionales..."></textarea>
            </div>

            <div class="modal-citas-footer" style="padding: 0; border: none; margin-top: 8px;">
                <button type="submit" class="btn-save-cita">
                    <i class="fas fa-save"></i> Guardar Cita
                </button>
            </div>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Flash success toast
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#10B981;color:#FFF;padding:12px 20px;border-radius:10px;font-size:0.88rem;font-weight:600;z-index:9999;box-shadow:0 4px 12px rgba(16,185,129,0.3);display:flex;align-items:center;gap:8px;';
            toast.innerHTML = '<i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        });
    </script>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.14/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@fullcalendar/core@6.1.14/locales/es.global.min.js"></script>
    <script src="~/js/citas-calendar.js" asp-append-version="true"></script>
}
