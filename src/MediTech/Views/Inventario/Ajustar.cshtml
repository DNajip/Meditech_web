@model MediTech.Models.Producto

@{
    ViewData["Title"] = "Ajuste de Stock";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 pt-3 pb-2">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="fw-bold mb-0">Ajuste de Inventario</h5>
                            <span class="text-primary small fw-semibold">@Model.Nombre</span>
                        </div>
                        <div class="text-end">
                            <span class="text-muted small d-block">Stock Actual</span>
                            <input type="hidden" id="stockActualVal" value="@Model.Stock" />
                            <span class="badge bg-soft-primary text-primary px-3 rounded-pill fs-6" id="stockActualBadge">@Model.Stock</span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Ajustar" method="post">
                        <input type="hidden" name="id" value="@Model.IdProducto" />

                        <!-- SECCIÓN 1: Tipo de Ajuste -->
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase text-muted silver-label mb-2">Tipo de Ajuste</label>
                            <div class="d-flex gap-2">
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" name="tipo" id="btn-ingreso" value="INGRESO" checked autocomplete="off">
                                    <label class="btn btn-outline-success w-100 py-2 d-flex align-items-center justify-content-center gap-2" for="btn-ingreso">
                                        <i class="fas fa-plus-circle"></i> + Ingreso / Compra
                                    </label>
                                </div>
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" name="tipo" id="btn-salida" value="AJUSTE_NEG" autocomplete="off">
                                    <label class="btn btn-outline-danger w-100 py-2 d-flex align-items-center justify-content-center gap-2" for="btn-salida">
                                        <i class="fas fa-minus-circle"></i> - Salida / Ajuste
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- SECCIÓN 2: Detalles -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-uppercase text-muted silver-label">Cantidad</label>
                                <input type="number" name="cantidad" id="inputCantidad" class="form-control form-control-lg bg-light border-0 text-center fw-bold" value="1" min="1" required />
                                <div id="errorStock" class="text-danger small mt-1 d-none">Stock insuficiente</div>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-bold small text-uppercase text-muted silver-label">Observación</label>
                                <textarea name="observacion" class="form-control bg-light border-0" rows="1" placeholder="Motivo del ajuste..." style="min-height: 48px;"></textarea>
                            </div>
                        </div>

                        <!-- SECCIÓN 3: Acciones -->
                        <div class="d-flex align-items-center justify-content-end gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small">
                                Volver
                            </a>
                            <button type="submit" id="btnProcesar" class="btn btn-primary px-4 py-2 shadow-sm rounded-3 fw-bold">
                                <i class="fas fa-check-circle me-2"></i> Procesar Movimiento
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .bg-soft-primary { background-color: rgba(59, 130, 246, 0.1); }
    .silver-label { letter-spacing: 0.5px; font-size: 0.75rem !important; }
    .rounded-4 { border-radius: 1rem !important; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const inputCantidad = document.getElementById('inputCantidad');
        const btnProcesar = document.getElementById('btnProcesar');
        const stockActual = parseInt(document.getElementById('stockActualVal').value);
        const errorStock = document.getElementById('errorStock');
        const radios = document.querySelectorAll('input[name="tipo"]');

        function validarStock() {
            let tipoActivo = "";
            radios.forEach(r => { if(r.checked) tipoActivo = r.value; });
            
            const cantidad = parseInt(inputCantidad.value) || 0;
            
            if (tipoActivo === "AJUSTE_NEG" && cantidad > stockActual) {
                errorStock.classList.remove('d-none');
                btnProcesar.disabled = true;
                inputCantidad.classList.add('is-invalid');
            } else {
                errorStock.classList.add('d-none');
                btnProcesar.disabled = false;
                inputCantidad.classList.remove('is-invalid');
            }
        }

        inputCantidad.addEventListener('input', validarStock);
        radios.forEach(r => r.addEventListener('change', validarStock));
    });
</script>
