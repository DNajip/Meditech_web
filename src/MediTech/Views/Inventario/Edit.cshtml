@model MediTech.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";































    // Cache Bust: 2026-03-15 18:21
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card card-premium border-0 shadow-lg">
                <div
                    class="card-header bg-transparent border-0 pt-3 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold text-primary mb-0">EDITAR PRODUCTO</h4>
                        <p class="text-danger small mb-0">*** Agrega modificaciones y presiona Actualizar Cambios ***
                        </p>
                    </div>
                    <div class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill fs-6">ID: @Model.IdProducto
                    </div>
                </div>
                <div class="card-body p-4 pt-2">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="IdProducto" />
                        <input type="hidden" asp-for="FechaCreacion" />

                        <div class="row g-3">
                            <!-- Sección 1: Básico -->
                            <div class="col-md-6">
                                <label asp-for="Nombre"
                                    class="form-label fw-bold small text-uppercase text-muted silver-label mb-1">Nombre
                                    del Producto</label>
                                <input asp-for="Nombre" class="form-control bg-light border-0"
                                    placeholder="Ej: Amoxicilina 500mg" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Descripcion"
                                    class="form-label fw-bold small text-uppercase text-muted silver-label mb-1">Descripción</label>
                                <input asp-for="Descripcion" class="form-control bg-light border-0"
                                    placeholder="Detalles o especificaciones..." />
                                <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            </div>

                            <!-- Sección 2: Financiero -->
                            <div class="col-md-12">
                                <label asp-for="Precio"
                                    class="form-label fw-bold small text-uppercase text-muted silver-label mb-1">Precio
                                    de Venta</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-tag"></i></span>
                                    <input asp-for="Precio" class="form-control bg-light border-0" type="number"
                                        step="0.01" />
                                </div>
                                <span asp-validation-for="Precio" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 d-none d-md-block"></div> <!-- Espaciador -->

                            <!-- Sección 3: Inventario -->
                            <div class="col-md-3">
                                <label asp-for="Stock"
                                    class="form-label fw-bold small text-uppercase text-muted silver-label mb-1">Stock
                                    Actual</label>
                                <input asp-for="Stock" class="form-control bg-light border-0 fw-bold text-primary"
                                    type="number" readonly />
                                <div class="form-text text-muted x-small mt-1">Use "Ajustar" para cambios físicos.</div>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="StockMinimo"
                                    class="form-label fw-bold small text-uppercase text-muted silver-label mb-1">Stock
                                    Mínimo</label>
                                <input asp-for="StockMinimo" class="form-control bg-light border-0" type="number" />
                                <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 d-flex align-items-center justify-content-center">
                                <div class="form-check form-switch pt-3">
                                    <input class="form-check-input" type="checkbox" asp-for="Activo">
                                    <label class="form-check-label fw-bold small" asp-for="Activo">Producto
                                        Activo</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                            <a asp-action="Index" class="btn btn-light-premium px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary-premium px-4 shadow-sm">Actualizar
                                Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-premium {
        border-radius: 20px;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        padding: 0.6rem 1rem;
        font-size: 0.95rem;
    }

    .btn-light-premium {
        background: #f8f9fa;
        color: #6c757d;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        border: 1px solid #eee;
    }

    .btn-primary-premium {
        background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
        color: white;
        border: none;
        border-radius: 10px;
    }

    .bg-soft-primary {
        background: rgba(13, 110, 253, 0.1);
    }

    .silver-label {
        letter-spacing: 0.5px;
        font-size: 0.72rem !important;
    }

    .x-small {
        font-size: 0.65rem !important;
    }
</style>
