@model MediTech.Models.Paciente
@{
    ViewData["Title"] = "Editar Paciente";
}

<style>
    .form-card {
        background: #FFFFFF;
        border-radius: 14px;
        border: 1px solid #E2E8F0;
        padding: 28px;
    }
    .form-card h4 { font-weight: 700; color: #1E293B; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid #F1F5F9; }
    .form-card label { font-size: 0.82rem; font-weight: 600; color: #475569; margin-bottom: 4px; }
    .form-card .form-control, .form-card .form-select {
        border-radius: 8px; border: 1px solid #E2E8F0; padding: 10px 14px; font-size: 0.88rem;
    }
    .form-card .form-control:focus, .form-card .form-select:focus { border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .section-title { font-size: 0.9rem; font-weight: 600; color: #3B82F6; margin: 20px 0 14px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 style="font-size:1.5rem; font-weight:700; color:#1E293B; margin:0;">
            <i class="fas fa-user-edit me-2" style="color:#3B82F6;"></i>Editar Paciente
        </h2>
        <span style="font-size:0.85rem; color:#64748B;">@Model.PrimerNombre @Model.PrimerApellido</span>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm" style="border-radius:8px;">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="IdPaciente" />
        <input type="hidden" asp-for="FechaRegistro" />
        <input type="hidden" asp-for="Estado" />

        <div class="section-title"><i class="fas fa-user me-1"></i> Datos Personales</div>
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="PrimerNombre">Primer Nombre *</label>
                <input asp-for="PrimerNombre" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label asp-for="SegundoNombre">Segundo Nombre</label>
                <input asp-for="SegundoNombre" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="PrimerApellido">Primer Apellido *</label>
                <input asp-for="PrimerApellido" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label asp-for="SegundoApellido">Segundo Apellido</label>
                <input asp-for="SegundoApellido" class="form-control" />
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-3">
                <label asp-for="Sexo">Sexo</label>
                <select asp-for="Sexo" class="form-select">
                    <option value="">Seleccionar...</option>
                    <option value="M">Masculino</option>
                    <option value="F">Femenino</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="FechaNacimiento">Fecha de Nacimiento</label>
                <input asp-for="FechaNacimiento" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="NumeroIdentificacion">N° Identificación</label>
                <input asp-for="NumeroIdentificacion" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Ocupacion">Ocupación</label>
                <input asp-for="Ocupacion" class="form-control" />
            </div>
        </div>

        <div class="section-title mt-4"><i class="fas fa-address-book me-1"></i> Contacto</div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Telefono">Teléfono *</label>
                <input asp-for="Telefono" class="form-control" required />
            </div>
            <div class="col-md-8">
                <label asp-for="Direccion">Dirección</label>
                <input asp-for="Direccion" class="form-control" />
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top:1px solid #F1F5F9;">
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary" style="border-radius:8px;">Cancelar</a>
            <button type="submit" class="btn btn-primary" style="border-radius:8px;">
                <i class="fas fa-save me-1"></i> Guardar Cambios
            </button>
        </div>
    </form>
</div>
