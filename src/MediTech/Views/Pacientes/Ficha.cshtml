</div>

@section Scripts {
<script>
    let historialData = null;
    const pacienteId = @Model.IdPaciente;
    let galeriaLoaded = false;
    let documentosLoaded = false;

    function switchTab(tabName) {
        console.log('Switching to tab:', tabName);
        // Update tabs active state
        document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
        const activeTab = document.getElementById('tab-' + tabName);
        if (activeTab) activeTab.classList.add('active');

        // Update panels visibility
        document.querySelectorAll('.tab-panel-content').forEach(el => el.classList.add('d-none'));
        const activePanel = document.getElementById('panel-' + tabName);
        if (activePanel) activePanel.classList.remove('d-none');

        // Also handle the common footer visibility (only for resumen/consulta)
        const commonFooter = document.getElementById('common-footer-panels');
        if (commonFooter) {
            if (tabName === 'resumen' || tabName === 'consulta') {
                commonFooter.classList.remove('d-none');
            } else {
                commonFooter.classList.add('d-none');
            }
        }

        // Special load for Historial
        if (tabName === 'historial' && !historialData) {
            cargarHistorial();
        }
        
        // Special load for Galeria
        if (tabName === 'galeria' && !galeriaLoaded) {
            cargarGaleria();
        }
        // Special load for Documentos
        if (tabName === 'documentos' && !documentosLoaded) {
            cargarDocumentos();
        }
    }

    function setToggle(field, value) {
        const group = document.querySelector(`.toggle-group[data-field="${field}"]`);
        if (!group) return;
        
        const btns = group.querySelectorAll('.toggle-btn');
        
        // Reset classes
        btns[0].classList.remove('active-si');
        btns[1].classList.remove('active-no');

        // Set active class
        if (value === true) btns[0].classList.add('active-si');
        else if (value === false) btns[1].classList.add('active-no');

        // Show/hide detail if exists
        const detailMap = {
            'alergias': 'histAlergiasDetalle',
            'medicamento': 'histMedicamentoDetalle',
            'otros': 'histOtrosDetalle',
            'cirugias': 'histCirugiasDetalle'
        };

        if (detailMap[field]) {
            const input = document.getElementById(detailMap[field]);
            if (value) input.classList.remove('d-none');
            else input.classList.add('d-none');
        }
    }

    async function cargarHistorial() {
        document.getElementById('historialLoading').classList.remove('d-none');
        try {
            const response = await fetch(`/Pacientes/GetHistorial/${pacienteId}`);
            const result = await response.json();
            if (result.success && result.data) {
                historialData = result.data;
                fillForm(result.data);
            }
        } catch (e) {
            console.error('Error loading history:', e);
        } finally {
            document.getElementById('historialLoading').classList.add('d-none');
        }
    }

    function fillForm(data) {
        setToggle('alergias', data.alergias);
        document.getElementById('histAlergiasDetalle').value = data.alergiasDetalle || '';
        
        setToggle('medicamento', data.tomaMedicamento);
        document.getElementById('histMedicamentoDetalle').value = data.medicamentoDetalle || '';

        setToggle('hipertension', data.hipertension);
        setToggle('diabetes', data.diabetes);
        setToggle('embarazada', data.embarazada);
        setToggle('cardiacos', data.cardiacos);
        setToggle('oncologico', data.antecedenteOncologico);
        
        setToggle('otros', data.otrosPadecimientos);
        document.getElementById('histOtrosDetalle').value = data.otrosPadecimientosDetalle || '';

        setToggle('alcohol', data.consumeAlcohol);
        setToggle('fuma', data.fumaCigarrillos);
        setToggle('ejercicio', data.realizaEjercicio);

        setToggle('cirugias', data.cirugiasEsteticas);
        document.getElementById('histCirugiasDetalle').value = data.cirugiasEsteticasDetalle || '';
    }

    async function guardarHistorial() {
        const data = {
            idPaciente: pacienteId,
            alergias: document.querySelector('.toggle-group[data-field="alergias"] .active-si') != null,
            alergiasDetalle: document.getElementById('histAlergiasDetalle').value,
            tomaMedicamento: document.querySelector('.toggle-group[data-field="medicamento"] .active-si') != null,
            medicamentoDetalle: document.getElementById('histMedicamentoDetalle').value,
            hipertension: document.querySelector('.toggle-group[data-field="hipertension"] .active-si') != null,
            diabetes: document.querySelector('.toggle-group[data-field="diabetes"] .active-si') != null,
            embarazada: document.querySelector('.toggle-group[data-field="embarazada"] .active-si') != null,
            cardiacos: document.querySelector('.toggle-group[data-field="cardiacos"] .active-si') != null,
            antecedenteOncologico: document.querySelector('.toggle-group[data-field="oncologico"] .active-si') != null,
            otrosPadecimientos: document.querySelector('.toggle-group[data-field="otros"] .active-si') != null,
            otrosPadecimientosDetalle: document.getElementById('histOtrosDetalle').value,
            consumeAlcohol: document.querySelector('.toggle-group[data-field="alcohol"] .active-si') != null,
            fumaCigarrillos: document.querySelector('.toggle-group[data-field="fuma"] .active-si') != null,
            realizaEjercicio: document.querySelector('.toggle-group[data-field="ejercicio"] .active-si') != null,
            cirugiasEsteticas: document.querySelector('.toggle-group[data-field="cirugias"] .active-si') != null,
            cirugiasEsteticasDetalle: document.getElementById('histCirugiasDetalle').value
        };

        const btn = document.querySelector('button[onclick="guardarHistorial()"]');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
        btn.disabled = true;

        try {
            const response = await fetch('/Pacientes/GuardarHistorial', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if (result.success) {
                // Success feedback
                const check = document.createElement('i');
                check.className = 'fas fa-check-circle ms-2';
                btn.parentElement.appendChild(check);
                setTimeout(() => check.remove(), 3000);
                
                historialData = data;
                alert('¡Historial guardado exitosamente!');
            } else {
                alert('Error al guardar: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    // --- GALLERY LOGIC ---
    let selectedFile = null;

    // Drag and drop helper
    function initDragAndDrop() {
        const dropZone = document.getElementById('dropZone');
        if (!dropZone) return;

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, e => {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.add('dragover'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('dragover'), false);
        });

        dropZone.addEventListener('drop', e => {
            const dt = e.dataTransfer;
            const files = dt.files;
            if (files.length > 0) prepareFile(files[0]);
        }, false);
    }

    function handleFileSelect(e) {
        if (e.target.files.length > 0) prepareFile(e.target.files[0]);
    }

    function prepareFile(file) {
        if (!file.type.startsWith('image/')) {
            alert('Solo se permiten archivos de imagen.');
            return;
        }
        selectedFile = file;
        
        // Show preview info
        const preview = document.getElementById('filePreview');
        const previewImg = document.getElementById('previewImg');
        const nameDisp = document.getElementById('fileNameDisp');
        const dropContent = document.getElementById('dropZoneContent');

        if (preview && previewImg && nameDisp) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                preview.classList.remove('d-none');
                if (dropContent) dropContent.classList.add('d-none');
                nameDisp.textContent = file.name;
            }
            reader.readAsDataURL(file);
        }
    }

    async function uploadSelectedFile() {
        if (!selectedFile) {
            alert('Por favor, seleccione una foto primero haciendo clic en la zona de carga.');
            return;
        }

        const titulo = document.getElementById('fotoTitulo').value;
        const formData = new FormData();
        formData.append('idPaciente', pacienteId);
        formData.append('titulo', titulo);
        formData.append('file', selectedFile);

        const btn = document.getElementById('btnSubir');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Subiendo...';
        btn.disabled = true;

        try {
            const response = await fetch('/Galeria/UploadFoto', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            if (result.success) {
                // Clear state
                selectedFile = null;
                document.getElementById('fileInput').value = '';
                document.getElementById('fotoTitulo').value = '';
                document.getElementById('filePreview').classList.add('d-none');
                const dropContent = document.getElementById('dropZoneContent');
                if (dropContent) dropContent.classList.remove('d-none');
                
                cargarGaleria();
                alert('¡Foto guardada con éxito!');
            } else {
                alert('Error: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    async function cargarGaleria() {
        const grid = document.getElementById('galeriaGrid');
        try {
            const response = await fetch(`/Galeria/GetFotos/${pacienteId}`);
            const result = await response.json();
            if (result.success) renderGaleria(result.data);
        } catch (e) {
            console.error(e);
            grid.innerHTML = '<div class="text-center w-100 py-4 text-danger">Error al cargar la galería.</div>';
        } finally {
            galeriaLoaded = true;
        }
    }

    const FOTOS_PER_PAGE = 8;
    let allFotos = [];
    let currentPage = 1;

    function renderGaleria(fotos) {
        allFotos = fotos;
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const grid = document.getElementById('galeriaGrid');
        const pag = document.getElementById('galeriaPagination');
        if (!grid) return;

        if (allFotos.length === 0) {
            grid.innerHTML = '<div class="text-center w-100 py-5 text-muted"><i class="fas fa-images fs-2 d-block mb-3 opacity-25"></i>No hay fotos registradas aún.</div>';
            if (pag) pag.innerHTML = '';
            return;
        }

        const totalPages = Math.ceil(allFotos.length / FOTOS_PER_PAGE);
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * FOTOS_PER_PAGE;
        const pageFotos = allFotos.slice(start, start + FOTOS_PER_PAGE);

        grid.innerHTML = pageFotos.map(foto => `
            <div class="photo-item">
                <button class="photo-delete" onclick="eliminarFoto(${foto.idFoto})" title="Eliminar">
                    <i class="fas fa-trash-alt"></i>
                </button>
                <div class="photo-thumb-container" onclick="verFotoFull(${foto.idFoto})">
                    <img src="/Galeria/GetFotoContent/${foto.idFoto}" class="photo-thumb" alt="${foto.titulo || 'Foto clínica'}">
                </div>
                <div class="photo-info">
                    <div class="photo-title">${foto.titulo || 'Sin título'}</div>
                    <div class="photo-date">${foto.fecha}</div>
                </div>
            </div>
        `).join('');

        // Render pagination controls
        if (pag) {
            if (totalPages <= 1) { pag.innerHTML = ''; return; }
            let html = `<button onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}><i class="fas fa-chevron-left"></i></button>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
            }
            html += `<button onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}><i class="fas fa-chevron-right"></i></button>`;
            html += `<span class="page-info">${allFotos.length} fotos</span>`;
            pag.innerHTML = html;
        }
    }

    function goToPage(page) {
        const totalPages = Math.ceil(allFotos.length / FOTOS_PER_PAGE);
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderPage();
        // Scroll to top of gallery
        document.getElementById('galeriaGrid')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    async function eliminarFoto(id) {
        if (!confirm('¿Está seguro de eliminar esta foto?')) return;
        try {
            const response = await fetch(`/Galeria/DeleteFoto/${id}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) cargarGaleria();
            else alert(result.message);
        } catch (e) { console.error(e); alert('Error al eliminar.'); }
    }

    function verFotoFull(id) {
        const modal = document.getElementById('photoModal');
        const modalImg = document.getElementById('modalImg');
        const modalCaption = document.getElementById('modalCaption');
        
        if (!modal || !modalImg) return;

        modalImg.src = `/Galeria/GetFotoContent/${id}`;
        
        // Get title from the specific item in the grid
        const photoItem = document.querySelector(`.photo-item button[onclick="eliminarFoto(${id})"]`)?.parentElement;
        const title = photoItem?.querySelector('.photo-title')?.textContent || '';
        modalCaption.textContent = title === 'Sin título' ? '' : title;

        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevent scrolling
    }

    function closePhotoModal() {
        const modal = document.getElementById('photoModal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    }

    // ============ DOCUMENTOS MODULE ============
    let selectedDocFile = null;
    const DOCS_PER_PAGE = 8;
    let allDocs = [];
    let currentDocPage = 1;

    function initDocDragAndDrop() {
        const zone = document.getElementById('docDropZone');
        if (!zone) return;
        ['dragenter','dragover','dragleave','drop'].forEach(e => {
            zone.addEventListener(e, ev => { ev.preventDefault(); ev.stopPropagation(); });
        });
        zone.addEventListener('dragenter', () => zone.classList.add('drag-over'));
        zone.addEventListener('dragover', () => zone.classList.add('drag-over'));
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            zone.classList.remove('drag-over');
            const file = e.dataTransfer.files[0];
            if (file) prepareDocFile(file);
        });
    }

    function handleDocFileSelect(event) {
        const file = event.target.files[0];
        if (file) prepareDocFile(file);
    }

    function getDocIconClass(contentType, fileName) {
        if (contentType.includes('pdf')) return { icon: 'fas fa-file-pdf', css: 'pdf' };
        if (contentType.includes('word') || contentType.includes('document') || fileName.endsWith('.docx') || fileName.endsWith('.doc')) return { icon: 'fas fa-file-word', css: 'word' };
        if (contentType.includes('excel') || contentType.includes('sheet') || fileName.endsWith('.xlsx') || fileName.endsWith('.xls')) return { icon: 'fas fa-file-excel', css: 'excel' };
        if (contentType.startsWith('image/')) return { icon: 'fas fa-file-image', css: 'image' };
        return { icon: 'fas fa-file', css: 'other' };
    }

    function formatFileSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }

    function prepareDocFile(file) {
        selectedDocFile = file;
        const preview = document.getElementById('docFilePreview');
        const icon = document.getElementById('docPreviewIcon');
        const nameDisp = document.getElementById('docFileNameDisp');
        const sizeDisp = document.getElementById('docFileSizeDisp');
        const dropContent = document.getElementById('docDropZoneContent');

        if (preview && nameDisp) {
            const iconInfo = getDocIconClass(file.type, file.name);
            icon.className = iconInfo.icon + ' fs-4';
            nameDisp.textContent = file.name;
            sizeDisp.textContent = formatFileSize(file.size);
            preview.classList.remove('d-none');
            if (dropContent) dropContent.classList.add('d-none');
        }
    }

    async function uploadDocumento() {
        if (!selectedDocFile) { alert('Seleccione un archivo primero.'); return; }

        const formData = new FormData();
        formData.append('idPaciente', pacienteId);
        formData.append('titulo', document.getElementById('docTitulo').value || '');
        formData.append('file', selectedDocFile);

        const btn = document.getElementById('btnSubirDoc');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Subiendo...';
        btn.disabled = true;

        try {
            const response = await fetch('/Documentos/UploadDocumento', { method: 'POST', body: formData });
            const result = await response.json();
            if (result.success) {
                selectedDocFile = null;
                document.getElementById('docFileInput').value = '';
                document.getElementById('docTitulo').value = '';
                document.getElementById('docFilePreview').classList.add('d-none');
                const dropContent = document.getElementById('docDropZoneContent');
                if (dropContent) dropContent.classList.remove('d-none');
                cargarDocumentos();
                alert('\u00a1Documento guardado con \u00e9xito!');
            } else {
                alert('Error: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    async function cargarDocumentos() {
        const list = document.getElementById('documentosList');
        try {
            const response = await fetch(`/Documentos/GetDocumentos/${pacienteId}`);
            const result = await response.json();
            if (result.success) {
                allDocs = result.data;
                currentDocPage = 1;
                renderDocsPage();
            }
        } catch (e) {
            console.error(e);
            list.innerHTML = '<div class="text-center w-100 py-4 text-danger">Error al cargar documentos.</div>';
        } finally {
            documentosLoaded = true;
        }
    }

    function renderDocsPage() {
        const list = document.getElementById('documentosList');
        const pag = document.getElementById('docsPagination');
        if (!list) return;

        if (allDocs.length === 0) {
            list.innerHTML = '<div class="text-center w-100 py-5 text-muted"><i class="fas fa-folder-open fs-2 d-block mb-3 opacity-25"></i>No hay documentos registrados a\u00fan.</div>';
            if (pag) pag.innerHTML = '';
            return;
        }

        const totalPages = Math.ceil(allDocs.length / DOCS_PER_PAGE);
        if (currentDocPage > totalPages) currentDocPage = totalPages;
        const start = (currentDocPage - 1) * DOCS_PER_PAGE;
        const pageDocs = allDocs.slice(start, start + DOCS_PER_PAGE);

        list.innerHTML = pageDocs.map(doc => {
            const iconInfo = getDocIconClass(doc.contentType, doc.nombreArchivo);
            const displayName = doc.titulo || doc.nombreArchivo;
            return `
                <div class="doc-item">
                    <div class="doc-icon ${iconInfo.css}"><i class="${iconInfo.icon}"></i></div>
                    <div class="doc-info">
                        <div class="doc-name" title="${doc.nombreArchivo}">${displayName}</div>
                        <div class="doc-meta">${doc.nombreArchivo} &bull; ${formatFileSize(doc.tamano)} &bull; ${doc.fecha}</div>
                    </div>
                    <div class="doc-actions">
                        <button class="btn-doc-download" onclick="descargarDocumento(${doc.idDocumento})" title="Descargar"><i class="fas fa-download"></i></button>
                        <button class="btn-doc-delete" onclick="eliminarDocumento(${doc.idDocumento})" title="Eliminar"><i class="fas fa-trash-alt"></i></button>
                    </div>
                </div>`;
        }).join('');

        // Pagination
        if (pag) {
            if (totalPages <= 1) { pag.innerHTML = ''; return; }
            let html = `<button onclick="goToDocPage(${currentDocPage - 1})" ${currentDocPage === 1 ? 'disabled' : ''}><i class="fas fa-chevron-left"></i></button>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="${i === currentDocPage ? 'active' : ''}" onclick="goToDocPage(${i})">${i}</button>`;
            }
            html += `<button onclick="goToDocPage(${currentDocPage + 1})" ${currentDocPage === totalPages ? 'disabled' : ''}><i class="fas fa-chevron-right"></i></button>`;
            html += `<span class="page-info">${allDocs.length} documentos</span>`;
            pag.innerHTML = html;
        }
    }

    function goToDocPage(page) {
        const totalPages = Math.ceil(allDocs.length / DOCS_PER_PAGE);
        if (page < 1 || page > totalPages) return;
        currentDocPage = page;
        renderDocsPage();
        document.getElementById('documentosList')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function descargarDocumento(id) {
        window.open(`/Documentos/DownloadDocumento/${id}`, '_blank');
    }

    async function eliminarDocumento(id) {
        if (!confirm('\u00bfEst\u00e1 seguro de eliminar este documento?')) return;
        try {
            const response = await fetch(`/Documentos/DeleteDocumento/${id}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) cargarDocumentos();
            else alert(result.message);
        } catch (e) { console.error(e); alert('Error al eliminar.'); }
    }

    // Initialize D&D on load
    document.addEventListener('DOMContentLoaded', () => {
        initDragAndDrop();
        initDocDragAndDrop();
    });
</script>
}
