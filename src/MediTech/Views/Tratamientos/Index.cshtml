@model IEnumerable<MediTech.Models.Tratamiento>
@{
    ViewData["Title"] = "Tratamientos";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .page-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1E293B;
        margin: 0;
    }
    .page-header .subtitle {
        font-size: 0.85rem;
        color: #64748B;
    }

    .tratamientos-table {
        background: #FFFFFF;
        border-radius: 14px;
        border: 1px solid #E2E8F0;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .tratamientos-table table {
        width: 100%;
        border-collapse: collapse;
    }
    .tratamientos-table th {
        background: #F8FAFC;
        padding: 12px 16px;
        font-size: 0.78rem;
        font-weight: 600;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: left;
        border-bottom: 1px solid #E2E8F0;
    }
    .tratamientos-table td {
        padding: 14px 16px;
        font-size: 0.88rem;
        color: #334155;
        border-bottom: 1px solid #F1F5F9;
    }
    .tratamientos-table tr:hover td { background: #F8FAFC; }
    .tratamientos-table tr:last-child td { border-bottom: none; }

    .price-cell {
        font-weight: 700;
        color: #0F172A;
    }
    .moneda-badge {
        font-size: 0.7rem;
        padding: 2px 6px;
        background: #F1F5F9;
        border-radius: 4px;
        margin-left: 4px;
        color: #64748B;
    }

    .badge-active {
        background: #D1FAE5; color: #065F46;
        font-size: 0.72rem; padding: 3px 10px;
        border-radius: 20px; font-weight: 600;
    }
    .badge-inactive {
        background: #FEE2E2; color: #991B1B;
        font-size: 0.72rem; padding: 3px 10px;
        border-radius: 20px; font-weight: 600;
    }

    .action-link {
        color: #3B82F6;
        text-decoration: none;
        font-weight: 500;
        font-size: 1rem;
        margin-right: 12px;
        transition: transform 0.2s;
        display: inline-block;
    }
    .action-link:hover { transform: scale(1.1); }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #94A3B8;
    }
    .empty-state i { font-size: 3rem; margin-bottom: 12px; color: #CBD5E1; }

    .toast-success {
        position: fixed; top: 80px; right: 28px;
        background: #10B981; color: white;
        padding: 12px 20px; border-radius: 8px;
        font-size: 0.85rem; font-weight: 500;
        z-index: 9999; animation: slideIn 0.3s;
        box-shadow: 0 4px 12px rgba(16,185,129,0.3);
    }
    @@keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-success" id="toast">
        <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-hand-holding-medical me-2" style="color:#10B981;"></i>Tratamientos</h2>
        <span class="subtitle">Catálogo de servicios y especialidades médicas</span>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary px-4" style="border-radius:10px; font-weight:600;">
        <i class="fas fa-plus me-1"></i> Nuevo Tratamiento
    </a>
</div>

<div class="tratamientos-table">
    @if (Model.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Tratamiento</th>
                    <th>Precio</th>
                    <th>Detalles Clínicos</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.NombreTratamiento</div>
                            <small class="text-secondary">#@item.IdTratamiento</small>
                        </td>
                        <td class="price-cell">
                            @(item.Moneda?.Simbolo ?? "$") @(item.Precio?.ToString("N2") ?? "0.00")
                            <span class="moneda-badge">@item.Moneda?.Codigo</span>
                        </td>
                        <td>
                            <div style="font-size: 0.75rem;">
                                <div><i class="fas fa-vial me-1"></i> <strong>Vía:</strong> @(item.ViaAdministracion ?? "N/A")</div>
                                <div><i class="fas fa-clock me-1"></i> <strong>Frec:</strong> @(item.Frecuencia ?? "N/A")</div>
                            </div>
                        </td>
                        <td>
                            <span class="@(item.IdEstado == 1 ? "badge-active" : "badge-inactive")">
                                @(item.Estado?.DescEstado ?? (item.IdEstado == 1 ? "Activo" : "Inactivo"))
                            </span>
                        </td>
                        <td>
                            <a href="@Url.Action("Edit", new { id = item.IdTratamiento })" class="action-link text-warning" title="Editar"><i class="fas fa-edit"></i></a>
                            <a href="@Url.Action("Details", new { id = item.IdTratamiento })" class="action-link text-info" title="Ver Detalles"><i class="fas fa-info-circle"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <div><i class="fas fa-notes-medical"></i></div>
            <h5>Sin tratamientos registrados</h5>
            <p>Comienza agregando los servicios y especialidades que ofrece la clínica.</p>
            <a href="@Url.Action("Create")" class="btn btn-outline-primary mt-3">Registrar Primer Tratamiento</a>
        </div>
    }
</div>

@section Scripts {
<script>
    setTimeout(() => { var t = document.getElementById('toast'); if (t) t.style.opacity = '0'; setTimeout(() => { if(t) t.remove(); }, 500); }, 4000);
</script>
}
