@model MediTech.Models.Tratamiento
@{
    ViewData["Title"] = "Detalles del Tratamiento";
}

<style>
    .details-container {
        background: #FFFFFF;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        padding: 32px;
        max-width: 800px;
        margin: 0 auto;
    }
    .detail-card {
        background: #F8FAFC;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #E2E8F0;
        height: 100%;
    }
    .detail-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
        display: block;
    }
    .detail-value {
        font-size: 1rem;
        font-weight: 500;
        color: #1E293B;
    }
    .price-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0F172A;
    }
    .moneda-pill {
        background: #E0F2FE;
        color: #0369A1;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
    }
    .section-header {
        font-size: 1.1rem;
        font-weight: 700;
        color: #334155;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #E2E8F0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="mb-4 d-flex align-items-center justify-content-between">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Información del Tratamiento</h2>
        <p class="text-muted small mb-0">Expediente técnico #@Model.IdTratamiento</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Index")" class="btn btn-light" style="border-radius:10px;">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </a>
        <a href="@Url.Action("Edit", new { id = Model.IdTratamiento })" class="btn btn-warning text-white" style="border-radius:10px; font-weight:600;">
            <i class="fas fa-edit me-1"></i> Editar Datos
        </a>
    </div>
</div>

<div class="details-container">
    <div class="row g-4">
        <!-- Encabezado de Identidad -->
        <div class="col-12 text-center mb-2">
            <div class="display-6 fw-bold text-primary mb-1">@Model.NombreTratamiento</div>
            <span class="@(Model.IdEstado == 1 ? "badge bg-success" : "badge bg-danger") px-3 py-2 rounded-pill shadow-sm">
                @(Model.Estado?.DescEstado ?? (Model.IdEstado == 1 ? "ACTIVO" : "INACTIVO"))
            </span>
        </div>

        <!-- Información Económica -->
        <div class="col-12">
            <div class="section-header text-primary">
                <i class="fas fa-money-bill-wave"></i> Valor Comercial
            </div>
            <div class="detail-card text-center">
                <span class="detail-label">Costo por Sesión / Servicio</span>
                <div class="d-flex align-items-baseline justify-content-center gap-2">
                    <span class="price-value">@(Model.Moneda?.Simbolo ?? "$") @(Model.Precio?.ToString("N2") ?? "0.00")</span>
                    <span class="moneda-pill">@Model.Moneda?.Codigo</span>
                </div>
            </div>
        </div>

        <!-- Detalles Médicos -->
        <div class="col-12 mt-4">
            <div class="section-header text-success">
                <i class="fas fa-stethoscope"></i> Especificaciones Clínicas
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="detail-card">
                        <span class="detail-label"><i class="fas fa-pills me-1"></i> Dosificación</span>
                        <span class="detail-value">@(string.IsNullOrEmpty(Model.Dosis) ? "No especificada" : Model.Dosis)</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-card">
                        <span class="detail-label"><i class="fas fa-syringe me-1"></i> Vía de Admin.</span>
                        <span class="detail-value">@(string.IsNullOrEmpty(Model.ViaAdministracion) ? "No especificada" : Model.ViaAdministracion)</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-card">
                        <span class="detail-label"><i class="fas fa-redo me-1"></i> Frecuencia</span>
                        <span class="detail-value">@(string.IsNullOrEmpty(Model.Frecuencia) ? "Según criterio médico" : Model.Frecuencia)</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-card">
                        <span class="detail-label"><i class="fas fa-hourglass-half me-1"></i> Duración Est.</span>
                        <span class="detail-value">@(string.IsNullOrEmpty(Model.DuracionTratamiento) ? "Variable" : Model.DuracionTratamiento)</span>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.FechaActualizacion != null)
        {
            <div class="col-12 text-center mt-4">
                <small class="text-muted">
                    <i class="fas fa-history me-1"></i> Última actualización del catálogo: @Model.FechaActualizacion?.ToString("dd/MM/yyyy hh:mm tt")
                </small>
            </div>
        }
    </div>
</div>
