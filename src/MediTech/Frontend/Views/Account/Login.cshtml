@model dynamic
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediTech</title>
    <!-- Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-color: #00bcd4; /* Cyan from login.png */
            --primary-hover: #0097a7;
            --bg-color: #f8fafc;
            --text-color: #475569;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(at 0% 0%, rgba(0, 188, 212, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(0, 188, 212, 0.05) 0px, transparent 50%);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            color: var(--text-color);
        }

        .login-container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .login-card {
            background: #ffffff;
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .login-header {
            padding: 40px 40px 20px;
            text-align: center;
        }

        .login-logo {
            max-height: 70px;
            margin-bottom: 24px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
        }

        .login-header h4 {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 8px;
            font-size: 1.5rem;
        }

        .card-body {
            padding: 20px 40px 40px;
        }

        .form-label {
            font-weight: 500;
            font-size: 0.9rem;
            margin-bottom: 8px;
            color: #64748b;
        }

        .form-control {
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(0, 188, 212, 0.1);
            outline: none;
        }

        .btn-login {
            background-color: var(--primary-color);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            font-size: 1rem;
            color: white;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-login:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 188, 212, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .alert-custom {
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.85rem;
            margin-bottom: 24px;
            background-color: #fef2f2;
            border: 1px solid #fee2e2;
            color: #b91c1c;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Micro-animations */
        .login-card {
            animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@media (max-width: 575.98px) {
            .login-header { padding: 30px 20px 15px; }
            .card-body { padding: 15px 20px 30px; }
            .login-logo { max-height: 55px; margin-bottom: 16px; }
            .login-header h4 { font-size: 1.25rem; }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="card login-card">
            <div class="login-header">
                <img src="~/images/logo.png" alt="MediTech Logo" class="login-logo" asp-append-version="true" />
                <h4>Acceso al Sistema</h4>
            </div>
            <div class="card-body">
                @if (ViewData["ErrorMessage"] != null)
                {
                    <div class="alert-custom">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@ViewData["ErrorMessage"]</span>
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    
                    <div class="mb-4">
                        <label for="username" class="form-label">Usuario</label>
                        <input type="text" class="form-control" id="username" name="username" required 
                               placeholder="Nombre de usuario" autofocus>
                    </div>
                    
                    <div class="mb-4">
                        <label for="password" class="form-label">Contraseña</label>
                        <input type="password" class="form-control" id="password" name="password" required 
                               placeholder="********">
                    </div>
                    
                    <div class="d-grid">
                        <button type="submit" class="btn btn-login">
                            Iniciar Sesión
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <p class="text-center mt-4 text-muted small">
            &copy; @DateTime.Now.Year MediTech System. Todos los derechos reservados.
        </p>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
