@model IEnumerable<MediTech.Backend.Models.Consulta>
@{
    ViewData["Title"] = "Historial de Consultas";
}

<style>
    .consultas-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
        overflow-x: auto;
    }
    .table-modern thead {
        background: #f8f9fa;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }
    .table-modern th {
        padding: 1.5rem 1rem;
        border: none;
        color: #6c757d;
    }
    .table-modern td {
        padding: 1.2rem 1rem;
        vertical-align: middle;
        border-top: 1px solid #f1f3f5;
    }
    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
</style>

<div class="page-header page-header-premium mb-4">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Clínica: Consultas Médicas</h2>
        <p class="text-muted mb-0 d-none d-sm-block">Gestión de expedientes y atención clínica diaria</p>
    </div>
    <a href="@Url.Action("Index", "Citas")" class="btn btn-primary-premium d-flex align-items-center gap-2 px-4 shadow-sm">
        <i class="fas fa-calendar-check"></i> <span class="d-none d-sm-inline">Nueva Atención</span><span class="d-sm-none">Nueva</span>
    </a>
</div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 animate__animated animate__bounceIn" role="alert" style="border-radius: 15px;">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="consultas-card table-responsive-premium animate__animated animate__fadeInUp">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Paciente</th>
                        <th>Médico</th>
                        <th>Diagnóstico</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded text-primary">
                                        <i class="fas fa-calendar-day"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.FechaConsulta.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-muted">@item.FechaConsulta.ToString("hh:mm tt")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">
                                    @item.Cita?.Paciente?.Persona?.PrimerNombre @item.Cita?.Paciente?.Persona?.PrimerApellido
                                </div>
                                <div class="small text-muted">ID: #@item.Cita?.Paciente?.IdPaciente</div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="https://ui-avatars.com/api/?name=@(item.Medico?.Persona?.PrimerNombre)+@(item.Medico?.Persona?.PrimerApellido)&background=random" class="rounded-circle" width="32" />
                                    <div class="small fw-medium">Dr. @item.Medico?.Persona?.PrimerNombre</div>
                                </div>
                            </td>
                            <td style="max-width: 250px;">
                                <div class="text-truncate" title="@item.DiagnosticoPrincipal">
                                    @(string.IsNullOrEmpty(item.DiagnosticoPrincipal) ? "Sin diagnóstico registrado" : item.DiagnosticoPrincipal)
                                </div>
                            </td>
                            <td>
                                <span class="status-badge bg-success bg-opacity-10 text-success">
                                    <i class="fas fa-check-circle me-1"></i> Finalizada
                                </span>
                            </td>
                            <td class="text-end px-4">
                                <div class="dropdown">
                                    <button class="btn btn-light btn-sm" type="button" data-bs-toggle="dropdown" style="border-radius: 8px;">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius: 12px;">
                                        <li><a class="dropdown-item" href="@Url.Action("Details", new { id = item.IdConsulta })"><i class="fas fa-eye me-2 text-primary"></i>Ver Expediente</a></li>
                                        <li><a class="dropdown-item" href="@Url.Action("Edit", new { id = item.IdConsulta })"><i class="fas fa-edit me-2 text-warning"></i>Editar</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-file-medical me-2"></i>Generar Receta</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
    </div>
</div>

