@model MediTech.Backend.Models.Consulta
@{
    ViewData["Title"] = "Nueva Atención Médica";
}

<style>
    .form-section {
        background: #ffffff;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid #e2e8f0;
        margin-bottom: 24px;
    }
    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a365d;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .vital-input {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px;
        transition: all 0.2s;
    }
    .vital-input:focus {
        border-color: #3182ce;
        box-shadow: none;
        background: #ffffff;
    }
    .patient-summary {
        background: linear-gradient(135deg, #2b6cb0, #2c5282);
        color: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 24px;
    }
</style>

<div class="container-fluid py-4">
    <div class="patient-summary d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="avatar-bg bg-white bg-opacity-20 rounded-circle p-1">
                <img src="https://ui-avatars.com/api/?name=@(Model.Cita?.Paciente?.Persona?.PrimerNombre)+@(Model.Cita?.Paciente?.Persona?.PrimerApellido)&background=fff&color=2c5282" class="rounded-circle" width="48" height="48" />
            </div>
            <div>
                <h4 class="fw-bold mb-0">@Model.Cita?.Paciente?.Persona?.PrimerNombre @Model.Cita?.Paciente?.Persona?.PrimerApellido</h4>
                <div class="small opacity-75">Expediente: #@Model.Cita?.Paciente?.IdPaciente | Procedimiento: @Model.Cita?.Tratamiento?.NombreTratamiento</div>
            </div>
        </div>
        <div class="text-end">
            <div class="small opacity-75">Cita Programada</div>
            <div class="fw-bold text-white">@Model.Cita?.Fecha.ToShortDateString() | @Model.Cita?.HoraInicio.ToString(@"hh\:mm")</div>
        </div>
    </div>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="IdCita" />
        <input type="hidden" asp-for="IdMedico" />

        <div class="row">
            <!-- Columna Izquierda: Signos Vitales -->
            <div class="col-lg-4">
                <div class="form-section h-100">
                    <div class="section-title text-danger">
                        <i class="fas fa-heartbeat"></i> Signos Vitales
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Presión Arterial (Sys/Dia)</label>
                        <input name="signos.PresionArterial" class="form-control vital-input" placeholder="120/80" />
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Temperatura (°C)</label>
                            <input name="signos.Temperatura" class="form-control vital-input" type="number" step="0.1" placeholder="36.5" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Frec. Cardíaca (LPM)</label>
                            <input name="signos.FrecuenciaCardiaca" class="form-control vital-input" type="number" placeholder="70" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Sat. Oxígeno (%)</label>
                            <input name="signos.SaturacionOxigeno" class="form-control vital-input" type="number" placeholder="98" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Peso (kg)</label>
                            <input name="signos.Peso" class="form-control vital-input" type="number" step="0.01" />
                        </div>
                        <div class="col-12 text-center">
                            <label class="form-label small fw-bold">Altura (cm)</label>
                            <input name="signos.Altura" class="form-control vital-input" type="number" step="0.5" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna Derecha: Clínica -->
            <div class="col-lg-8">
                <div class="form-section">
                    <div class="section-title text-primary">
                        <i class="fas fa-notes-medical"></i> Registro de Atención
                    </div>

                    <div class="mb-4">
                        <label asp-for="MotivoConsulta" class="form-label fw-bold">Motivo de la Consulta / Síntomas</label>
                        <textarea asp-for="MotivoConsulta" class="form-control" rows="3" placeholder="Describa el motivo expresado por el paciente..." style="border-radius: 12px;"></textarea>
                        <span asp-validation-for="MotivoConsulta" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DiagnosticoPrincipal" class="form-label fw-bold">Diagnóstico Principal</label>
                        <input asp-for="DiagnosticoPrincipal" class="form-control" placeholder="Ej: Gingivitis crónica, Caries dental..." style="border-radius: 12px; height: 50px;" />
                        <span asp-validation-for="DiagnosticoPrincipal" class="text-danger"></span>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Observaciones" class="form-label fw-bold">Observaciones y Plan de Tratamiento</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="5" placeholder="Indique las recomendaciones médicas, recetas u observaciones adicionales..." style="border-radius: 12px;"></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-3 justify-content-end">
                    <a href="@Url.Action("Index", "Citas")" class="btn btn-light px-4 py-3" style="border-radius: 12px;">Descartar</a>
                    <button type="submit" class="btn btn-primary px-5 py-3 shadow-sm" style="border-radius: 12px; font-weight: 700;">
                        <i class="fas fa-save me-2"></i> Finalizar y Guardar Consulta
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

