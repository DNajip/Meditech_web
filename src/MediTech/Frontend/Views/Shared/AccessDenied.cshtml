@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-danger shadow">
                <div class="card-body py-5">
                    <i class="bi bi-shield-lock-fill text-danger display-1 mb-4"></i>
                    <h1 class="text-danger fw-bold">Acceso Denegado</h1>
                    <p class="lead text-muted mb-4">Lo sentimos, no tienes los permisos necesarios para acceder a esta sección.</p>
                    <hr class="my-4">
                    <div class="d-grid gap-2 d-md-block">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-house-door me-2"></i>Ir al Inicio
                        </a>
                        <button onclick="history.back()" class="btn btn-danger px-4">
                            <i class="bi bi-arrow-left me-2"></i>Regresar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
