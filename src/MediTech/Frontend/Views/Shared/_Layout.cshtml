@{
    var userName = User.Identity?.IsAuthenticated == true ? User.Identity.Name : "";
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var allowedModules = User.Claims.Where(c => c.Type == "Module").Select(c => c.Value).ToList();
    
    var initials = "";
    if (!string.IsNullOrEmpty(userName))
    {
        var parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = string.Join("", parts.Select(p => p[0])).ToUpper();
        if (initials.Length > 2) initials = initials.Substring(0, 2);
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediTech</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/meditech-notifications.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --sidebar-width: 250px;
            --topbar-height: 60px;
            --primary-blue: #3B82F6;
            --primary-dark: #1E40AF;
            --bg-light: #F8FAFC;
            --sidebar-bg: #FFFFFF;
            --text-primary: #1E293B;
            --text-secondary: #64748B;
            --border-color: #E2E8F0;
        }

        * { font-family: 'Inter', sans-serif; }

        body {
            margin: 0;
            background-color: var(--bg-light);
            overflow-x: hidden;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed;
            left: 0; top: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform 0.3s;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-brand img { height: 36px; }
        .sidebar-brand span {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary-blue);
        }

        .sidebar-section-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-secondary);
            padding: 20px 20px 6px;
            font-weight: 600;
        }

        .sidebar-nav { list-style: none; padding: 0; margin: 0; flex: 1; }

        .sidebar-nav li a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 20px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }

        .sidebar-nav li a:hover,
        .sidebar-nav li a.active {
            color: var(--primary-blue);
            background-color: #EFF6FF;
            border-left-color: var(--primary-blue);
        }

        .sidebar-nav li a i { width: 20px; text-align: center; font-size: 1rem; }

        /* ===== TOPBAR ===== */
        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: #FFFFFF;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            z-index: 999;
        }

        .topbar-search {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-light);
            border-radius: 8px;
            padding: 8px 16px;
            min-width: 280px;
        }

        .topbar-search input {
            border: none;
            background: transparent;
            outline: none;
            font-size: 0.85rem;
            width: 100%;
            color: var(--text-primary);
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: var(--primary-blue);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.8rem;
        }

        .user-info { text-align: right; }
        .user-info .name { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); }
        .user-info .role { font-size: 0.72rem; color: var(--text-secondary); }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            padding: 28px;
            min-height: calc(100vh - var(--topbar-height));
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 991.98px) {
            .sidebar { 
                transform: translateX(-100%); 
                box-shadow: 0 0 20px rgba(0,0,0,0.1);
            }
            .sidebar.show { 
                transform: translateX(0); 
            }
            .topbar { 
                left: 0 !important; 
                padding: 0 15px; 
            }
            .main-content { 
                margin-left: 0 !important; 
                padding: 16px 12px; /* Reducido para maximizar espacio en móvil */
            }
            
            /* Sidebar Overlay */
            .sidebar-overlay {
                position: fixed;
                top: 0; left: 0;
                width: 100%; height: 100%;
                background: rgba(0,0,0,0.4);
                backdrop-filter: blur(2px);
                z-index: 998;
                display: none;
                opacity: 0;
                transition: opacity 0.3s;
            }
            .sidebar-overlay.show {
                display: block;
                opacity: 1;
            }

            .topbar-search { display: none; } /* Hide search in mobile topbar to save space */
            
            .topbar .badge { 
                font-size: 0.65rem; 
                padding: 4px 8px;
            }
            .topbar .d-flex.gap-3 { gap: 0.5rem !important; }
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="~/images/logo.png" alt="MediTech" />
                <span class="d-lg-none">MediTech</span>
            </div>
            <button type="button" class="btn text-secondary d-lg-none p-3" id="sidebarClose" aria-label="Cerrar menú">
                <i class="fas fa-times fs-4"></i>
            </button>
        </div>

        <div class="sidebar-section-label">Principal</div>
        <ul class="sidebar-nav">
            <li><a href="@Url.Action("Index","Home")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"><i class="fas fa-th-large"></i> Dashboard</a></li>
            
            @if (allowedModules.Contains("Citas") || userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Citas")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Citas" ? "active" : "")"><i class="fas fa-calendar-alt"></i> Citas</a></li>
            }
            
            @if (allowedModules.Contains("Pacientes") || userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Pacientes")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pacientes" ? "active" : "")"><i class="fas fa-user-injured"></i> Pacientes</a></li>
            }
            
            @if (allowedModules.Contains("Tratamientos") || userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Tratamientos")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Tratamientos" ? "active" : "")"><i class="fas fa-hand-holding-medical"></i> Tratamientos</a></li>
            }
            
            @if (allowedModules.Contains("Consultas") || userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Consultas")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Consultas" ? "active" : "")"><i class="fas fa-stethoscope"></i> Consultas</a></li>
            }
            
            @if (allowedModules.Contains("Inventario") || userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Inventario")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventario" ? "active" : "")"><i class="fas fa-boxes"></i> Inventario</a></li>
            }


        </ul>

        <div class="sidebar-section-label">Administración</div>
        <ul class="sidebar-nav">
            @if (allowedModules.Contains("Caja") || userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Caja")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Caja" ? "active" : "")"><i class="fas fa-cash-register"></i> Caja y Pagos</a></li>
            }
            
            <li><a href="#"><i class="fas fa-chart-bar"></i> Reportes</a></li>
            
            @if (userRole == "ADMINISTRADOR") {
                <li><a href="@Url.Action("Index","Configuracion")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Configuracion" ? "active" : "")"><i class="fas fa-cog"></i> Configuración</a></li>
            }
        </ul>

        <!-- Logout at bottom -->
        <div style="padding: 16px 20px; border-top: 1px solid var(--border-color); margin-top: auto;">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
                </button>
            </form>
        </div>
    </aside>

    <!-- TOPBAR -->
    <div class="topbar">
        <div class="d-flex align-items-center gap-3">
             <button type="button" class="btn btn-light btn-sm d-lg-none" id="sidebarToggle">
                <i class="fas fa-bars"></i>
             </button>
             @{
                 var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                 var isAccounting = currentController == "Caja" || 
                                    currentController == "Inventario" || 
                                    currentController == "Tratamientos" || 
                                    currentController == "Configuracion";
             }

             @if (isAccounting)
             {
                 <div class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill border border-primary border-opacity-25">
                    <i class="fas fa-coins me-2"></i>MONEDA: <span id="globalCurrencyLabel" class="fw-bold">@((ViewBag.MonedaBase as MediTech.Backend.Models.Moneda)?.Codigo ?? "USD")</span>
                 </div>
                 @if (ViewBag.TasaCambio != null)
                 {
                     <div id="globalExchangeRate" class="text-muted small">
                        <i class="fas fa-exchange-alt mx-2"></i> T.C: <span class="fw-bold text-dark">@ViewBag.TasaCambio</span>
                     </div>
                 }
             }
             else
             {
                 <div class="badge bg-soft-info text-info px-3 py-2 rounded-pill border border-info border-opacity-25">
                    <i class="fas fa-shield-halved me-2"></i>SISTEMA: <span class="fw-bold">PROFESSIONAL</span>
                 </div>
             }
        </div>

        <div class="topbar-user">
            <div class="user-info">
                <div class="name">@userName</div>
                <div class="role">@userRole</div>
            </div>
            <div class="user-avatar">@initials</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    @{
        var isCitas = ViewContext.RouteData.Values["controller"]?.ToString() == "Citas"
            && (ViewContext.RouteData.Values["action"]?.ToString() == "Index"
                || ViewContext.RouteData.Values["action"] == null);
    }
    <main class="main-content" style="@(isCitas ? "padding:0;" : "")">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/meditech-notifications.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(document).ready(function() {
            // Bridge TempData messages to MediToast
            const success = '@TempData["Success"]';
            const error = '@TempData["Error"]';
            const warning = '@TempData["Warning"]';
            const info = '@TempData["Info"]';

            if (success && typeof MediToast !== 'undefined') MediToast.success(success);
            if (error && typeof MediToast !== 'undefined') MediToast.error(error);
            if (warning && typeof MediToast !== 'undefined') MediToast.warning(warning);
            if (info && typeof MediToast !== 'undefined') MediToast.info(info);
        });
    </script>
    @await RenderSectionAsync("Modals", required: false)
</body>
</html>

