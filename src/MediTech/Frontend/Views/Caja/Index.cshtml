@model IEnumerable<MediTech.Backend.Models.Cuenta>

@{
    ViewData["Title"] = "Caja y Pagos";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="display-6 fw-bold text-gradient-primary mb-0">Caja y Pagos</h2>
            <p class="text-muted">Control de cuentas, cobros e ingresos de la clínica</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary-premium shadow-sm">
                <i class="fas fa-plus-circle me-2"></i>Nueva Cuenta
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-success rounded-circle me-3">
                        <i class="fas fa-coins text-success"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Ingresos Hoy</h6>
                        <h3 class="mb-0 fw-bold text-success">C$ @ViewBag.IngresosHoy.ToString("N2")</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden border-start border-4 border-primary">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-primary rounded-circle me-3">
                        <i class="fas fa-file-invoice-dollar text-primary"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Cuentas Hoy</h6>
                        <h3 class="mb-0 fw-bold text-primary">@ViewBag.CuentasHoy</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden border-start border-4 border-warning">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-warning rounded-circle me-3">
                        <i class="fas fa-clock text-warning"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Pendientes</h6>
                        <h3 class="mb-0 fw-bold text-warning">@ViewBag.CuentasPendientes</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden border-start border-4 border-info">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-info rounded-circle me-3">
                        <i class="fas fa-wallet text-info"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Total Recaudado</h6>
                        <h3 class="mb-0 fw-bold text-info">C$ @ViewBag.TotalRecaudado.ToString("N2")</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card card-premium border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Fecha</label>
                    <input type="date" name="fecha" class="form-control" value="@ViewBag.FechaFilter">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Estado</label>
                    <select name="estado" class="form-select">
                        <option value="">Todos</option>
                        <option value="PENDIENTE" selected="@(ViewBag.EstadoFilter == "PENDIENTE")">Pendiente</option>
                        <option value="PAGADA" selected="@(ViewBag.EstadoFilter == "PAGADA")">Pagada</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="fas fa-filter me-1"></i>Filtrar
                    </button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-redo me-1"></i>Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Table -->
    <div class="card card-premium border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light-faded">
                    <tr>
                        <th class="ps-4"># Cuenta</th>
                        <th>Paciente</th>
                        <th>Total</th>
                        <th>Pagado</th>
                        <th>Saldo</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                No hay cuentas registradas. <a asp-action="Create" class="text-primary">Crear la primera</a>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        var totalPagado = item.Pagos.Sum(p => p.Monto ?? 0);
                        var saldo = (item.TotalFinal ?? 0) - totalPagado;
                        var isPagada = saldo <= 0 && (item.TotalFinal ?? 0) > 0;
                        var badgeClass = isPagada ? "bg-soft-success text-success" : "bg-soft-warning text-warning";
                        var statusText = isPagada ? "Pagada" : "Pendiente";
                        var nombrePaciente = item.Paciente?.Persona != null
                            ? $"{item.Paciente.Persona.PrimerNombre} {item.Paciente.Persona.PrimerApellido}"
                            : "N/A";

                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark fw-bold fs-6">#@item.IdCuenta</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                        <i class="fas fa-user text-primary"></i>
                                    </div>
                                    <span class="fw-semibold">@nombrePaciente</span>
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold">@item.MonedaBase?.Simbolo @item.TotalFinal?.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="text-success fw-bold">@item.MonedaBase?.Simbolo @totalPagado.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="fw-bold @(saldo > 0 ? "text-danger" : "text-success")">@item.MonedaBase?.Simbolo @saldo.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="badge @badgeClass rounded-pill">@statusText</span>
                            </td>
                            <td>
                                <span class="text-muted small">@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.IdCuenta" class="btn btn-sm btn-outline-primary" title="Ver Detalle">
                                    <i class="fas fa-eye me-1"></i>Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-white border-0 py-3">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0 gap-1">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link border-0 bg-light rounded shadow-none" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter">
                                <i class="fas fa-chevron-left small"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link border-0 @(ViewBag.CurrentPage == i ? "bg-primary text-white" : "bg-light text-dark shadow-none") rounded" asp-action="Index" asp-route-page="@i" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter">@i</a>
                            </li>
                        }
                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link border-0 bg-light rounded shadow-none" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter">
                                <i class="fas fa-chevron-right small"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .text-gradient-primary {
        background: linear-gradient(135deg, #2D3E50 0%, #4A90E2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .card-premium { border-radius: 15px; transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .card-premium:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important; }
    .icon-shape { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; }
    .bg-soft-primary { background: rgba(13, 110, 253, 0.1); }
    .bg-soft-warning { background: rgba(255, 193, 7, 0.1); }
    .bg-soft-danger { background: rgba(220, 53, 69, 0.1); }
    .bg-soft-info { background: rgba(13, 202, 240, 0.1); }
    .bg-soft-success { background: rgba(25, 135, 84, 0.1); }
    .btn-primary-premium {
        background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
        color: white; border: none; padding: 0.6rem 1.5rem; border-radius: 10px;
    }
    .bg-light-faded { background-color: rgba(248, 249, 250, 0.7); }
</style>

