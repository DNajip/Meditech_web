@model IEnumerable<MediTech.Backend.Models.Cuenta>

@{
    ViewData["Title"] = "Caja y Pagos";
}

<div class="container-fluid py-4">
    <!-- Header -->
<div class="page-header page-header-premium mb-4">
    <div>
        <h2 class="display-6 fw-bold text-gradient-primary mb-0">Caja y Pagos</h2>
        <p class="text-muted d-none d-sm-block">Control de cuentas, cobros e ingresos de la clínica</p>
    </div>
    <div class="d-flex gap-2">
        @if (ViewBag.IsCajaAbierta)
        {
            <div class="d-flex align-items-center bg-soft-success px-3 py-2 rounded-pill me-2 border border-success border-opacity-25">
                <div class="status-indicator-pumping me-2"></div>
                <span class="text-success fw-bold small">CAJA ABIERTA: @ViewBag.TurnoActual.FechaApertura.ToString("HH:mm")</span>
            </div>
            <button type="button" class="btn btn-outline-danger shadow-sm px-4 py-2" onclick="abrirModalCierre()">
                <i class="fas fa-lock me-1"></i> Cerrar Caja
            </button>
            <a asp-action="Create" class="btn btn-primary-premium shadow-sm px-4 py-2 ms-2">
                <i class="fas fa-plus-circle me-1"></i> Nueva Cuenta
            </a>
        }
        else
        {
            <div class="d-flex align-items-center bg-soft-danger px-3 py-2 rounded-pill me-2 border border-danger border-opacity-25">
                <i class="fas fa-lock text-danger me-2"></i>
                <span class="text-danger fw-bold small">CAJA CERRADA</span>
            </div>
            <button type="button" class="btn btn-success shadow-sm px-4 py-2" onclick="abrirModalApertura()">
                <i class="fas fa-key me-1"></i> Abrir Caja
            </button>
        }
    </div>
</div>

@if (!ViewBag.IsCajaAbierta)
{
    <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex align-items-center p-4" style="border-radius: 12px; border-left: 5px solid #f59e0b !important;">
        <div class="icon-shape bg-warning text-white rounded-circle me-4 fs-3">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div>
            <h5 class="fw-bold mb-1">Caja Cerrada</h5>
            <p class="mb-0 text-dark opacity-75">Debe realizar la apertura de caja para poder registrar nuevos pagos y gestionar las finanzas del día.</p>
        </div>
        <button class="btn btn-warning fw-bold ms-auto px-4" onclick="abrirModalApertura()">
            Comenzar Turno
        </button>
    </div>
}

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-success rounded-circle me-3">
                        <i class="fas fa-coins text-success"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Ingresos Hoy</h6>
                        <h3 class="mb-0 fw-bold text-success">@ViewBag.MonedaBase?.Simbolo @ViewBag.IngresosHoy.ToString("N2")</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden border-start border-4 border-primary">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-primary rounded-circle me-3">
                        <i class="fas fa-file-invoice-dollar text-primary"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Cuentas Hoy</h6>
                        <h3 class="mb-0 fw-bold text-primary">@ViewBag.CuentasHoy</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden border-start border-4 border-warning">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-warning rounded-circle me-3">
                        <i class="fas fa-clock text-warning"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Pendientes</h6>
                        <h3 class="mb-0 fw-bold text-warning">@ViewBag.CuentasPendientes</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden border-start border-4 border-info">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-soft-info rounded-circle me-3">
                        <i class="fas fa-wallet text-info"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small text-uppercase fw-bold">Total Recaudado</h6>
                        <h3 class="mb-0 fw-bold text-info">@ViewBag.MonedaBase?.Simbolo @ViewBag.TotalRecaudado.ToString("N2")</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card card-premium border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Buscar Paciente o #</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="buscar" class="form-control border-start-0" placeholder="Nombre o ID..." value="@ViewBag.BuscarFilter">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Fecha</label>
                    <input type="date" name="fecha" class="form-control" value="@ViewBag.FechaFilter">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Estado</label>
                    <select name="estado" class="form-select border-0 shadow-none">
                        <option value="">Todos</option>
                        <option value="PENDIENTE" selected='@(ViewBag.EstadoFilter == "PENDIENTE")'>Pendiente</option>
                        <option value="PAGADA" selected='@(ViewBag.EstadoFilter == "PAGADA")'>Pagada</option>
                        <option value="CANCELADA" selected='@(ViewBag.EstadoFilter == "CANCELADA")'>Cancelada</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="fas fa-filter me-1"></i>Filtrar
                    </button>
                </div>
                <div class="col-md-3">
                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100" title="Limpiar Filtros">
                            <i class="fas fa-redo"></i>
                        </a>
                        <div class="bg-light px-3 py-2 rounded text-muted small fw-bold d-flex align-items-center w-100 justify-content-center">
                            Total: @ViewBag.TotalItems
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Table -->
    <div class="card card-premium border-0 shadow-sm overflow-hidden">
        <div class="table-responsive-premium">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light-faded">
                    <tr>
                        <th class="ps-4"># Cuenta</th>
                        <th>Paciente</th>
                        <th>Total</th>
                        <th>Pagado</th>
                        <th>Saldo</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                No hay cuentas registradas. <a asp-action="Create" class="text-primary">Crear la primera</a>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        var totalPagado = item.Pagos.Sum(p => p.MontoBase ?? 0);
                        var totalFinal = item.TotalFinal ?? 0;
                        var saldo = totalFinal - totalPagado;
                        
                        string badgeClass, statusText;
                        if (totalFinal == 0)
                        {
                            badgeClass = "bg-soft-secondary text-secondary";
                            statusText = "Cancelada";
                        }
                        else if (saldo <= 0)
                        {
                            badgeClass = "bg-soft-success text-success";
                            statusText = "Pagada";
                        }
                        else
                        {
                            badgeClass = "bg-soft-warning text-warning";
                            statusText = "Pendiente";
                        }

                        var nombrePaciente = item.Paciente?.Persona != null
                            ? $"{item.Paciente.Persona.PrimerNombre} {item.Paciente.Persona.PrimerApellido}"
                            : "N/A";

                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark fw-bold fs-6">#@item.IdCuenta</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                        <i class="fas fa-user text-primary"></i>
                                    </div>
                                    <span class="fw-semibold">@nombrePaciente</span>
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold">@item.MonedaBase?.Simbolo @item.TotalFinal?.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="text-success fw-bold">@item.MonedaBase?.Simbolo @totalPagado.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="fw-bold @(saldo > 0 ? "text-danger" : "text-success")">@item.MonedaBase?.Simbolo @saldo.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="badge @badgeClass rounded-pill">@statusText</span>
                            </td>
                            <td>
                                <span class="text-muted small">@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.IdCuenta" class="btn btn-sm btn-outline-primary" title="Ver Detalle">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (statusText == "Pendiente" && totalPagado == 0)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-anular" 
                                                data-id="@item.IdCuenta" title="Anular Cuenta">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-white border-0 py-3">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0 gap-1">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link border-0 bg-light rounded shadow-none" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter" asp-route-buscar="@ViewBag.BuscarFilter">
                                <i class="fas fa-chevron-left small"></i>
                            </a>
                        </li>
                        
                        @{
                            int totalPages = ViewBag.TotalPages;
                            int currentPage = ViewBag.CurrentPage;
                            int maxVisible = 5;
                            int startPage = Math.Max(1, currentPage - 2);
                            int endPage = Math.Min(totalPages, startPage + maxVisible - 1);
                            
                            if (endPage - startPage < maxVisible - 1)
                            {
                                startPage = Math.Max(1, endPage - maxVisible + 1);
                            }
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link border-0 bg-light text-dark rounded shadow-none" asp-action="Index" asp-route-page="1" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter" asp-route-buscar="@ViewBag.BuscarFilter">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(currentPage == i ? "active" : "")">
                                <a class="page-link border-0 @(currentPage == i ? "bg-primary text-white" : "bg-light text-dark shadow-none") rounded" asp-action="Index" asp-route-page="@i" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter" asp-route-buscar="@ViewBag.BuscarFilter">@i</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link border-0 bg-light text-dark rounded shadow-none" asp-action="Index" asp-route-page="@totalPages" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter" asp-route-buscar="@ViewBag.BuscarFilter">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link border-0 bg-light rounded shadow-none" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-estado="@ViewBag.EstadoFilter" asp-route-fecha="@ViewBag.FechaFilter" asp-route-buscar="@ViewBag.BuscarFilter">
                                <i class="fas fa-chevron-right small"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        .status-indicator-pumping {
            width: 10px;
            height: 10px;
            background-color: #10B981;
            border-radius: 50%;
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            animation: pulse-green 2s infinite;
        }

        @@keyframes pulse-green {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
        
        .bg-soft-success { background-color: rgba(16, 185, 129, 0.1); }
        .bg-soft-danger { background-color: rgba(239, 68, 68, 0.1); }
        .bg-soft-warning { background-color: rgba(245, 158, 11, 0.1); }
        .bg-soft-primary { background-color: rgba(79, 70, 229, 0.1); }
        .bg-soft-info { background-color: rgba(6, 182, 212, 0.1); }
    </style>

<script>
    function abrirModalApertura() {
        const modal = new bootstrap.Modal(document.getElementById('modalApertura'));
        modal.show();
    }

    function abrirModalCierre() {
        const modal = new bootstrap.Modal(document.getElementById('modalCierre'));
        modal.show();
    }

    function confirmarApertura() {
        const montoStr = document.getElementById('montoInicial').value;
        const monto = parseFloat(montoStr);
        if (isNaN(monto) || monto < 0) {
            MediToast.error("Ingrese un monto inicial válido.");
            return;
        }

        const btn = document.getElementById('btnConfirmarApertura');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Abriendo...';

        const form = new FormData();
        form.append('montoInicial', monto);
        form.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        fetch('/Caja/AbrirCaja', {
            method: 'POST',
            body: form
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                MediToast.success(data.message);
                setTimeout(() => location.reload(), 1000);
            } else {
                MediToast.error(data.message);
                btn.disabled = false;
                btn.innerHTML = 'Abrir Caja';
            }
        });
    }

    function confirmarCierre() {
        const montoStr = document.getElementById('montoReal').value;
        const obs = document.getElementById('observacionesCierre').value;
        const monto = parseFloat(montoStr);
        
        if (isNaN(monto) || monto < 0) {
            MediToast.error("Ingrese el monto real en caja.");
            return;
        }

        const btn = document.getElementById('btnConfirmarCierre');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Cerrando...';

        const form = new FormData();
        form.append('montoReal', monto);
        form.append('observaciones', obs);
        form.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        fetch('/Caja/CerrarCaja', {
            method: 'POST',
            body: form
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                MediToast.success(data.message);
                if (data.diferencia != 0) {
                    MediToast.warning("Diferencia detectada: " + data.diferencia.toFixed(2));
                }
                setTimeout(() => location.reload(), 2000);
            } else {
                MediToast.error(data.message);
                btn.disabled = false;
                btn.innerHTML = 'Cerrar Turno';
            }
        });
    }

    document.querySelectorAll('.btn-anular').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.dataset.id;
            MediConfirm.show({
                title: '¿Anular Cuenta #' + id + '?',
                message: 'Esta acción anulará todos los cargos y devolverá el stock de productos al inventario. No se puede revertir.',
                variant: 'danger',
                confirmText: 'Sí, Anular',
                cancelText: 'Cancelar',
                icon: 'fa-ban'
            }).then(confirmed => {
                if (confirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '/Caja/AnularCuenta/' + id;
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    if (token) {
                        const inputToken = document.createElement('input');
                        inputToken.type = 'hidden';
                        inputToken.name = '__RequestVerificationToken';
                        inputToken.value = token;
                        form.appendChild(inputToken);
                    }
                    
                    fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form)
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            MediToast.success(data.message);
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            MediToast.error(data.message);
                        }
                    });
                }
            });
        });
    });
</script>
}

@Html.AntiForgeryToken()

<!-- Modal Apertura de Caja -->
<div class="modal fade" id="modalApertura" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="fas fa-key text-success me-2"></i>Apertura de Turno</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted small mb-4">Ingrese el monto en efectivo con el que inicia su turno en caja.</p>
                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Monto Inicial (@ViewBag.MonedaBase?.Simbolo)</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0 fs-4 text-muted">@ViewBag.MonedaBase?.Simbolo</span>
                        <input type="number" id="montoInicial" class="form-control border-start-0 fs-3 fw-bold" value="0.00" step="0.01">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4">
                <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmarApertura" class="btn btn-success fw-bold px-4" onclick="confirmarApertura()">Abrir Caja</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cierre de Caja -->
<div class="modal fade" id="modalCierre" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger"><i class="fas fa-lock text-danger me-2"></i>Cierre de Turno</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted small mb-4">Para cerrar el turno, realice el conteo de efectivo real en caja e ingréselo a continuación.</p>
                
                <div class="alert alert-info border-0 py-2 small mb-4" style="border-radius: 10px;">
                    <i class="fas fa-info-circle me-1"></i> El sistema comparará su ingreso con lo recaudado digitalmente.
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted">Total Efectivo Real (@ViewBag.MonedaBase?.Simbolo)</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0 fs-4 text-muted">@ViewBag.MonedaBase?.Simbolo</span>
                        <input type="number" id="montoReal" class="form-control border-start-0 fs-3 fw-bold" placeholder="0.00" step="0.01">
                    </div>
                </div>

                <div class="mb-0">
                    <label class="form-label fw-bold small text-muted">Observaciones final del turno</label>
                    <textarea id="observacionesCierre" class="form-control" rows="2" placeholder="Notas sobre el turno, diferencias, etc..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4">
                <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">Mantener Abierto</button>
                <button type="button" id="btnConfirmarCierre" class="btn btn-danger fw-bold px-4" onclick="confirmarCierre()">Cerrar Turno</button>
            </div>
        </div>
    </div>
</div>

