@model MediTech.Backend.Models.Cuenta

@{
    ViewData["Title"] = "Detalle de Cuenta #" + Model.IdCuenta;
    var monedas = ViewBag.Monedas as List<MediTech.Backend.Models.Moneda>;
    decimal totalPagado = ViewBag.TotalPagado;
    decimal saldoPendiente = ViewBag.SaldoPendiente;
    bool isCancelada = (Model.TotalFinal ?? 0) == 0;
    bool isPagada = !isCancelada && saldoPendiente <= 0 && (Model.TotalFinal ?? 0) > 0;
    var nombrePaciente = Model.Paciente?.Persona != null
        ? $"{Model.Paciente.Persona.PrimerNombre} {Model.Paciente.Persona.PrimerApellido}"
        : "N/A";
}

<div class="container-fluid py-4">
    <!-- Header -->
        <div class="d-flex gap-2">
            @if (!isCancelada && !isPagada && totalPagado == 0 && (Model.TotalFinal ?? 0) > 0)
            {
                <button type="button" class="btn btn-outline-danger shadow-sm" id="btnAnularCuenta">
                    <i class="fas fa-ban me-2"></i>Anular Cuenta
                </button>
            }
            @if (!isCancelada && !isPagada)
            {
                <button type="button" class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#registrarPagoModal">
                    <i class="fas fa-dollar-sign me-2"></i>Registrar Pago
                </button>
            }
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Info Card -->
        <div class="col-md-4">
            <div class="card card-premium border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar-lg bg-soft-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;">
                            <i class="fas fa-file-invoice-dollar text-primary fs-3"></i>
                        </div>
                        <span class="badge @(isCancelada ? "bg-soft-secondary text-secondary" : (isPagada ? "bg-success" : "bg-warning text-dark")) rounded-pill fs-6 px-3 py-2">
                            @(isCancelada ? "✕ CANCELADA" : (isPagada ? "✓ PAGADA" : "⏳ PENDIENTE"))
                        </span>
                    </div>

                    <ul class="list-unstyled">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Paciente</span>
                            <span class="fw-bold">@nombrePaciente</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Moneda</span>
                            <span class="fw-bold">@Model.MonedaBase?.Nombre (@Model.MonedaBase?.Codigo)</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Fecha</span>
                            <span class="fw-bold">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Tasa de Cambio</span>
                            <span class="fw-bold">@ViewBag.TasaCambio</span>
                        </li>
                    </ul>

                    <div class="bg-light rounded-3 p-3 mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal:</span>
                            <span class="fw-bold">@Model.MonedaBase?.Simbolo @Model.TotalBruto?.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Descuento:</span>
                            <span class="fw-bold text-danger">- @Model.MonedaBase?.Simbolo @Model.Descuento.ToString("N2")</span>
                        </div>
                        <hr class="my-2">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold fs-5">Total:</span>
                            <span class="fw-bold fs-5 text-primary">@Model.MonedaBase?.Simbolo @Model.TotalFinal?.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Pagado:</span>
                            <span class="fw-bold text-success">@Model.MonedaBase?.Simbolo @totalPagado.ToString("N2")</span>
                        </div>
                        <hr class="my-2">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold fs-5">Saldo:</span>
                            <span class="fw-bold fs-5 @(saldoPendiente > 0 ? "text-danger" : "text-success")">@Model.MonedaBase?.Simbolo @saldoPendiente.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Items & Payments -->
        <div class="col-md-8">
            <!-- Items de la Cuenta -->
            <div class="card card-premium border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0"><i class="fas fa-list text-primary me-2"></i>Ítems de la Cuenta</h5>
                </div>
                <div class="card-body px-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light-faded">
                                <tr>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">Precio Unit.</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Detalles)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @(item.TipoItem == "TRATAMIENTO" ? "bg-soft-success text-success" : "bg-soft-info text-info") rounded-pill">
                                                @item.TipoItem
                                            </span>
                                        </td>
                                        <td class="fw-semibold">@item.Descripcion</td>
                                        <td class="text-center">@item.Cantidad</td>
                                        <td class="text-end">@Model.MonedaBase?.Simbolo @item.PrecioUnitario?.ToString("N2")</td>
                                        <td class="text-end fw-bold">@Model.MonedaBase?.Simbolo @item.Subtotal?.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Historial de Pagos -->
            <div class="card card-premium border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="fas fa-money-bill-wave text-success me-2"></i>Historial de Pagos</h5>
                    <span class="badge bg-primary rounded-pill">@Model.Pagos.Count pagos</span>
                </div>
                <div class="card-body px-4">
                    @if (!Model.Pagos.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-receipt fa-3x mb-3 d-block opacity-25"></i>
                            Aún no se han registrado pagos para esta cuenta.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="bg-light-faded">
                                    <tr>
                                        <th># Pago</th>
                                        <th>Método</th>
                                        <th class="text-end">Monto</th>
                                        <th>Moneda</th>
                                        <th>Tasa</th>
                                        <th>Fecha</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pago in Model.Pagos.OrderByDescending(p => p.FechaPago))
                                    {
                                        <tr>
                                            <td><span class="badge bg-light text-dark">#@pago.IdPago</span></td>
                                            <td>
                                                <span class="badge @GetMetodoClass(pago.MetodoPago) rounded-pill">
                                                    <i class="@GetMetodoIcon(pago.MetodoPago) me-1"></i>@pago.MetodoPago
                                                </span>
                                            </td>
                                            <td class="text-end fw-bold text-success">@pago.Moneda?.Simbolo @pago.Monto?.ToString("N2")</td>
                                            <td>@pago.Moneda?.Nombre</td>
                                            <td class="text-muted small">@pago.TasaCambioAplicada</td>
                                            <td class="text-muted small">@pago.FechaPago.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div id="currency-metadata" 
     data-base-id="@ViewBag.IdMonedaBase" 
     data-tasa="@ViewBag.TasaCambio"
     data-saldo="@ViewBag.SaldoPendiente"
     data-tasa-origen="@ViewBag.TasaOrigenId"
     data-tasa-destino="@ViewBag.TasaDestinoId"
     style="display:none;"></div>

<!-- Modal Registrar Pago -->
<div class="modal fade" id="registrarPagoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1.2rem;">
            <div class="modal-header bg-success bg-opacity-10 border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-success">
                    <i class="fas fa-dollar-sign me-2"></i>Registrar Pago
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formRegistrarPago" asp-action="RegistrarPago" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="idCuenta" value="@Model.IdCuenta" />
                    <div class="bg-soft-danger rounded-4 p-4 mb-4 text-center border border-danger border-opacity-10">
                        <span class="text-danger-emphasis small fw-bold text-uppercase d-block mb-1">Saldo a Liquidar</span>
                        <h2 class="fw-bold text-danger mb-0 font-monospace">@Model.MonedaBase?.Simbolo @saldoPendiente.ToString("N2")</h2>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-secondary">Monto a Recibir <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light border-0" id="simboloPago">@Model.MonedaBase?.Simbolo</span>
                            <input type="number" name="monto" id="inputMontoPago" class="form-control bg-light border-0 fw-bold" step="0.01" min="0.01" value="@saldoPendiente" required>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-secondary">Moneda <span class="text-danger">*</span></label>
                            <select name="idMoneda" class="form-select border-0 bg-light" id="selectMonedaPago" required>
                                @if (monedas != null)
                                {
                                    @foreach (var m in monedas)
                                    {
                                        <option value="@m.IdMoneda" 
                                                data-simbolo="@m.Simbolo"
                                                data-base="@(m.IdMoneda == Model.IdMonedaBase ? "true" : "false")"
                                                selected="@(m.IdMoneda == Model.IdMonedaBase)">
                                            @m.Codigo - @m.Nombre
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-secondary">Vía de Pago <span class="text-danger">*</span></label>
                            <select name="metodoPago" class="form-select border-0 bg-light" required>
                                <option value="EFECTIVO">💵 Efectivo</option>
                                <option value="TARJETA">💳 Tarjeta</option>
                                <option value="TRANSFERENCIA">🏦 Transferencia</option>
                            </select>
                        </div>
                    </div>

                    <div id="previewConversion" class="mt-4 p-3 bg-soft-primary rounded-3 border border-primary border-opacity-10" style="display:none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="fw-bold text-primary text-uppercase" style="font-size: 0.65rem;">Equivalente en Moneda Base</small>
                            <span class="fw-bold text-primary fs-5" id="montoBaseCalculado">0.00</span>
                        </div>
                        <small class="text-muted" style="font-size: 0.7rem;">Usando tasa: <span id="tasaAplicadaPreview">1.00</span></small>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold text-muted" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-success rounded-pill px-5 fw-bold shadow-sm" id="btnSubmitPago">
                        <i class="fas fa-check-circle me-2"></i>Confirmar Cobro
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetMetodoClass(string? metodo) => metodo switch
    {
        "EFECTIVO" => "bg-soft-success text-success",
        "TARJETA" => "bg-soft-primary text-primary",
        "TRANSFERENCIA" => "bg-soft-info text-info",
        _ => "bg-light text-dark"
    };

    string GetMetodoIcon(string? metodo) => metodo switch
    {
        "EFECTIVO" => "fas fa-money-bill-wave",
        "TARJETA" => "fas fa-credit-card",
        "TRANSFERENCIA" => "fas fa-university",
        _ => "fas fa-question"
    };
}


@Html.AntiForgeryToken()

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const formPago = document.getElementById('formRegistrarPago');
        const inputMonto = document.getElementById('inputMontoPago');
        const selectMoneda = document.getElementById('selectMonedaPago');
        const divPreview = document.getElementById('previewConversion');
        const spanMontoBase = document.getElementById('montoBaseCalculado');
        const spanTasaPreview = document.getElementById('tasaAplicadaPreview');
        const spanSimboloPago = document.getElementById('simboloPago');
        const btnSubmit = document.getElementById('btnSubmitPago');
        const meta = document.getElementById('currency-metadata');

        if (!meta || !inputMonto || !selectMoneda) return;

        const idMonedaBase = parseInt(meta.dataset.baseId) || 0;
        const saldoPendiente = parseFloat(meta.dataset.saldo.replace(',', '.')) || 0;
        const tasa = parseFloat(meta.dataset.tasa.replace(',', '.')) || 1;
        const idTasaOrigen = parseInt(meta.dataset.tasaOrigen) || 0;
        const idTasaDestino = parseInt(meta.dataset.tasaDestino) || 0;

        function updatePreview() {
            const opt = selectMoneda.options[selectMoneda.selectedIndex];
            const idMonedaPago = parseInt(opt.value);
            const simbolo = opt.dataset.simbolo;
            const monto = parseFloat(inputMonto.value) || 0;

            spanSimboloPago.textContent = simbolo;
            spanTasaPreview.textContent = tasa.toFixed(4);

            const isBase = (idMonedaPago === idMonedaBase);
            let equiv = monto;

            if (isBase) {
                divPreview.style.display = 'none';
            } else {
                divPreview.style.display = 'block';
                if (idTasaOrigen === idMonedaPago && idTasaDestino === idMonedaBase) {
                    equiv = monto * tasa;
                } else if (idTasaOrigen === idMonedaBase && idTasaDestino === idMonedaPago) {
                    equiv = monto / tasa;
                } else {
                    equiv = monto * tasa; 
                }
                spanMontoBase.textContent = equiv.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Base';
            }

            // Validar monto insuficiente
            if (monto > 0 && equiv < (saldoPendiente - 0.05)) { // 0.05 margen redondeo
                inputMonto.classList.add('is-invalid');
                btnSubmit.disabled = true;
                if (!document.getElementById('insufficientWarning')) {
                    const warn = document.createElement('div');
                    warn.id = 'insufficientWarning';
                    warn.className = 'invalid-feedback fw-bold';
                    warn.textContent = 'El monto debe cubrir el saldo total.';
                    inputMonto.parentNode.appendChild(warn);
                }
            } else {
                inputMonto.classList.remove('is-invalid');
                btnSubmit.disabled = false;
                document.getElementById('insufficientWarning')?.remove();
            }
        }

        selectMoneda.addEventListener('change', updatePreview);
        inputMonto.addEventListener('input', updatePreview);

        // AJAX Submission
        formPago.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const btn = e.submitter || document.querySelector('#formPago button[type="submit"]');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Procesando...';

            const formData = new FormData(formPago);
            fetch(formPago.action, {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('registrarPagoModal')).hide();
                    MediToast.success(data.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    MediToast.error(data.message);
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            })
            .catch(error => {
                MediToast.error("Error al procesar el pago");
                console.error(error);
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        });

        // Anular Cuenta
        const btnAnular = document.getElementById('btnAnularCuenta');
        if (btnAnular) {
            btnAnular.addEventListener('click', function() {
                MediConfirm.show({
                    title: '¿Anular Cuenta permanentemente?',
                    message: 'Esta acción liberará los cargos y devolverá el stock de productos al almacén. No se puede deshacer.',
                    variant: 'danger',
                    confirmText: 'Sí, Anular',
                    icon: 'fa-ban'
                }).then(confirmed => {
                    if (confirmed) {
                        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
                        const formData = new FormData();
                        formData.append('id', @Model.IdCuenta);
                        formData.append('__RequestVerificationToken', csrfToken);

                        fetch('/Caja/AnularCuenta', {
                            method: 'POST',
                            body: formData
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                MediToast.success(data.message);
                                setTimeout(() => location.href = '/Caja/Index', 1500);
                            } else {
                                MediToast.error(data.message);
                            }
                        });
                    }
                });
            });
        }

        updatePreview();
    });
</script>
}

