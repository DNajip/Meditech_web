@model MediTech.Backend.Models.Paciente
@{
    ViewData["Title"] = "Editar Paciente";
}

<style>
    .form-card {
        background: #FFFFFF;
        border-radius: 14px;
        border: 1px solid #E2E8F0;
        padding: 28px;
    }
    .form-card h4 { font-weight: 700; color: #1E293B; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid #F1F5F9; }
    .form-card label { font-size: 0.82rem; font-weight: 600; color: #475569; margin-bottom: 4px; }
    .form-card .form-control, .form-card .form-select {
        border-radius: 8px; border: 1px solid #E2E8F0; padding: 10px 14px; font-size: 0.88rem;
    }
    .form-card .form-control:focus, .form-card .form-select:focus { border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .section-title { font-size: 0.9rem; font-weight: 600; color: #3B82F6; margin: 20px 0 14px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 style="font-size:1.5rem; font-weight:700; color:#1E293B; margin:0;">
            <i class="fas fa-user-edit me-2" style="color:#3B82F6;"></i>Editar Paciente
        </h2>
        <span style="font-size:0.85rem; color:#64748B;">@(Model.Persona?.PrimerNombre ?? "") @(Model.Persona?.PrimerApellido ?? "")</span>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm" style="border-radius:8px;">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>
        <input type="hidden" asp-for="IdPaciente" />
        <input type="hidden" asp-for="IdPersona" />
        <input type="hidden" asp-for="FechaRegistro" />
        <input type="hidden" asp-for="IdEstado" />

        <div class="section-title"><i class="fas fa-user me-1"></i> Datos Personales</div>
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="Persona!.PrimerNombre">Primer Nombre *</label>
                <input asp-for="Persona!.PrimerNombre" class="form-control" />
                <span asp-validation-for="Persona!.PrimerNombre" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Persona!.SegundoNombre">Segundo Nombre</label>
                <input asp-for="Persona!.SegundoNombre" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Persona!.PrimerApellido">Primer Apellido *</label>
                <input asp-for="Persona!.PrimerApellido" class="form-control" />
                <span asp-validation-for="Persona!.PrimerApellido" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Persona!.SegundoApellido">Segundo Apellido</label>
                <input asp-for="Persona!.SegundoApellido" class="form-control" />
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-3">
                <label asp-for="Persona!.IdGenero">Género</label>
                <select asp-for="Persona!.IdGenero" class="form-select" asp-items="@(new SelectList(ViewBag.Generos, "IdGenero", "DescGenero"))">
                    <option value="">Seleccione</option>
                </select>
                <span asp-validation-for="Persona!.IdGenero" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Persona!.IdTipoIdentificacion">Tipo Identificación</label>
                <select asp-for="Persona!.IdTipoIdentificacion" class="form-select" asp-items="@(new SelectList(ViewBag.TiposIdentificacion, "IdTipoIdentificacion", "DescTipo"))">
                    <option value="">Seleccione</option>
                </select>
                <span asp-validation-for="Persona!.IdTipoIdentificacion" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Persona!.NumIdentificacion">N° Identificación</label>
                <input asp-for="Persona!.NumIdentificacion" class="form-control" />
                <span asp-validation-for="Persona!.NumIdentificacion" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Persona!.FechaNacimiento">Fecha de Nacimiento *</label>
                <input asp-for="Persona!.FechaNacimiento" type="date" class="form-control" />
                <span asp-validation-for="Persona!.FechaNacimiento" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <label asp-for="Ocupacion">Ocupación</label>
                <input asp-for="Ocupacion" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Persona!.Email">Correo Electrónico</label>
                <input asp-for="Persona!.Email" type="email" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Persona!.Telefono">Teléfono *</label>
                <input asp-for="Persona!.Telefono" class="form-control" />
                <span asp-validation-for="Persona!.Telefono" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-12">
                <label asp-for="Persona!.Direccion">Dirección</label>
                <textarea asp-for="Persona!.Direccion" class="form-control" rows="2"></textarea>
            </div>
        </div>

        <div class="section-title mt-4"><i class="fas fa-exclamation-triangle me-1"></i> Contacto de Emergencia</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ContactoEmergencia">Nombre de Contacto</label>
                <input asp-for="ContactoEmergencia" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="TelefonoEmergencia">Teléfono de Emergencia</label>
                <input asp-for="TelefonoEmergencia" class="form-control" />
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top:1px solid #F1F5F9;">
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary" style="border-radius:8px;">Cancelar</a>
            <button type="submit" class="btn btn-primary" style="border-radius:8px;">
                <i class="fas fa-save me-1"></i> Guardar Cambios
            </button>
        </div>
    </form>
</div>

