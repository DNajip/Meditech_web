                    <a class="page-link" href="javascript:void(0)" onclick="changeCitasPage(${i})">${i}</a>
                </li>`;
        }

        // Next button
        pagesHtml += `
            <li class="page-item ${currentCitasPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="javascript:void(0)" onclick="${currentCitasPage < totalPages ? `changeCitasPage(${currentCitasPage + 1})` : ''}" title="Siguiente">
