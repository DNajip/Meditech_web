@model MediTech.Backend.Models.Paciente
@{
    ViewData["Title"] = "Ficha Médica";
    var fullName = Model.Persona != null 
        ? $"{Model.Persona.PrimerNombre} {Model.Persona.SegundoNombre} {Model.Persona.PrimerApellido} {Model.Persona.SegundoApellido}".Replace("  ", " ").Trim()
        : "Paciente";
    var initials = Model.Persona != null 
        ? ((Model.Persona.PrimerNombre?.Length > 0 ? Model.Persona.PrimerNombre[0].ToString() : "") +
           (Model.Persona.PrimerApellido?.Length > 0 ? Model.Persona.PrimerApellido[0].ToString() : "")).ToUpper()
        : "P";
}

<style>
    .ficha-container {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 24px;
        align-items: start;
    }

    .sidebar-card {
        background: #FFFFFF;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
        padding: 24px;
        position: sticky;
        top: 88px;
    }

    .profile-section {
        text-align: center;
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid #F1F5F9;
    }

    .profile-avatar-large {
        width: 100px; height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3B82F6, #1E40AF);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0 auto 16px;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .profile-name { font-size: 1.25rem; font-weight: 700; color: #1E293B; margin-bottom: 4px; }
    .profile-id { font-size: 0.85rem; color: #64748B; margin-bottom: 12px; display: block; }

    .quick-info {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.88rem;
        color: #334155;
    }

    .info-item i { width: 20px; color: #94A3B8; text-align: center; }

    .main- ficha-content {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .content-card {
        background: #FFFFFF;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
        padding: 24px;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid #F1F5F9;
        background: transparent;
    }

    .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1E293B;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .placeholder-content {
        background: #F8FAFC;
        border: 2px dashed #E2E8F0;
        border-radius: 12px;
        padding: 40px;
        text-align: center;
        color: #94A3B8;
    }

    .placeholder-content i { font-size: 2.5rem; margin-bottom: 12px; color: #CBD5E1; }

    .nav-tabs-ficha {
        display: flex;
        gap: 8px;
        margin-bottom: 8px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .nav-tab {
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #64748B;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .nav-tab:hover { background: #F1F5F9; color: #334155; }
    .nav-tab.active { background: #3B82F6; color: white !important; }

    /* Estilos para Toggles de Historial */
    .toggle-group {
        display: flex;
        background: #F1F5F9;
        padding: 4px;
        border-radius: 20px;
        width: fit-content;
    }
    .toggle-btn {
        padding: 4px 16px;
        border-radius: 16px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        color: #64748B;
        background: transparent;
    }
    .toggle-btn.active-si { background: #DC2626; color: white; }
    .toggle-btn.active-no { background: #94A3B8; color: white; }

    /* Paginación estilo Premium (UX/UI) */
    .examen-pagination {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0;
        padding: 0;
    }
    .examen-pagination .page-item {
        list-style: none;
    }
    .examen-pagination .page-link {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px !important;
        border: 1px solid #EDF2F7;
        color: #718096;
        font-weight: 600;
        transition: all 0.2s ease;
        background: white;
        padding: 0;
        text-decoration: none;
        font-size: 0.9rem;
    }
    .examen-pagination .page-link:hover {
        background: #F7FAFC;
        border-color: #E2E8F0;
        color: #4A5568;
    }
    .examen-pagination .page-item.active .page-link {
        background: #5e5eff;
        border-color: #5e5eff;
        color: white;
        box-shadow: 0 4px 12px rgba(94, 94, 255, 0.25);
    }
    .examen-pagination .page-item.disabled .page-link {
        opacity: 0.4;
        cursor: not-allowed;
        background: white;
    }
    .examen-pagination .total-count {
        font-size: 0.9rem;
        color: #A0AEC0;
        margin-left: 12px;
        font-weight: 500;
    }
    
    .historial-section-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #64748B;
        border-bottom: 1px solid #E2E8F0;
        padding-bottom: 8px;
        margin-top: 24px;
        margin-bottom: 16px;
    }

    .historial-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .historial-label {
        font-size: 0.9rem;
        font-weight: 500;
        color: #1E293B;
    }

    .especifique-input {
        border: none;
        border-bottom: 1px solid #E2E8F0;
        border-radius: 0;
        padding: 2px 0;
        font-size: 0.85rem;
        width: 100%;
        margin-bottom: 10px;
        background: transparent;
    }
    .especifique-input:focus {
        box-shadow: none;
        border-color: #3B82F6;
    }

    .btn-ficha-action {
        background: #F1F5F9;
        border: none;
        color: #475569;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-ficha-action:hover { background: #E2E8F0; color: #1E293B; }

    .active-consultation-banner {
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        color: white;
        padding: 16px 24px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
    }
    .pulse-dot-white {
        width: 8px;
        height: 8px;
        background-color: #fff;
        border-radius: 50%;
        display: inline-block;
        animation: pulse-white 2s infinite;
        margin-right: 8px;
    }
    @@keyframes pulse-white {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(255, 255, 255, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
    }
    .badge-consultation {
        background: rgba(255,255,255,0.2);
        color: white;
        border: 1px solid rgba(255,255,255,0.3);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
    }
    .photo-delete {
        position: absolute;
        top: 8px; right: 8px;
        width: 28px; height: 28px;
        background: rgba(239, 68, 68, 0.9);
        color: white;
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        opacity: 0;
        transition: opacity 0.2s;
        z-index: 10;
        cursor: pointer;
    }
    .photo-item:hover .photo-delete { opacity: 1; }

    /* --- GALLERY UI STYLES --- */
    .upload-zone {
        background: #F8FAFC;
        border: 2px dashed #CBD5E1;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
        margin-bottom: 24px;
        position: relative;
    }
    .upload-zone:hover, .upload-zone.dragover {
        border-color: #3B82F6;
        background: #EFF6FF;
    }
    .upload-zone i { font-size: 2.5rem; color: #94A3B8; margin-bottom: 12px; display: block; }

    .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 16px;
        margin-top: 24px;
    }
    .photo-item {
        background: #FFFFFF;
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        overflow: hidden;
        transition: all 0.2s;
        position: relative;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    }
    .photo-item:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .photo-thumb-container {
        height: 140px;
        background: #F1F5F9;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
    }
    .photo-thumb { width: 100%; height: 100%; object-fit: cover; }
    .photo-info { padding: 10px; background: white; }
    .photo-title {
        font-size: 0.85rem; font-weight: 600; color: #1E293B;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        margin-bottom: 2px;
    }
    .photo-date { font-size: 0.75rem; color: #64748B; }

    /* GALLERY PAGINATION */
    .gallery-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 20px;
        padding: 12px 0;
    }
    .gallery-pagination button {
        width: 36px; height: 36px;
        border-radius: 10px;
        border: 1px solid #E2E8F0;
        background: #fff;
        color: #64748B;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .gallery-pagination button:hover:not(:disabled) {
        background: #EEF2FF;
        border-color: #818CF8;
        color: #4F46E5;
    }
    .gallery-pagination button.active {
        background: linear-gradient(135deg, #6366F1, #4F46E5);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
    }
    .gallery-pagination button:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }
    .gallery-pagination .page-info {
        font-size: 0.8rem;
        color: #94A3B8;
        margin: 0 8px;
    }

    /* CIERRE CONSULTA MODAL */
    .cierre-section {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }
    .cierre-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    .cierre-table th { background: #e2e8f0; padding: 8px; font-size: 0.85rem; font-weight: 600; text-align: left; }
    .cierre-table td { padding: 8px; border-bottom: 1px solid #e2e8f0; font-size: 0.9rem; }
    .cierre-table td.num { text-align: right; }
    .total-box { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 16px; }
    .total-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.95rem; }
    .total-final { font-size: 1.25rem; font-weight: bold; color: #1e40af; border-top: 2px solid #bfdbfe; padding-top: 8px; }

    /* DOCUMENT LIST */
    .doc-list { display: flex; flex-direction: column; gap: 10px; }
    .doc-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        background: #F8FAFC;
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        transition: all 0.2s;
    }
    .doc-item:hover { background: #EEF2FF; border-color: #C7D2FE; }
    .doc-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .doc-icon.pdf { background: #FEE2E2; color: #DC2626; }
    .doc-icon.word { background: #DBEAFE; color: #2563EB; }
    .doc-icon.excel { background: #D1FAE5; color: #059669; }
    .doc-icon.image { background: #FEF3C7; color: #D97706; }
    .doc-icon.other { background: #F1F5F9; color: #64748B; }
    .doc-info { flex: 1; min-width: 0; }
    .doc-name { font-weight: 600; color: #1E293B; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .doc-meta { font-size: 0.78rem; color: #94A3B8; margin-top: 2px; }
    .doc-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .doc-actions button {
        width: 34px; height: 34px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        transition: 0.2s;
    }
    .btn-doc-download { background: #DBEAFE; color: #2563EB; }
    .btn-doc-download:hover { background: #BFDBFE; }
    .btn-doc-delete { background: #FEE2E2; color: #DC2626; }
    .btn-doc-delete:hover { background: #FECACA; }

    /* PHOTO MODAL */
    .photo-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.85);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .modal-content-wrapper {
        position: relative;
        max-width: 90%;
        max-height: 90%;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: modalZoom 0.3s ease;
    }
    @@keyframes modalZoom {
        from { transform: scale(0.8); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
    .modal-photo {
        max-width: 100%;
        max-height: 80vh;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        object-fit: contain;
        background: #000;
    }
    .modal-caption {
        margin-top: 15px;
        color: white;
        font-size: 1.2rem;
        font-weight: 600;
        text-align: center;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
    .close-modal {
        position: absolute;
        top: 20px;
        right: 30px;
        color: white;
        font-size: 35px;
        font-weight: bold;
        cursor: pointer;
        z-index: 10000;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        transition: 0.2s;
    }
    .close-modal:hover { background: rgba(255,255,255,0.2); transform: scale(1.1); }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm" style="border-radius:8px;">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </a>
        <h4 class="mb-0 fw-bold">Ficha Médica</h4>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary btn-sm" style="border-radius:8px;"><i class="fas fa-print me-1"></i> Imprimir</button>
        <a href="@Url.Action("Edit", new { id = Model.IdPaciente })" class="btn btn-primary btn-sm" style="border-radius:8px;"><i class="fas fa-edit me-1"></i> Editar</a>
    </div>
</div>

<div class="ficha-container">
    <!-- SIDEBAR: Personal Data -->
    <aside class="sidebar-card">
        <div class="profile-section">
            <div class="profile-avatar-large">@initials</div>
            <h5 class="profile-name">@fullName</h5>
            <span class="profile-id">@Model.Persona?.TipoIdentificacion?.DescTipo: @Model.Persona?.NumIdentificacion</span>
            <span class="badge @(Model.IdEstado == 1 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")" style="font-size: 0.75rem; border-radius: 20px; padding: 4px 12px;">
                @(Model.IdEstado == 1 ? "Activo" : "Inactivo")
            </span>
        </div>

        <div class="quick-info">
            <div class="info-item">
                <i class="fas fa-venus-mars"></i>
                <span>@(Model.Persona?.Genero?.DescGenero ?? "No definido")</span>
            </div>
            <div class="info-item">
                <i class="fas fa-birthday-cake"></i>
                <span>@(Model.Persona?.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "N/D")</span>
            </div>
            <div class="info-item">
                <i class="fas fa-phone"></i>
                <span>@(Model.Persona?.Telefono ?? "N/D")</span>
            </div>
            <div class="info-item">
                <i class="fas fa-envelope"></i>
                <span class="text-truncate">@(Model.Persona?.Email ?? "N/D")</span>
            </div>
            <div class="info-item">
                <i class="fas fa-briefcase"></i>
                <span>@(Model.Ocupacion ?? "N/D")</span>
            </div>
            <hr class="my-2" style="border-color: #F1F5F9;">
            <div class="info-item">
                <i class="fas fa-calendar-alt"></i>
                <span style="font-size: 0.8rem; color: #94A3B8;">Registrado: @(Model.FechaRegistro?.ToString("dd/MM/yyyy") ?? "—")</span>
            </div>
        </div>
    </aside>

    <!-- MAIN CONTENT: Clinical Modules -->
    <div class="main-ficha-content">
        <!-- Banner de Consulta Activa -->
        @if (ViewBag.Modo == "consulta")
        {
            <div class="active-consultation-banner">
                <div class="d-flex align-items-center">
                    <span class="pulse-dot-white"></span>
                    <div>
                        <h6 class="mb-0 fw-bold">Consulta en proceso</h6>
                        <span class="small opacity-75">Motivo: @(((MediTech.Backend.Models.Consulta)ViewBag.ConsultaActiva)?.MotivoConsulta ?? "No especificado")</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <span class="badge-consultation">@(((MediTech.Backend.Models.Consulta)ViewBag.ConsultaActiva)?.Cita?.Tratamiento?.NombreTratamiento)</span>
                    <a href="@Url.Action("Recepcion", "Consultas", new { id = ((MediTech.Backend.Models.Consulta)ViewBag.ConsultaActiva)?.IdCita })" class="btn btn-sm btn-light fw-bold" style="border-radius: 8px; color: #1e40af;">Editar Recepción</a>
                </div>
            </div>
        }

        <!-- Tabs Navigation -->
        <div class="nav-tabs-ficha">
            <a href="javascript:void(0)" onclick="switchTab('resumen')" id="tab-resumen" class="nav-tab @(ViewBag.Modo != "consulta" ? "active" : "")">Resumen</a>
            <a href="javascript:void(0)" onclick="switchTab('citas')" id="tab-citas" class="nav-tab">Citas</a>
            <a href="javascript:void(0)" onclick="switchTab('consulta')" id="tab-consulta" class="nav-tab @(ViewBag.Modo == "consulta" ? "active" : "")">@(ViewBag.Modo == "consulta" ? "Consulta Activa" : "Consultas")</a>
            <a href="javascript:void(0)" onclick="switchTab('examenes')" id="tab-examenes" class="nav-tab">Exámenes</a>
            <a href="javascript:void(0)" onclick="switchTab('historial')" id="tab-historial" class="nav-tab">Historial</a>

            <a href="javascript:void(0)" onclick="switchTab('galeria')" id="tab-galeria" class="nav-tab">Galería</a>
            <a href="javascript:void(0)" onclick="switchTab('documentos')" id="tab-documentos" class="nav-tab">Documentos</a>
            <a href="javascript:void(0)" onclick="switchTab('finanzas')" id="tab-finanzas" class="nav-tab">Finanzas</a>

        </div>

        <!-- PANELS -->
        <div id="panel-resumen" class="tab-panel-content @(ViewBag.Modo == "consulta" ? "d-none" : "")">
            <!-- Historial de Citas Placeholder -->
            <div class="content-card">
                <div class="card-header">
                    <h6 class="card-title"><i class="fas fa-calendar-check" style="color:#3B82F6;"></i> Próximas Citas</h6>
                    <button class="btn-ficha-action">Agendar Nueva</button>
                </div>
                <div class="placeholder-content">
                    <i class="fas fa-calendar-day"></i>
                    <p class="mb-0">No hay citas programadas para este paciente.</p>
                </div>
            </div>

            <!-- Consultas Médicas Placeholder -->
            <div class="content-card">
                <div class="card-header">
                    <h6 class="card-title"><i class="fas fa-stethoscope" style="color:#10B981;"></i> Consultas Recientes</h6>
                    <button class="btn-ficha-action">Nueva Consulta</button>
                </div>
                <div class="placeholder-content">
                    <i class="fas fa-notes-medical"></i>
                    <p class="mb-0">Aún no se han registrado consultas médicas.</p>
                </div>
            </div>
        </div>

        <div id="panel-citas" class="tab-panel-content d-none">
            <div class="content-card">
                <div class="card-header"><h6 class="card-title"><i class="fas fa-calendar-alt"></i> Agenda del Paciente</h6></div>
                <div class="placeholder-content"><i class="fas fa-calendar-times"></i><p>Módulo de citas en desarrollo.</p></div>
            </div>
        </div>
        <div id="panel-consulta" class="tab-panel-content @(ViewBag.Modo == "consulta" ? "" : "d-none")">
        @if (ViewBag.Modo == "consulta")
        {
            var consultaActiva = (MediTech.Backend.Models.Consulta)ViewBag.ConsultaActiva;
            
