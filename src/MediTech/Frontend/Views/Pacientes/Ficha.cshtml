                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-muted">Observaciones Adicionales</label>
                                    <textarea id="cierreObservaciones" class="form-control" rows="3" placeholder="Recomendaciones, notas clínicas..."></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Sección 2: Tratamientos -->
                        <div class="cierre-section">
                            <h6 class="fw-bold mb-3"><i class="fas fa-hand-holding-medical text-info me-2"></i>2. Tratamientos Aplicados</h6>
                            <div class="row align-items-end mb-3">
                                <div class="col-md-7">
                                    <label class="form-label small fw-bold text-muted">Seleccionar Tratamiento</label>
                                    <select id="selCierreTratamiento" class="form-select" onchange="actualizarPrecioCierre('TRATAMIENTO')">
                                        <option value="">-- Seleccione --</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">Precio (<span class="simbolo-moneda">$</span>)</label>
                                    <input type="number" id="precioCierreTratamiento" class="form-control" step="0.01" readonly style="background-color: #f1f5f9;">
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-outline-primary w-100" type="button" onclick="agregarItemCierre('TRATAMIENTO')"><i class="fas fa-plus me-1"></i> Agregar</button>
                                </div>
                            </div>
                            <table class="cierre-table">
                                <thead><tr><th>Tratamiento</th><th class="text-end">Precio</th><th class="text-center">Remover</th></tr></thead>
                                <tbody id="tbodyCierreTratamientos"></tbody>
                            </table>
                        </div>

                        <!-- Sección 3: Productos -->
                        <div class="cierre-section">
                            <h6 class="fw-bold mb-3"><i class="fas fa-box-open text-warning me-2"></i>3. Productos</h6>
                            <div class="row align-items-end mb-3">
                                <div class="col-md-5">
                                    <label class="form-label small fw-bold text-muted">Seleccionar Producto</label>
                                    <select id="selCierreProducto" class="form-select" onchange="actualizarPrecioCierre('PRODUCTO')">
                                        <option value="">-- Seleccione --</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">Precio (<span class="simbolo-moneda">$</span>)</label>
                                    <input type="number" id="precioCierreProducto" class="form-control" step="0.01" readonly style="background-color: #f1f5f9;">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">Cantidad</label>
                                    <input type="number" id="cantCierreProducto" class="form-control" value="1" min="1">
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-outline-warning w-100 text-dark" type="button" onclick="agregarItemCierre('PRODUCTO')"><i class="fas fa-plus me-1"></i> Agregar</button>
                                </div>
                            </div>
                            <table class="cierre-table">
                                <thead><tr><th>Producto</th><th class="text-center">Cant.</th><th class="text-end">Precio</th><th class="text-end">Subtotal</th><th class="text-center" style="width: 80px;">Remover</th></tr></thead>
                                <tbody id="tbodyCierreProductos"></tbody>
                            </table>
                        </div>

                        <!-- Sección 4: Resumen -->
                        <div class="row justify-content-end mt-4">
                            <div class="col-md-5">
                                <div class="total-box shadow-sm">
                                    <h6 class="fw-bold mb-3 text-center"><i class="fas fa-file-invoice-dollar me-2" style="color:#1e40af;"></i>Resumen de la Cuenta</h6>
                                    <div class="total-row"><span>Subtotal Tratamientos:</span> <span><span class="simbolo-moneda">$</span><span id="resCierreTrat">0.00</span></span></div>
                                    <div class="total-row"><span>Subtotal Productos:</span> <span><span class="simbolo-moneda">$</span><span id="resCierreProd">0.00</span></span></div>
                                    <div class="total-row total-final"><span>TOTAL FINAL:</span> <span><span class="simbolo-moneda">$</span><span id="resCierreTotal">0.00</span></span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 8px;">Cancelar</button>
                        <button type="button" class="btn btn-success px-4 fw-bold shadow-sm" id="btnConfirmarCierre" onclick="submitCierreConsulta()" style="border-radius: 8px;"><i class="fas fa-check me-2"></i>Confirmar y Facturar</button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- MODAL ORDEN DE EXAMEN -->
        <div class="modal fade" id="modalOrdenExamen" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-indigo text-white" style="background-color: #6366F1;">
                        <h5 class="modal-title fw-bold"><i class="fas fa-file-medical-alt me-2"></i>Nueva Orden de Examen</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Nombre del Examen</label>
                            <input type="text" id="ordenExamenNombre" class="form-control" placeholder="Ej: BHS, Perfil Lipídico, etc.">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary" onclick="guardarOrdenExamen()">Guardar Orden</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- MODAL RESULTADO DE EXAMEN -->
        <div class="modal fade" id="modalResultadoExamen" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title fw-bold"><i class="fas fa-upload me-2"></i>Registrar Resultado de Examen</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="resultadoExamenId">
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Imagen del Resultado</label>
                                <div class="upload-zone" id="examenDropZone" onclick="document.getElementById('examenFileInput').click()" style="padding: 20px;">
                                    <div id="examenDropContent">
                                        <i class="fas fa-cloud-upload-alt fs-2"></i>
                                        <p class="small mb-0">Haga clic o arrastre la imagen aquí</p>
                                    </div>
                                    <div id="examenFilePreview" class="d-none mt-2 text-center">
                                        <img id="examenPreviewImg" src="#" style="max-width: 100%; max-height: 200px; border-radius: 8px;">
                                    </div>
                                </div>
                                <input type="file" id="examenFileInput" class="d-none" accept="image/*" onchange="handleExamenFileSelect(event)">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Comentario / Respuesta Médica</label>
                                <textarea id="resultadoExamenComentario" class="form-control" rows="8" placeholder="Escriba su observación sobre el resultado..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-success" id="btnGuardarResultado" onclick="guardarResultadoExamen()">Guardar Resultado</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- MODAL DETALLE DE CONSULTA -->
        <div class="modal fade" id="modalDetalleConsulta" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="detailModalTitle"><i class="fas fa-stethoscope text-success me-2"></i>Detalle de Consulta</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4" id="detailModalBody">
                        <!-- Se llena vía JS -->
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal" style="border-radius: 8px;">Cerrar</button>
                        <button type="button" class="btn btn-primary fw-bold" onclick="window.print()" style="border-radius: 8px;"><i class="fas fa-print me-1"></i> Imprimir</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- MODAL DETALLE DE FACTURA -->
        <div class="modal fade" id="modalDetalleFactura" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold"><i class="fas fa-file-invoice-dollar text-primary me-2"></i>Detalle de Transacción</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4" id="detailFacturaBody">
                        <!-- Se llena vía JS -->
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal" style="border-radius: 8px;">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- PHOTO MODAL -->

        <div id="photoModal" class="photo-modal" onclick="closePhotoModal()">
            <span class="close-modal">&times;</span>
            <div class="modal-content-wrapper" onclick="event.stopPropagation()">
                <img class="modal-photo" id="modalImg">
                <div id="modalCaption" class="modal-caption"></div>
            </div>
        </div>
        <!-- CAMERA MODAL -->
        <div class="modal fade" id="modalCamara" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                    <div class="modal-header bg-dark text-white border-0">
                        <h5 class="modal-title fw-bold"><i class="fas fa-camera me-2"></i>Capturar Fotografía</h5>
                        <button type="button" class="btn-close btn-close-white" onclick="cerrarCamara()" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-0 bg-black text-center position-relative">
                        <video id="videoCamara" autoplay playsinline style="width: 100%; max-height: 70vh; object-fit: cover;"></video>
                        <canvas id="canvasCamara" class="d-none"></canvas>
                        
                        <!-- Overlay controls -->
                        <div class="position-absolute bottom-0 w-100 p-3 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center gap-4">
                            <button type="button" class="btn btn-secondary rounded-circle" onclick="cambiarCamara()" style="width: 50px; height: 50px;" title="Rotar cámara">
                                <i class="fas fa-sync-alt fs-5"></i>
                            </button>
                            <button type="button" class="btn btn-light rounded-circle shadow" onclick="capturarFoto()" style="width: 70px; height: 70px; border: 5px solid #CBD5E1;" title="Capturar">
                                <i class="fas fa-camera fs-3 text-dark"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    let historialData = null;
    const pacienteId = parseInt('@Model.IdPaciente');
    let fullCitasData = [];
    let currentCitasPage = 1;
    const citasPageSize = 6;
    let currentConsultasPage = 1;
    const consultasPageSize = 6;
    let examenesLoaded = false;
    let citasLoaded = false;
    let consultasHistoryLoaded = false;
    let galeriaLoaded = false;
    let documentosLoaded = false;
    let finanzasLoaded = false;
    let allConsultas = [];
    let modalCurrencySymbol = '$';
    let modalCurrencyId = 1;

    // Load Global Currency Configuration on load
    document.addEventListener('DOMContentLoaded', async () => {
        if ('@ViewBag.Modo' !== 'consulta') {
            loadCitasPaciente();
        }

        try {
            const resC = await fetch('/Consultas/GetMonedaConfig');
            const config = await resC.json();
            if (config.success) {
                modalCurrencySymbol = config.simbolo;
                modalCurrencyId = config.id;
                // Update all static labels
                document.querySelectorAll('.simbolo-moneda').forEach(el => el.textContent = modalCurrencySymbol);
            }
        } catch(e) { console.error('Error preload currency', e); }
    });


    // DASHBOARD LOGIC REMOVED

    function switchTab(tabName) {
        console.log('Switching to tab:', tabName);
        // Update tabs active state
        document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
        const activeTab = document.getElementById('tab-' + tabName);
        if (activeTab) activeTab.classList.add('active');

        // Update panels visibility
        document.querySelectorAll('.tab-panel-content').forEach(el => el.classList.add('d-none'));
        const activePanel = document.getElementById('panel-' + tabName);
        if (activePanel) activePanel.classList.remove('d-none');

        // Special loads wrapped in try-catch to ensure navigation never blocks
        try {
            if (tabName === 'historial' && !historialData) cargarHistorial();
            if (tabName === 'galeria' && !galeriaLoaded) cargarGaleria();
            if (tabName === 'documentos' && !documentosLoaded) cargarDocumentos();
            if (tabName === 'examenes' && !examenesLoaded) cargarExamenes();
            if (tabName === 'consulta' && !consultasHistoryLoaded) {
                cargarConsultasHistory();
            }
            if (tabName === 'citas' && !citasLoaded) {
                loadCitasPaciente();
            } else if (tabName === 'citas') {
                renderCitasHistory(currentCitasPage);
            }
            if (tabName === 'finanzas' && !finanzasLoaded) cargarFinanzas();
        } catch (e) {
            console.warn('Error loading tab data:', tabName, e);
        }
    }


    function setToggle(field, value) {
        const group = document.querySelector(`.toggle-group[data-field="${field}"]`);
        if (!group) return;
        
        const btns = group.querySelectorAll('.toggle-btn');
        
        // Reset classes
        btns[0].classList.remove('active-si');
        btns[1].classList.remove('active-no');

        // Set active class
        if (value === true) btns[0].classList.add('active-si');
        else if (value === false) btns[1].classList.add('active-no');

        // Show/hide detail if exists
        const detailMap = {
            'alergias': 'histAlergiasDetalle',
            'medicamento': 'histMedicamentoDetalle',
            'otros': 'histOtrosDetalle',
            'cirugias': 'histCirugiasDetalle'
        };

        if (detailMap[field]) {
            const input = document.getElementById(detailMap[field]);
            if (value) input.classList.remove('d-none');
            else input.classList.add('d-none');
        }
    }

    async function cargarHistorial() {
        document.getElementById('historialLoading').classList.remove('d-none');
        try {
            const response = await fetch(`/Pacientes/GetHistorial/${pacienteId}`);
            const result = await response.json();
            if (result.success && result.data) {
                historialData = result.data;
                fillForm(result.data);
            }
        } catch (e) {
            console.error('Error loading history:', e);
        } finally {
            document.getElementById('historialLoading').classList.add('d-none');
        }
    }

    function fillForm(data) {
        setToggle('alergias', data.alergias);
        document.getElementById('histAlergiasDetalle').value = data.alergiasDetalle || '';
        
        setToggle('medicamento', data.tomaMedicamento);
        document.getElementById('histMedicamentoDetalle').value = data.medicamentoDetalle || '';

        setToggle('hipertension', data.hipertension);
        setToggle('diabetes', data.diabetes);
        setToggle('embarazada', data.embarazada);
        setToggle('cardiacos', data.cardiacos);
        setToggle('oncologico', data.antecedenteOncologico);
        
        setToggle('otros', data.otrosPadecimientos);
        document.getElementById('histOtrosDetalle').value = data.otrosPadecimientosDetalle || '';

        setToggle('alcohol', data.consumeAlcohol);
        setToggle('fuma', data.fumaCigarrillos);
        setToggle('ejercicio', data.realizaEjercicio);

        setToggle('cirugias', data.cirugiasEsteticas);
        document.getElementById('histCirugiasDetalle').value = data.cirugiasEsteticasDetalle || '';
    }

    async function guardarHistorial() {
        const data = {
            idPaciente: pacienteId,
            alergias: document.querySelector('.toggle-group[data-field="alergias"] .active-si') != null,
            alergiasDetalle: document.getElementById('histAlergiasDetalle').value,
            tomaMedicamento: document.querySelector('.toggle-group[data-field="medicamento"] .active-si') != null,
            medicamentoDetalle: document.getElementById('histMedicamentoDetalle').value,
            hipertension: document.querySelector('.toggle-group[data-field="hipertension"] .active-si') != null,
            diabetes: document.querySelector('.toggle-group[data-field="diabetes"] .active-si') != null,
            embarazada: document.querySelector('.toggle-group[data-field="embarazada"] .active-si') != null,
            cardiacos: document.querySelector('.toggle-group[data-field="cardiacos"] .active-si') != null,
            antecedenteOncologico: document.querySelector('.toggle-group[data-field="oncologico"] .active-si') != null,
            otrosPadecimientos: document.querySelector('.toggle-group[data-field="otros"] .active-si') != null,
            otrosPadecimientosDetalle: document.getElementById('histOtrosDetalle').value,
            consumeAlcohol: document.querySelector('.toggle-group[data-field="alcohol"] .active-si') != null,
            fumaCigarrillos: document.querySelector('.toggle-group[data-field="fuma"] .active-si') != null,
            realizaEjercicio: document.querySelector('.toggle-group[data-field="ejercicio"] .active-si') != null,
            cirugiasEsteticas: document.querySelector('.toggle-group[data-field="cirugias"] .active-si') != null,
            cirugiasEsteticasDetalle: document.getElementById('histCirugiasDetalle').value
        };

        const btn = document.querySelector('button[onclick="guardarHistorial()"]');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
        btn.disabled = true;

        try {
            const response = await fetch('/Pacientes/GuardarHistorial', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if (result.success) {
                // Success feedback
                const check = document.createElement('i');
                check.className = 'fas fa-check-circle ms-2';
                btn.parentElement.appendChild(check);
                setTimeout(() => check.remove(), 3000);
                
                historialData = data;
                MediToast.success('¡Historial guardado exitosamente!');
            } else {
                MediToast.error('Error al guardar: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            MediToast.error('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    // --- GALLERY LOGIC ---
    let selectedFile = null;

    // Drag and drop helper
    function initDragAndDrop() {
        const dropZone = document.getElementById('dropZone');
        if (!dropZone) return;

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, e => {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.add('dragover'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('dragover'), false);
        });

        dropZone.addEventListener('drop', e => {
            const dt = e.dataTransfer;
            const files = dt.files;
            if (files.length > 0) prepareFile(files[0]);
        }, false);
    }

    function handleFileSelect(e) {
        if (e.target.files.length > 0) prepareFile(e.target.files[0]);
    }

    function prepareFile(file) {
        if (!file.type.startsWith('image/')) {
            MediToast.warning('Solo se permiten archivos de imagen.');
            return;
        }
        selectedFile = file;
        
        // Show preview info
        const preview = document.getElementById('filePreview');
        const previewImg = document.getElementById('previewImg');
        const nameDisp = document.getElementById('fileNameDisp');
        const dropContent = document.getElementById('dropZoneContent');

        if (preview && previewImg && nameDisp) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                preview.classList.remove('d-none');
                if (dropContent) dropContent.classList.add('d-none');
                nameDisp.textContent = file.name;
            }
            reader.readAsDataURL(file);
        }
    }

    async function uploadSelectedFile() {
        if (!selectedFile) {
            MediToast.warning('Por favor, seleccione una foto primero haciendo clic en la zona de carga.');
            return;
        }

        const titulo = document.getElementById('fotoTitulo').value;
        const formData = new FormData();
        formData.append('idPaciente', pacienteId);
        formData.append('titulo', titulo);
        formData.append('file', selectedFile);

        const btn = document.getElementById('btnSubir');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Subiendo...';
        btn.disabled = true;

        try {
            const response = await fetch('/Galeria/UploadFoto', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            if (result.success) {
                // Clear state
                selectedFile = null;
                document.getElementById('fileInput').value = '';
                document.getElementById('fotoTitulo').value = '';
                document.getElementById('filePreview').classList.add('d-none');
                const dropContent = document.getElementById('dropZoneContent');
                if (dropContent) dropContent.classList.remove('d-none');
                
                cargarGaleria();
                MediToast.success('¡Foto guardada con éxito!');
            } else {
                MediToast.error('Error: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            MediToast.error('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    // ============ CAMERA MODULE ============
    let videoStream = null;
    let cameraModalInstance = null;
    let currentFacingMode = "environment"; // Priorizar cámara trasera

    function abrirCamara() {
        cameraModalInstance = new bootstrap.Modal(document.getElementById('modalCamara'));
        cameraModalInstance.show();
        iniciarVideo(currentFacingMode);
        
        // Listen to hidden to make sure we stop tracks if closed via backdrop
        document.getElementById('modalCamara').addEventListener('hidden.bs.modal', cerrarCamaraTrackSolo);
    }

    async function iniciarVideo(facingMode) {
        const video = document.getElementById('videoCamara');
        if (videoStream) {
            videoStream.getTracks().forEach(track => track.stop());
        }

        try {
            const constraints = {
                video: { facingMode: facingMode }
            };
            videoStream = await navigator.mediaDevices.getUserMedia(constraints);
            video.srcObject = videoStream;
        } catch (error) {
            console.error("Error al acceder a la cámara:", error);
            cerrarCamara();
            MediToast.error("No se pudo acceder a la cámara. Asegure los permisos y de estar usando conexión HTTPS.");
        }
    }

    function cambiarCamara() {
        currentFacingMode = currentFacingMode === "environment" ? "user" : "environment";
        iniciarVideo(currentFacingMode);
    }

    function capturarFoto() {
        const video = document.getElementById('videoCamara');
        const canvas = document.getElementById('canvasCamara');
        
        if (!videoStream || !videoStream.active) return;

        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

        canvas.toBlob(blob => {
            if (!blob) return;
            const file = new File([blob], "captura_" + Date.now() + ".jpg", { type: "image/jpeg" });
            prepareFile(file); // Reusar función existente para la previsualización
            cerrarCamara();
            MediToast.success("Foto capturada. Puedes añadir un título y guardarla.");
        }, 'image/jpeg', 0.85); 
    }

    function cerrarCamaraTrackSolo() {
        if (videoStream) {
            videoStream.getTracks().forEach(track => track.stop());
            videoStream = null;
        }
    }

    function cerrarCamara() {
        cerrarCamaraTrackSolo();
        if (cameraModalInstance) {
            cameraModalInstance.hide();
        }
    }

    async function cargarGaleria() {
        const grid = document.getElementById('galeriaGrid');
        try {
            const response = await fetch(`/Galeria/GetFotos/${pacienteId}`);
            const result = await response.json();
            if (result.success) renderGaleria(result.data);
        } catch (e) {
            console.error(e);
            grid.innerHTML = '<div class="text-center w-100 py-4 text-danger">Error al cargar la galería.</div>';
        } finally {
            galeriaLoaded = true;
        }
    }

    const FOTOS_PER_PAGE = 8;
    let allFotos = [];
    let currentPage = 1;

    function renderGaleria(fotos) {
        allFotos = fotos;
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const grid = document.getElementById('galeriaGrid');
        const pag = document.getElementById('galeriaPagination');
        if (!grid) return;

        if (allFotos.length === 0) {
            grid.innerHTML = '<div class="text-center w-100 py-5 text-muted"><i class="fas fa-images fs-2 d-block mb-3 opacity-25"></i>No hay fotos registradas aún.</div>';
            if (pag) pag.innerHTML = '';
            return;
        }

        const totalPages = Math.ceil(allFotos.length / FOTOS_PER_PAGE);
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * FOTOS_PER_PAGE;
        const pageFotos = allFotos.slice(start, start + FOTOS_PER_PAGE);

        grid.innerHTML = pageFotos.map(foto => `
            <div class="photo-item">
                <button class="photo-delete" onclick="eliminarFoto(${foto.idFoto})" title="Eliminar">
                    <i class="fas fa-trash-alt"></i>
                </button>
