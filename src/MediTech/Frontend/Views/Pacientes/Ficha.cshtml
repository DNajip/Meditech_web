    function renderCitasPagination(totalItems) {
        const totalPages = Math.ceil(totalItems / citasPageSize);
        let pagesHtml = '';

        // Previous button
        pagesHtml += `
            <li class="page-item ${currentCitasPage === 1 ? 'disabled' : ''}">
