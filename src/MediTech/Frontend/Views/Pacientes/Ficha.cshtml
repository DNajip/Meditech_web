        <!-- MODAL CIERRE DE CONSULTA -->
        <div class="modal fade" id="modalCierreConsulta" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title fw-bold"><i class="fas fa-check-circle me-2"></i>Cierre de Consulta</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Sección 1: Diagnóstico Final y Observaciones -->
                        <div class="cierre-section">
                            <h6 class="fw-bold mb-3"><i class="fas fa-notes-medical text-primary me-2"></i>1. Diagnóstico y Observaciones</h6>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-muted">Diagnóstico Final</label>
                                    <textarea id="cierreDiagnostico" class="form-control" rows="3" placeholder="Diagnóstico definitivo de la consulta..."></textarea>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-muted">Observaciones Adicionales</label>
                                    <textarea id="cierreObservaciones" class="form-control" rows="3" placeholder="Recomendaciones, notas clínicas..."></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Sección 2: Tratamientos -->
                        <div class="cierre-section">
                            <h6 class="fw-bold mb-3"><i class="fas fa-hand-holding-medical text-info me-2"></i>2. Tratamientos Aplicados</h6>
                            <div class="row align-items-end mb-3">
                                <div class="col-md-7">
                                    <label class="form-label small fw-bold text-muted">Seleccionar Tratamiento</label>
                                    <select id="selCierreTratamiento" class="form-select" onchange="actualizarPrecioCierre('TRATAMIENTO')">
                                        <option value="">-- Seleccione --</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">Precio ($)</label>
                                    <input type="number" id="precioCierreTratamiento" class="form-control" step="0.01" readonly style="background-color: #f1f5f9;">
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-outline-primary w-100" type="button" onclick="agregarItemCierre('TRATAMIENTO')"><i class="fas fa-plus me-1"></i> Agregar</button>
                                </div>
                            </div>
                            <table class="cierre-table">
                                <thead><tr><th>Tratamiento</th><th class="text-end">Precio</th><th class="text-center">Remover</th></tr></thead>
                                <tbody id="tbodyCierreTratamientos"></tbody>
                            </table>
                        </div>

                        <!-- Sección 3: Productos -->
                        <div class="cierre-section">
                            <h6 class="fw-bold mb-3"><i class="fas fa-box-open text-warning me-2"></i>3. Productos</h6>
                            <div class="row align-items-end mb-3">
                                <div class="col-md-5">
                                    <label class="form-label small fw-bold text-muted">Seleccionar Producto</label>
                                    <select id="selCierreProducto" class="form-select" onchange="actualizarPrecioCierre('PRODUCTO')">
                                        <option value="">-- Seleccione --</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">Precio ($)</label>
                                    <input type="number" id="precioCierreProducto" class="form-control" step="0.01" readonly style="background-color: #f1f5f9;">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">Cantidad</label>
                                    <input type="number" id="cantCierreProducto" class="form-control" value="1" min="1">
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-outline-warning w-100 text-dark" type="button" onclick="agregarItemCierre('PRODUCTO')"><i class="fas fa-plus me-1"></i> Agregar</button>
                                </div>
                            </div>
                            <table class="cierre-table">
                                <thead><tr><th>Producto</th><th class="text-center">Cant.</th><th class="text-end">Precio</th><th class="text-end">Subtotal</th><th class="text-center" style="width: 80px;">Remover</th></tr></thead>
                                <tbody id="tbodyCierreProductos"></tbody>
                            </table>
                        </div>

                        <!-- Sección 4: Resumen -->
                        <div class="row justify-content-end mt-4">
                            <div class="col-md-5">
                                <div class="total-box shadow-sm">
                                    <h6 class="fw-bold mb-3 text-center"><i class="fas fa-file-invoice-dollar me-2" style="color:#1e40af;"></i>Resumen de la Cuenta</h6>
                                    <div class="total-row"><span>Subtotal Tratamientos:</span> <span>$<span id="resCierreTrat">0.00</span></span></div>
                                    <div class="total-row"><span>Subtotal Productos:</span> <span>$<span id="resCierreProd">0.00</span></span></div>
                                    <div class="total-row total-final"><span>TOTAL FINAL:</span> <span>$<span id="resCierreTotal">0.00</span></span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 8px;">Cancelar</button>
                        <button type="button" class="btn btn-success px-4 fw-bold shadow-sm" id="btnConfirmarCierre" onclick="submitCierreConsulta()" style="border-radius: 8px;"><i class="fas fa-check me-2"></i>Confirmar y Facturar</button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- MODAL ORDEN DE EXAMEN -->
        <div class="modal fade" id="modalOrdenExamen" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-indigo text-white" style="background-color: #6366F1;">
                        <h5 class="modal-title fw-bold"><i class="fas fa-file-medical-alt me-2"></i>Nueva Orden de Examen</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Nombre del Examen</label>
                            <input type="text" id="ordenExamenNombre" class="form-control" placeholder="Ej: BHS, Perfil Lipídico, etc.">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary" onclick="guardarOrdenExamen()">Guardar Orden</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- MODAL RESULTADO DE EXAMEN -->
        <div class="modal fade" id="modalResultadoExamen" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title fw-bold"><i class="fas fa-upload me-2"></i>Registrar Resultado de Examen</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="resultadoExamenId">
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Imagen del Resultado</label>
                                <div class="upload-zone" id="examenDropZone" onclick="document.getElementById('examenFileInput').click()" style="padding: 20px;">
                                    <div id="examenDropContent">
                                        <i class="fas fa-cloud-upload-alt fs-2"></i>
                                        <p class="small mb-0">Haga clic o arrastre la imagen aquí</p>
                                    </div>
                                    <div id="examenFilePreview" class="d-none mt-2 text-center">
                                        <img id="examenPreviewImg" src="#" style="max-width: 100%; max-height: 200px; border-radius: 8px;">
                                    </div>
                                </div>
                                <input type="file" id="examenFileInput" class="d-none" accept="image/*" onchange="handleExamenFileSelect(event)">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Comentario / Respuesta Médica</label>
                                <textarea id="resultadoExamenComentario" class="form-control" rows="8" placeholder="Escriba su observación sobre el resultado..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-success" id="btnGuardarResultado" onclick="guardarResultadoExamen()">Guardar Resultado</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- PHOTO MODAL -->

        <div id="photoModal" class="photo-modal" onclick="closePhotoModal()">
            <span class="close-modal">&times;</span>
            <div class="modal-content-wrapper" onclick="event.stopPropagation()">
                <img class="modal-photo" id="modalImg">
                <div id="modalCaption" class="modal-caption"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let historialData = null;
    const pacienteId = @Model.IdPaciente;
    let galeriaLoaded = false;
    let documentosLoaded = false;
    let examenesLoaded = false;


    function switchTab(tabName) {
        console.log('Switching to tab:', tabName);
        // Update tabs active state
        document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
        const activeTab = document.getElementById('tab-' + tabName);
        if (activeTab) activeTab.classList.add('active');

        // Update panels visibility
        document.querySelectorAll('.tab-panel-content').forEach(el => el.classList.add('d-none'));
        const activePanel = document.getElementById('panel-' + tabName);
        if (activePanel) activePanel.classList.remove('d-none');

        // Also handle the common footer visibility (only for resumen/consulta)
        const commonFooter = document.getElementById('common-footer-panels');
        if (commonFooter) {
            if (tabName === 'resumen' || tabName === 'consulta') {
                commonFooter.classList.remove('d-none');
            } else {
                commonFooter.classList.add('d-none');
            }
        }

        // Special load for Historial
        if (tabName === 'historial' && !historialData) {
            cargarHistorial();
        }
        
        // Special load for Galeria
        if (tabName === 'galeria' && !galeriaLoaded) {
            cargarGaleria();
        }
        // Special load for Documentos
        if (tabName === 'documentos' && !documentosLoaded) {
            cargarDocumentos();
        }
        // Special load for Examenes
        if (tabName === 'examenes' && !examenesLoaded) {
            cargarExamenes();
        }
    }


    function setToggle(field, value) {
        const group = document.querySelector(`.toggle-group[data-field="${field}"]`);
        if (!group) return;
        
        const btns = group.querySelectorAll('.toggle-btn');
        
        // Reset classes
        btns[0].classList.remove('active-si');
        btns[1].classList.remove('active-no');

        // Set active class
        if (value === true) btns[0].classList.add('active-si');
        else if (value === false) btns[1].classList.add('active-no');

        // Show/hide detail if exists
        const detailMap = {
            'alergias': 'histAlergiasDetalle',
            'medicamento': 'histMedicamentoDetalle',
            'otros': 'histOtrosDetalle',
            'cirugias': 'histCirugiasDetalle'
        };

        if (detailMap[field]) {
            const input = document.getElementById(detailMap[field]);
            if (value) input.classList.remove('d-none');
            else input.classList.add('d-none');
        }
    }

    async function cargarHistorial() {
        document.getElementById('historialLoading').classList.remove('d-none');
        try {
            const response = await fetch(`/Pacientes/GetHistorial/${pacienteId}`);
            const result = await response.json();
            if (result.success && result.data) {
                historialData = result.data;
                fillForm(result.data);
            }
        } catch (e) {
            console.error('Error loading history:', e);
        } finally {
            document.getElementById('historialLoading').classList.add('d-none');
        }
    }

    function fillForm(data) {
        setToggle('alergias', data.alergias);
        document.getElementById('histAlergiasDetalle').value = data.alergiasDetalle || '';
        
        setToggle('medicamento', data.tomaMedicamento);
        document.getElementById('histMedicamentoDetalle').value = data.medicamentoDetalle || '';

        setToggle('hipertension', data.hipertension);
        setToggle('diabetes', data.diabetes);
        setToggle('embarazada', data.embarazada);
        setToggle('cardiacos', data.cardiacos);
        setToggle('oncologico', data.antecedenteOncologico);
        
        setToggle('otros', data.otrosPadecimientos);
        document.getElementById('histOtrosDetalle').value = data.otrosPadecimientosDetalle || '';

        setToggle('alcohol', data.consumeAlcohol);
        setToggle('fuma', data.fumaCigarrillos);
        setToggle('ejercicio', data.realizaEjercicio);

        setToggle('cirugias', data.cirugiasEsteticas);
        document.getElementById('histCirugiasDetalle').value = data.cirugiasEsteticasDetalle || '';
    }

    async function guardarHistorial() {
        const data = {
            idPaciente: pacienteId,
            alergias: document.querySelector('.toggle-group[data-field="alergias"] .active-si') != null,
            alergiasDetalle: document.getElementById('histAlergiasDetalle').value,
            tomaMedicamento: document.querySelector('.toggle-group[data-field="medicamento"] .active-si') != null,
            medicamentoDetalle: document.getElementById('histMedicamentoDetalle').value,
            hipertension: document.querySelector('.toggle-group[data-field="hipertension"] .active-si') != null,
            diabetes: document.querySelector('.toggle-group[data-field="diabetes"] .active-si') != null,
            embarazada: document.querySelector('.toggle-group[data-field="embarazada"] .active-si') != null,
            cardiacos: document.querySelector('.toggle-group[data-field="cardiacos"] .active-si') != null,
            antecedenteOncologico: document.querySelector('.toggle-group[data-field="oncologico"] .active-si') != null,
            otrosPadecimientos: document.querySelector('.toggle-group[data-field="otros"] .active-si') != null,
            otrosPadecimientosDetalle: document.getElementById('histOtrosDetalle').value,
            consumeAlcohol: document.querySelector('.toggle-group[data-field="alcohol"] .active-si') != null,
            fumaCigarrillos: document.querySelector('.toggle-group[data-field="fuma"] .active-si') != null,
            realizaEjercicio: document.querySelector('.toggle-group[data-field="ejercicio"] .active-si') != null,
            cirugiasEsteticas: document.querySelector('.toggle-group[data-field="cirugias"] .active-si') != null,
            cirugiasEsteticasDetalle: document.getElementById('histCirugiasDetalle').value
        };

        const btn = document.querySelector('button[onclick="guardarHistorial()"]');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
        btn.disabled = true;

        try {
            const response = await fetch('/Pacientes/GuardarHistorial', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if (result.success) {
                // Success feedback
                const check = document.createElement('i');
                check.className = 'fas fa-check-circle ms-2';
                btn.parentElement.appendChild(check);
                setTimeout(() => check.remove(), 3000);
                
                historialData = data;
                alert('¡Historial guardado exitosamente!');
            } else {
                alert('Error al guardar: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    // --- GALLERY LOGIC ---
    let selectedFile = null;

    // Drag and drop helper
    function initDragAndDrop() {
        const dropZone = document.getElementById('dropZone');
        if (!dropZone) return;

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, e => {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.add('dragover'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('dragover'), false);
        });

        dropZone.addEventListener('drop', e => {
            const dt = e.dataTransfer;
            const files = dt.files;
            if (files.length > 0) prepareFile(files[0]);
        }, false);
    }

    function handleFileSelect(e) {
        if (e.target.files.length > 0) prepareFile(e.target.files[0]);
    }

    function prepareFile(file) {
        if (!file.type.startsWith('image/')) {
            alert('Solo se permiten archivos de imagen.');
            return;
        }
        selectedFile = file;
        
        // Show preview info
        const preview = document.getElementById('filePreview');
        const previewImg = document.getElementById('previewImg');
        const nameDisp = document.getElementById('fileNameDisp');
        const dropContent = document.getElementById('dropZoneContent');

        if (preview && previewImg && nameDisp) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                preview.classList.remove('d-none');
                if (dropContent) dropContent.classList.add('d-none');
                nameDisp.textContent = file.name;
            }
            reader.readAsDataURL(file);
        }
    }

    async function uploadSelectedFile() {
        if (!selectedFile) {
            alert('Por favor, seleccione una foto primero haciendo clic en la zona de carga.');
            return;
        }

        const titulo = document.getElementById('fotoTitulo').value;
        const formData = new FormData();
        formData.append('idPaciente', pacienteId);
        formData.append('titulo', titulo);
        formData.append('file', selectedFile);

        const btn = document.getElementById('btnSubir');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Subiendo...';
        btn.disabled = true;

        try {
            const response = await fetch('/Galeria/UploadFoto', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            if (result.success) {
                // Clear state
                selectedFile = null;
                document.getElementById('fileInput').value = '';
                document.getElementById('fotoTitulo').value = '';
                document.getElementById('filePreview').classList.add('d-none');
                const dropContent = document.getElementById('dropZoneContent');
                if (dropContent) dropContent.classList.remove('d-none');
                
                cargarGaleria();
                alert('¡Foto guardada con éxito!');
            } else {
                alert('Error: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    async function cargarGaleria() {
        const grid = document.getElementById('galeriaGrid');
        try {
            const response = await fetch(`/Galeria/GetFotos/${pacienteId}`);
            const result = await response.json();
            if (result.success) renderGaleria(result.data);
        } catch (e) {
            console.error(e);
            grid.innerHTML = '<div class="text-center w-100 py-4 text-danger">Error al cargar la galería.</div>';
        } finally {
            galeriaLoaded = true;
        }
    }

    const FOTOS_PER_PAGE = 8;
    let allFotos = [];
    let currentPage = 1;

    function renderGaleria(fotos) {
        allFotos = fotos;
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const grid = document.getElementById('galeriaGrid');
        const pag = document.getElementById('galeriaPagination');
        if (!grid) return;

        if (allFotos.length === 0) {
            grid.innerHTML = '<div class="text-center w-100 py-5 text-muted"><i class="fas fa-images fs-2 d-block mb-3 opacity-25"></i>No hay fotos registradas aún.</div>';
            if (pag) pag.innerHTML = '';
            return;
        }

        const totalPages = Math.ceil(allFotos.length / FOTOS_PER_PAGE);
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * FOTOS_PER_PAGE;
        const pageFotos = allFotos.slice(start, start + FOTOS_PER_PAGE);

        grid.innerHTML = pageFotos.map(foto => `
            <div class="photo-item">
                <button class="photo-delete" onclick="eliminarFoto(${foto.idFoto})" title="Eliminar">
                    <i class="fas fa-trash-alt"></i>
                </button>
                <div class="photo-thumb-container" onclick="verFotoFull(${foto.idFoto})">
                    <img src="/Galeria/GetFotoContent/${foto.idFoto}" class="photo-thumb" alt="${foto.titulo || 'Foto clínica'}">
                </div>
                <div class="photo-info">
                    <div class="photo-title">${foto.titulo || 'Sin título'}</div>
                    <div class="photo-date">${foto.fecha}</div>
                </div>
            </div>
        `).join('');

        // Render pagination controls
        if (pag) {
            if (totalPages <= 1) { pag.innerHTML = ''; return; }
            let html = `<button onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}><i class="fas fa-chevron-left"></i></button>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
            }
            html += `<button onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}><i class="fas fa-chevron-right"></i></button>`;
            html += `<span class="page-info">${allFotos.length} fotos</span>`;
            pag.innerHTML = html;
        }
    }

    function goToPage(page) {
        const totalPages = Math.ceil(allFotos.length / FOTOS_PER_PAGE);
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderPage();
        // Scroll to top of gallery
        document.getElementById('galeriaGrid')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    async function eliminarFoto(id) {
        if (!confirm('¿Está seguro de eliminar esta foto?')) return;
        try {
            const response = await fetch(`/Galeria/DeleteFoto/${id}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) cargarGaleria();
            else alert(result.message);
        } catch (e) { console.error(e); alert('Error al eliminar.'); }
    }

    function verFotoFull(id) {
        const modal = document.getElementById('photoModal');
        const modalImg = document.getElementById('modalImg');
        const modalCaption = document.getElementById('modalCaption');
        
        if (!modal || !modalImg) return;

        modalImg.src = `/Galeria/GetFotoContent/${id}`;
        
        // Get title from the specific item in the grid
        const photoItem = document.querySelector(`.photo-item button[onclick="eliminarFoto(${id})"]`)?.parentElement;
        const title = photoItem?.querySelector('.photo-title')?.textContent || '';
        modalCaption.textContent = title === 'Sin título' ? '' : title;

        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevent scrolling
    }

    function closePhotoModal() {
        const modal = document.getElementById('photoModal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    }

    // ============ DOCUMENTOS MODULE ============
    let selectedDocFile = null;
    const DOCS_PER_PAGE = 8;
    let allDocs = [];
    let currentDocPage = 1;

    function initDocDragAndDrop() {
        const zone = document.getElementById('docDropZone');
        if (!zone) return;
        ['dragenter','dragover','dragleave','drop'].forEach(e => {
            zone.addEventListener(e, ev => { ev.preventDefault(); ev.stopPropagation(); });
        });
        zone.addEventListener('dragenter', () => zone.classList.add('drag-over'));
        zone.addEventListener('dragover', () => zone.classList.add('drag-over'));
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            zone.classList.remove('drag-over');
            const file = e.dataTransfer.files[0];
            if (file) prepareDocFile(file);
        });
    }

    function handleDocFileSelect(event) {
        const file = event.target.files[0];
        if (file) prepareDocFile(file);
    }

    function getDocIconClass(contentType, fileName) {
        if (contentType.includes('pdf')) return { icon: 'fas fa-file-pdf', css: 'pdf' };
        if (contentType.includes('word') || contentType.includes('document') || fileName.endsWith('.docx') || fileName.endsWith('.doc')) return { icon: 'fas fa-file-word', css: 'word' };
        if (contentType.includes('excel') || contentType.includes('sheet') || fileName.endsWith('.xlsx') || fileName.endsWith('.xls')) return { icon: 'fas fa-file-excel', css: 'excel' };
        if (contentType.startsWith('image/')) return { icon: 'fas fa-file-image', css: 'image' };
        return { icon: 'fas fa-file', css: 'other' };
    }

    function formatFileSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }

    function prepareDocFile(file) {
        selectedDocFile = file;
        const preview = document.getElementById('docFilePreview');
        const icon = document.getElementById('docPreviewIcon');
        const nameDisp = document.getElementById('docFileNameDisp');
        const sizeDisp = document.getElementById('docFileSizeDisp');
        const dropContent = document.getElementById('docDropZoneContent');

        if (preview && nameDisp) {
            const iconInfo = getDocIconClass(file.type, file.name);
            icon.className = iconInfo.icon + ' fs-4';
            nameDisp.textContent = file.name;
            sizeDisp.textContent = formatFileSize(file.size);
            preview.classList.remove('d-none');
            if (dropContent) dropContent.classList.add('d-none');
        }
    }

    async function uploadDocumento() {
        if (!selectedDocFile) { alert('Seleccione un archivo primero.'); return; }

        const formData = new FormData();
        formData.append('idPaciente', pacienteId);
        formData.append('titulo', document.getElementById('docTitulo').value || '');
        formData.append('file', selectedDocFile);

        const btn = document.getElementById('btnSubirDoc');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Subiendo...';
        btn.disabled = true;

        try {
            const response = await fetch('/Documentos/UploadDocumento', { method: 'POST', body: formData });
            const result = await response.json();
            if (result.success) {
                selectedDocFile = null;
                document.getElementById('docFileInput').value = '';
                document.getElementById('docTitulo').value = '';
                document.getElementById('docFilePreview').classList.add('d-none');
                const dropContent = document.getElementById('docDropZoneContent');
                if (dropContent) dropContent.classList.remove('d-none');
                cargarDocumentos();
                alert('\u00a1Documento guardado con \u00e9xito!');
            } else {
                alert('Error: ' + result.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error al conectar con el servidor.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    async function cargarDocumentos() {
        const list = document.getElementById('documentosList');
        try {
            const response = await fetch(`/Documentos/GetDocumentos/${pacienteId}`);
            const result = await response.json();
            if (result.success) {
                allDocs = result.data;
                currentDocPage = 1;
                renderDocsPage();
            }
        } catch (e) {
            console.error(e);
            list.innerHTML = '<div class="text-center w-100 py-4 text-danger">Error al cargar documentos.</div>';
        } finally {
            documentosLoaded = true;
        }
    }

    function renderDocsPage() {
        const list = document.getElementById('documentosList');
        const pag = document.getElementById('docsPagination');
        if (!list) return;

        if (allDocs.length === 0) {
            list.innerHTML = '<div class="text-center w-100 py-5 text-muted"><i class="fas fa-folder-open fs-2 d-block mb-3 opacity-25"></i>No hay documentos registrados a\u00fan.</div>';
            if (pag) pag.innerHTML = '';
            return;
        }

        const totalPages = Math.ceil(allDocs.length / DOCS_PER_PAGE);
        if (currentDocPage > totalPages) currentDocPage = totalPages;
        const start = (currentDocPage - 1) * DOCS_PER_PAGE;
        const pageDocs = allDocs.slice(start, start + DOCS_PER_PAGE);

        list.innerHTML = pageDocs.map(doc => {
            const iconInfo = getDocIconClass(doc.contentType, doc.nombreArchivo);
            const displayName = doc.titulo || doc.nombreArchivo;
            return `
                <div class="doc-item">
                    <div class="doc-icon ${iconInfo.css}"><i class="${iconInfo.icon}"></i></div>
                    <div class="doc-info">
                        <div class="doc-name" title="${doc.nombreArchivo}">${displayName}</div>
                        <div class="doc-meta">${doc.nombreArchivo} &bull; ${formatFileSize(doc.tamano)} &bull; ${doc.fecha}</div>
                    </div>
                    <div class="doc-actions">
                        <button class="btn-doc-download" onclick="descargarDocumento(${doc.idDocumento})" title="Descargar"><i class="fas fa-download"></i></button>
                        <button class="btn-doc-delete" onclick="eliminarDocumento(${doc.idDocumento})" title="Eliminar"><i class="fas fa-trash-alt"></i></button>
                    </div>
                </div>`;
        }).join('');

        // Pagination
        if (pag) {
            if (totalPages <= 1) { pag.innerHTML = ''; return; }
            let html = `<button onclick="goToDocPage(${currentDocPage - 1})" ${currentDocPage === 1 ? 'disabled' : ''}><i class="fas fa-chevron-left"></i></button>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="${i === currentDocPage ? 'active' : ''}" onclick="goToDocPage(${i})">${i}</button>`;
            }
            html += `<button onclick="goToDocPage(${currentDocPage + 1})" ${currentDocPage === totalPages ? 'disabled' : ''}><i class="fas fa-chevron-right"></i></button>`;
            html += `<span class="page-info">${allDocs.length} documentos</span>`;
            pag.innerHTML = html;
        }
    }

    function goToDocPage(page) {
        const totalPages = Math.ceil(allDocs.length / DOCS_PER_PAGE);
        if (page < 1 || page > totalPages) return;
        currentDocPage = page;
        renderDocsPage();
        document.getElementById('documentosList')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function descargarDocumento(id) {
        window.open(`/Documentos/DownloadDocumento/${id}`, '_blank');
    }

    async function eliminarDocumento(id) {
        if (!confirm('\u00bfEst\u00e1 seguro de eliminar este documento?')) return;
        try {
            const response = await fetch(`/Documentos/DeleteDocumento/${id}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) cargarDocumentos();
            else alert(result.message);
        } catch (e) { console.error(e); alert('Error al eliminar.'); }
    }
    // Initialize D&D on load
    document.addEventListener('DOMContentLoaded', () => {
        initDragAndDrop();
        initDocDragAndDrop();
    });
    
    // ============ EXAMENES MODULE ============
    let selectedExamenFile = null;
    let paginaActualExamenes = 1;


    async function cargarExamenes(pagina = 1) {
        paginaActualExamenes = pagina;
        const container = document.getElementById('examenesContainer');
        try {
            const response = await fetch(`/Examenes/GetExamenes/${pacienteId}?page=${pagina}&pageSize=6`);
            const result = await response.json();
            if (result.success) {
                renderExamenes(result);
            }
        } catch (e) {
            console.error(e);
            container.innerHTML = '<div class="text-center py-4 text-danger">Error al cargar exámenes.</div>';
        } finally {
            examenesLoaded = true;
        }
    }

    function renderExamenes(result) {
        const { data: examenes, totalPages, currentPage } = result;
        const container = document.getElementById('examenesContainer');
        
        if (examenes.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-file-invoice fs-2 d-block mb-3 opacity-25"></i>
                    <p class="mb-0">No se han ordenado exámenes para este paciente.</p>
                </div>`;
            return;
        }

        let html = `
            <div class="table-responsive mt-3">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Examen</th>
                            <th>Fecha Orden</th>
                            <th>Fecha Realizado</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${examenes.map(e => `
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">${e.nombreExamen}</div>
                                    ${e.comentarioMedico ? `<div class="small text-muted text-truncate" style="max-width: 250px;">${e.comentarioMedico}</div>` : ''}
                                </td>
                                <td class="small">${e.fechaOrden}</td>
                                <td class="small">${e.fechaResultado || '—'}</td>
                                <td>
                                    <span class="badge ${e.idEstado === 1 ? 'bg-warning-subtle text-warning' : (e.idEstado === 2 ? 'bg-success-subtle text-success' : 'bg-info-subtle text-info')}" style="border-radius:20px; font-size:0.7rem;">
                                        ${e.estado}
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary" onclick="abrirModalResultadoExamen(${e.idExamen}, '${e.nombreExamen}', '${e.comentarioMedico || ''}')" title="Subir Resultado / Comentar">
                                            <i class="fas ${e.idEstado === 1 ? 'fa-upload' : 'fa-edit'}"></i>
                                        </button>
                                        ${e.tieneImagen ? `
                                            <button class="btn btn-sm btn-outline-info" onclick="verImagenExamen(${e.idExamen}, '${e.nombreExamen}')" title="Ver Imagen">
                                                <i class="fas fa-image"></i>
                                            </button>` : ''}
                                        <button class="btn btn-sm btn-outline-danger" onclick="eliminarExamen(${e.idExamen})" title="Eliminar">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>`;

        // Pagination controls Premium UX/UI
        if (totalPages > 1 || result.totalItems > 0) {
            html += `
                <div class="d-flex justify-content-center align-items-center mt-4 mb-2">
                    <nav>
                        <ul class="examen-pagination">
                            <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                                <a class="page-link" href="javascript:void(0)" onclick="cargarExamenes(${currentPage - 1})" title="Anterior">
                                    <i class="fas fa-chevron-left" style="font-size: 0.8rem;"></i>
                                </a>
                            </li>
                            ${Array.from({ length: totalPages }, (_, i) => i + 1).map(p => `
                                <li class="page-item ${currentPage === p ? 'active' : ''}">
                                    <a class="page-link" href="javascript:void(0)" onclick="cargarExamenes(${p})">${p}</a>
                                </li>
                            `).join('')}
                            <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                                <a class="page-link" href="javascript:void(0)" onclick="cargarExamenes(${currentPage + 1})" title="Siguiente">
                                    <i class="fas fa-chevron-right" style="font-size: 0.8rem;"></i>
                                </a>
                            </li>
                            <li class="total-count">
                                ${result.totalItems} ${result.totalItems === 1 ? 'examen' : 'exámenes'}
                            </li>
                        </ul>
                    </nav>
                </div>`;
        }

        container.innerHTML = html;
    }

    function abrirModalOrdenExamen() {
        document.getElementById('ordenExamenNombre').value = '';
        const modal = new bootstrap.Modal(document.getElementById('modalOrdenExamen'));
        modal.show();
    }

    async function guardarOrdenExamen() {
        const nombre = document.getElementById('ordenExamenNombre').value;
        if (!nombre) return alert('Ingrese el nombre del examen.');

        try {
            const response = await fetch('/Examenes/GuardarExamen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ idPaciente: pacienteId, nombreExamen: nombre })
            });
            const result = await response.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.getElementById('modalOrdenExamen')).hide();
                cargarExamenes();
            } else alert(result.message);
        } catch (e) {
            console.error(e);
            alert('Error al guardar la orden.');
        }
    }

    function abrirModalResultadoExamen(id, nombre, comentario) {
        document.getElementById('resultadoExamenId').value = id;
        document.getElementById('resultadoExamenComentario').value = comentario;
        
        // Reset file upload state
        selectedExamenFile = null;
        document.getElementById('examenFileInput').value = '';
        document.getElementById('examenFilePreview').classList.add('d-none');
        document.getElementById('examenDropContent').classList.remove('d-none');
        
        const modal = new bootstrap.Modal(document.getElementById('modalResultadoExamen'));
        modal.show();
    }

    function handleExamenFileSelect(e) {
        const file = e.target.files[0];
        if (!file) return;
        if (!file.type.startsWith('image/')) {
            alert('Solo se permiten imágenes.');
            return;
        }
        
        selectedExamenFile = file;
        const reader = new FileReader();
        reader.onload = function(ev) {
            document.getElementById('examenPreviewImg').src = ev.target.result;
            document.getElementById('examenFilePreview').classList.remove('d-none');
            document.getElementById('examenDropContent').classList.add('d-none');
        }
        reader.readAsDataURL(file);
    }

    async function guardarResultadoExamen() {
        const id = document.getElementById('resultadoExamenId').value;
        const comentario = document.getElementById('resultadoExamenComentario').value;
        
        const formData = new FormData();
        formData.append('idExamen', id);
        formData.append('comentario', comentario);
        if (selectedExamenFile) {
            formData.append('file', selectedExamenFile);
        }

        const btn = document.getElementById('btnGuardarResultado');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Guardando...';

        try {
            const response = await fetch('/Examenes/SubirResultadoExamen', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.getElementById('modalResultadoExamen')).hide();
                cargarExamenes();
                alert('Resultado guardado correctamente.');
            } else alert(result.message);
        } catch (e) {
            console.error(e);
            alert('Error al guardar el resultado.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = 'Guardar Resultado';
        }
    }

    function verImagenExamen(id, nombre) {
        const modal = document.getElementById('photoModal');
        const modalImg = document.getElementById('modalImg');
        const modalCaption = document.getElementById('modalCaption');
        
        modalImg.src = `/Examenes/GetResultadoImage/${id}`;
        modalCaption.textContent = nombre;
        
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    async function eliminarExamen(id) {
        if (!confirm('¿Está seguro de eliminar este registro de examen?')) return;
        try {
            const response = await fetch(`/Examenes/EliminarExamen/${id}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) cargarExamenes();
            else alert(result.message);
        } catch (e) { console.error(e); alert('Error al eliminar.'); }
    }


    // ============ CIERRE CONSULTA LOGIC ============
    let catTratamientos = [];
    let catProductos = [];
    let itemsCierre = [];
    let modalCierreObj = null;
    const idConsultaActivaParaCierre = @(ViewBag.ConsultaActiva != null ? ((MediTech.Backend.Models.Consulta)ViewBag.ConsultaActiva).IdConsulta : 0);

    async function abrirModalCierre() {
        if (!modalCierreObj) {
            modalCierreObj = new bootstrap.Modal(document.getElementById('modalCierreConsulta'));
        }
        
        // Load catalogs if not loaded
        if (catTratamientos.length === 0) {
            try { 
                const resT = await fetch('/Consultas/GetCatTratamientos');
                catTratamientos = await resT.json(); 
                const selT = document.getElementById('selCierreTratamiento');
                catTratamientos.forEach(t => selT.add(new Option(t.nombre, t.id)));
                
                const resP = await fetch('/Consultas/GetCatProductos');
                catProductos = await resP.json(); 
                const selP = document.getElementById('selCierreProducto');
                catProductos.forEach(p => selP.add(new Option(`${p.nombre} (Stock: ${p.stock})`, p.id)));
            } catch(e) { console.error('Error loading catalogs', e); }
        }
        
        modalCierreObj.show();
    }

    function actualizarPrecioCierre(tipo) {
        if (tipo === 'TRATAMIENTO') {
            const id = parseInt(document.getElementById('selCierreTratamiento').value);
            const item = catTratamientos.find(t => t.id === id);
            document.getElementById('precioCierreTratamiento').value = item ? item.precio : '';
        } else {
            const id = parseInt(document.getElementById('selCierreProducto').value);
            const item = catProductos.find(p => p.id === id);
            document.getElementById('precioCierreProducto').value = item ? item.precio : '';
        }
    }

    function agregarItemCierre(tipo) {
        const isTrat = tipo === 'TRATAMIENTO';
        const sel = document.getElementById(isTrat ? 'selCierreTratamiento' : 'selCierreProducto');
        const inpPrecio = document.getElementById(isTrat ? 'precioCierreTratamiento' : 'precioCierreProducto');
        
        const idRef = parseInt(sel.value);
        if (!idRef) return alert('Seleccione un ítem.');
        const precio = parseFloat(inpPrecio.value);
        if (isNaN(precio) || precio < 0) return alert('Precio inválido.');
        
        // Tratamientos always have quantity 1. Products take quantity from input.
        let cant = 1;
        if (!isTrat) {
            const inpCant = document.getElementById('cantCierreProducto');
            cant = parseInt(inpCant.value);
            if (isNaN(cant) || cant <= 0) return alert('Cantidad inválida.');
        }

        let desc = sel.options[sel.selectedIndex].text;
        
        // Validate stock logic for PRODUCTO
        if (!isTrat) {
            const prod = catProductos.find(p => p.id === idRef);
            // Current quantity in cart
            const cantInCart = itemsCierre.filter(i => i.tipoItem === 'PRODUCTO' && i.idReferencia === idRef).reduce((acc, curr) => acc + curr.cantidad, 0);
            
            if (prod && (cant + cantInCart) > prod.stock) {
                return alert(`Stock insuficiente. Solo hay ${prod.stock} unidades de ${prod.nombre} (ya tiene ${cantInCart} agregadas).`);
            }
            desc = desc.split(' (Stock')[0]; // Limpiar el texto visual del select para guardar nomás el nombre
        }

        itemsCierre.push({
            id: Date.now(), // ID temporal
            tipoItem: tipo,
            idReferencia: idRef,
            descripcion: desc,
            cantidad: cant,
            precioUnitario: precio,
            subtotal: parseFloat((precio * cant).toFixed(2))
        });

        // Reset inputs
        sel.value = ''; inpPrecio.value = ''; 
        if (!isTrat) document.getElementById('cantCierreProducto').value = '1';
        
        renderItemsCierre();
    }

    function eliminarItemCierre(tempId) {
        itemsCierre = itemsCierre.filter(i => i.id !== tempId);
        renderItemsCierre();
    }

    function renderItemsCierre() {
        const tbTrat = document.getElementById('tbodyCierreTratamientos');
        const tbProd = document.getElementById('tbodyCierreProductos');
        tbTrat.innerHTML = ''; tbProd.innerHTML = '';
        
        let subTrat = 0, subProd = 0;

        itemsCierre.forEach(item => {
            if (item.tipoItem === 'TRATAMIENTO') {
                tbTrat.innerHTML += `<tr>
                    <td>${item.descripcion}</td>
                    <td class="text-end">$${item.precioUnitario.toFixed(2)}</td>
                    <td class="text-center"><button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="eliminarItemCierre(${item.id})"><i class="fas fa-trash-alt"></i></button></td>
                </tr>`;
                subTrat += item.subtotal;
            } else {
                tbProd.innerHTML += `<tr>
                    <td>${item.descripcion}</td>
                    <td class="text-center">${item.cantidad}</td>
                    <td class="text-end">$${item.precioUnitario.toFixed(2)}</td>
                    <td class="text-end fw-bold">$${item.subtotal.toFixed(2)}</td>
                    <td class="text-center"><button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="eliminarItemCierre(${item.id})"><i class="fas fa-trash-alt"></i></button></td>
                </tr>`;
                subProd += item.subtotal;
            }
        });

        document.getElementById('resCierreTrat').textContent = subTrat.toFixed(2);
        document.getElementById('resCierreProd').textContent = subProd.toFixed(2);
        document.getElementById('resCierreTotal').textContent = (subTrat + subProd).toFixed(2);
    }

    async function submitCierreConsulta() {
        if (itemsCierre.length === 0) {
            if (!confirm('No ha agregado tratamientos ni productos a la cuenta. ¿Está seguro de que desea cerrar la consulta de todos modos?')) return;
        } else {
            if (!confirm('¿Está seguro de cerrar la consulta y generar la facturación?')) return;
        }
        
        if (idConsultaActivaParaCierre <= 0) {
            return alert('Error: No se encontró la consulta activa.');
        }

        const btn = document.getElementById('btnConfirmarCierre');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Facturando...';
        btn.disabled = true;

        const payload = {
            idConsulta: idConsultaActivaParaCierre,
            diagnosticoFinal: document.getElementById('cierreDiagnostico').value,
            observaciones: document.getElementById('cierreObservaciones').value,
            items: itemsCierre.map(i => ({
                tipoItem: i.tipoItem,
                idReferencia: i.idReferencia,
                descripcion: i.descripcion,
                cantidad: i.cantidad,
                precioUnitario: i.precioUnitario,
                subtotal: i.subtotal
            }))
        };

        try {
            const response = await fetch('/Consultas/CerrarConsulta', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            
            if (result.success) {
                alert('\u00a1Consulta finalizada y cuenta generada exitosamente!');
                window.location.href = '/Citas/Index';
            } else {
                alert('Ocurrió un error: ' + result.message);
                btn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar y Facturar';
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Error de red o conexión al intentar cerrar.');
            btn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar y Facturar';
            btn.disabled = false;
        }
    }
</script>
}

