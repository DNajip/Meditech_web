    // ============ CIERRE CONSULTA LOGIC ============
    let catTratamientos = [];
    let catProductos = [];
    let itemsCierre = [];
    let modalCierreObj = null;
    const idConsultaActivaParaCierre = @(ViewBag.ConsultaActiva != null ? ((MediTech.Backend.Models.Consulta)ViewBag.ConsultaActiva).IdConsulta : 0);

    async function abrirModalCierre() {
        if (!modalCierreObj) {
            modalCierreObj = new bootstrap.Modal(document.getElementById('modalCierreConsulta'));
        }
        
        // Load catalogs and currency config if not loaded
        if (catTratamientos.length === 0) {
            try { 
                const resT = await fetch('/Consultas/GetCatTratamientos');
                catTratamientos = await resT.json(); 
                const selT = document.getElementById('selCierreTratamiento');
                catTratamientos.forEach(t => selT.add(new Option(t.nombre, t.id)));
                
                const resP = await fetch('/Consultas/GetCatProductos');
                catProductos = await resP.json(); 
                const selP = document.getElementById('selCierreProducto');
                catProductos.forEach(p => selP.add(new Option(`${p.nombre} (Stock: ${p.stock})`, p.id)));

                // Load Currency Configuration
                const resC = await fetch('/Consultas/GetMonedaConfig');
                const config = await resC.json();
                if (config.success) {
                    modalCurrencySymbol = config.simbolo;
                    modalCurrencyId = config.id;
                    // Update HTML labels with new symbol
                    document.querySelectorAll('.simbolo-moneda').forEach(el => el.textContent = modalCurrencySymbol);
                }
            } catch(e) { console.error('Error loading closure data', e); }
        }
        
        modalCierreObj.show();
    }

    function actualizarPrecioCierre(tipo) {
        if (tipo === 'TRATAMIENTO') {
            const id = parseInt(document.getElementById('selCierreTratamiento').value);
            const item = catTratamientos.find(t => t.id === id);
            document.getElementById('precioCierreTratamiento').value = item ? item.precio : '';
        } else {
            const id = parseInt(document.getElementById('selCierreProducto').value);
            const item = catProductos.find(p => p.id === id);
            document.getElementById('precioCierreProducto').value = item ? item.precio : '';
        }
    }

    function agregarItemCierre(tipo) {
        const isTrat = tipo === 'TRATAMIENTO';
        const sel = document.getElementById(isTrat ? 'selCierreTratamiento' : 'selCierreProducto');
        const inpPrecio = document.getElementById(isTrat ? 'precioCierreTratamiento' : 'precioCierreProducto');
        
        const idRef = parseInt(sel.value);
        if (!idRef) { MediToast.warning('Seleccione un ítem.'); return; }
        const precio = parseFloat(inpPrecio.value);
        if (isNaN(precio) || precio < 0) { MediToast.warning('Precio inválido.'); return; }
        
        // Tratamientos always have quantity 1. Products take quantity from input.
        let cant = 1;
        if (!isTrat) {
            const inpCant = document.getElementById('cantCierreProducto');
            cant = parseInt(inpCant.value);
            if (isNaN(cant) || cant <= 0) { MediToast.warning('Cantidad inválida.'); return; }
        }

        let desc = sel.options[sel.selectedIndex].text;
        
        // Validate stock logic for PRODUCTO
        if (!isTrat) {
            const prod = catProductos.find(p => p.id === idRef);
            // Current quantity in cart
            const cantInCart = itemsCierre.filter(i => i.tipoItem === 'PRODUCTO' && i.idReferencia === idRef).reduce((acc, curr) => acc + curr.cantidad, 0);
            
            if (prod && (cant + cantInCart) > prod.stock) {
                MediToast.warning(`Stock insuficiente. Solo hay ${prod.stock} unidades de ${prod.nombre} (ya tiene ${cantInCart} agregadas).`);
                return;
            }
            desc = desc.split(' (Stock')[0]; // Limpiar el texto visual del select para guardar nomás el nombre
        }

        itemsCierre.push({
            id: Date.now(), // ID temporal
            tipoItem: tipo,
            idReferencia: idRef,
            descripcion: desc,
            cantidad: cant,
            precioUnitario: precio,
            subtotal: parseFloat((precio * cant).toFixed(2))
        });

        // Reset inputs
        sel.value = ''; inpPrecio.value = ''; 
        if (!isTrat) document.getElementById('cantCierreProducto').value = '1';
        
        renderItemsCierre();
    }

    function eliminarItemCierre(tempId) {
        itemsCierre = itemsCierre.filter(i => i.id !== tempId);
        renderItemsCierre();
    }

    function renderItemsCierre() {
        const tbTrat = document.getElementById('tbodyCierreTratamientos');
        const tbProd = document.getElementById('tbodyCierreProductos');
        tbTrat.innerHTML = ''; tbProd.innerHTML = '';
        
        let subTrat = 0, subProd = 0;

        itemsCierre.forEach(item => {
            if (item.tipoItem === 'TRATAMIENTO') {
                tbTrat.innerHTML += `<tr>
                    <td>${item.descripcion}</td>
                    <td class="text-end">${modalCurrencySymbol}${item.precioUnitario.toFixed(2)}</td>
                    <td class="text-center"><button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="eliminarItemCierre(${item.id})"><i class="fas fa-trash-alt"></i></button></td>
                </tr>`;
                subTrat += item.subtotal;
            } else {
                tbProd.innerHTML += `<tr>
                    <td>${item.descripcion}</td>
                    <td class="text-center">${item.cantidad}</td>
                    <td class="text-end">${modalCurrencySymbol}${item.precioUnitario.toFixed(2)}</td>
                    <td class="text-end fw-bold">${modalCurrencySymbol}${item.subtotal.toFixed(2)}</td>
                    <td class="text-center"><button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="eliminarItemCierre(${item.id})"><i class="fas fa-trash-alt"></i></button></td>
                </tr>`;
                subProd += item.subtotal;
            }
        });

        document.getElementById('resCierreTrat').textContent = subTrat.toFixed(2);
        document.getElementById('resCierreProd').textContent = subProd.toFixed(2);
        document.getElementById('resCierreTotal').textContent = (subTrat + subProd).toFixed(2);
    }

    async function submitCierreConsulta() {
        MediConfirm.show({
            title: '¿Confirmar Cierre de Consulta?',
            message: 'Se generará la cuenta de cobro y se cerrará el expediente de esta visita.',
            variant: 'primary',
            confirmText: 'Sí, finalizar y facturar',
            cancelText: 'Revisar detalles',
            icon: 'bi-receipt'
        }).then(async (confirmed) => {
            if (!confirmed) return;
        

        
        if (idConsultaActivaParaCierre <= 0) {
            MediToast.error('Error: No se encontró la consulta activa. Verifique que la consulta esté en proceso.');
            return;
        }

        const btn = document.getElementById('btnConfirmarCierre');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Facturando...';
        btn.disabled = true;

        const payload = {
            idConsulta: parseInt(idConsultaActivaParaCierre),
            diagnosticoFinal: document.getElementById('cierreDiagnostico').value,
            observaciones: document.getElementById('cierreObservaciones').value,
            items: itemsCierre.map(i => ({
                tipoItem: i.tipoItem,
                idReferencia: parseInt(i.idReferencia),
                descripcion: i.descripcion,
                cantidad: parseInt(i.cantidad),
                precioUnitario: parseFloat(i.precioUnitario),
                subtotal: parseFloat((parseInt(i.cantidad) * parseFloat(i.precioUnitario)).toFixed(2))
            }))
        };

        // Debugging: verificar payload en F12 > Console
        console.log('=== CIERRE CONSULTA: Payload ===', JSON.stringify(payload, null, 2));

            try {
                const response = await fetch('/Consultas/CerrarConsulta', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    MediToast.error('Error del servidor: ' + response.status + ' ' + response.statusText);
                    btn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar y Facturar';
                    btn.disabled = false;
                    return;
                }

                const result = await response.json();
                
                if (result.success) {
                    MediToast.success('¡Consulta finalizada y cuenta generada exitosamente!');
                    setTimeout(() => {
                        window.location.href = '/Citas/Index';
                    }, 1500);
                } else {
                    MediToast.error('Ocurrió un error: ' + result.message);
                    btn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar y Facturar';
                    btn.disabled = false;
                }
            } catch (e) {
                console.error('CIERRE CONSULTA: Error de red:', e);
                MediToast.error('Error de red o conexión al intentar cerrar.');
                btn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar y Facturar';
                btn.disabled = false;
            }
        });
    }

