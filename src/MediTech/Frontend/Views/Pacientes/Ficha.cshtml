                    </tbody>
                </table>
            </div>`;
        container.innerHTML = html;
    }

    function verDetalleFactura(id) {
        const cuenta = allFinanzas.find(c => c.idCuenta === id);
        if (!cuenta) return;

        const modal = new bootstrap.Modal(document.getElementById('modalDetalleFactura'));
        const body = document.getElementById('detailFacturaBody');

        body.innerHTML = `
            <div class="mb-4 text-center">
                <div class="text-muted small text-uppercase fw-bold">Referencia de Cuenta</div>
                <h3 class="fw-bold text-primary mb-1">#${cuenta.idCuenta}</h3>
                <div class="badge bg-light text-dark border">${cuenta.fecha}</div>
            </div>
            
            <div class="p-3 bg-light rounded-3 mb-4">
                <h6 class="fw-bold text-dark small text-uppercase mb-3"><i class="fas fa-list-ul me-2"></i>Ítems Facturados</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-borderless mb-0">
                        <thead>
                            <tr class="text-muted small border-bottom">
                                <th>Descripción</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${cuenta.detalles.map(d => `
                                <tr>
                                    <td class="small pt-2">
                                        <span class="badge ${d.tipo === 'PRODUCTO' ? 'bg-info-subtle text-info' : 'bg-primary-subtle text-primary'} me-1" style="font-size:0.6rem;">${d.tipo}</span>
                                        ${d.descripcion}
                                    </td>
                                    <td class="text-center small pt-2">${d.cant}</td>
                                    <td class="text-end small pt-2 fw-bold">${cuenta.simbolo}${d.subtotal.toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                        <tfoot>
                            <tr class="border-top">
                                <td colspan="2" class="pt-3 fw-bold text-dark">TOTAL PAGADO</td>
                                <td class="pt-3 text-end fw-bold text-primary" style="font-size: 1.1rem;">${cuenta.simbolo}${cuenta.totalFinal.toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            
            <div class="alert ${cuenta.estado === 'PAGADA' ? 'alert-success' : 'alert-warning'} border-0 shadow-xs flex-grow-1 mb-0 py-3 d-flex align-items-center">
                <i class="fas ${cuenta.estado === 'PAGADA' ? 'fa-check-circle' : 'fa-exclamation-triangle'} fs-4 me-3"></i>
                <div>
                    <div class="fw-bold">Estado del Cobro: ${cuenta.estado}</div>
                    <div class="small opacity-75">Transacción procesada vía módulo de Caja.</div>
                </div>
            </div>
        `;

        modal.show();
    }
</script>
}

