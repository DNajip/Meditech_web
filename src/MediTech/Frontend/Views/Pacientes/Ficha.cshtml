                                    <div class="small text-muted mb-1">Frec. Cardíaca</div>
                                    <div class="fw-bold">@((consultaActiva?.SignosVitales?.FrecuenciaCardiaca)?.ToString() ?? "--") <small class="text-muted">LPM</small></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-light rounded-3">
                                    <div class="small text-muted mb-1">Saturación</div>
                                    <div class="fw-bold">@((consultaActiva?.SignosVitales?.SaturacionOxigeno)?.ToString() ?? "--")% <small class="text-muted">O2</small></div>
                                </div>
                            </div>
                            <div class="col-12 mt-3">
                                <div class="p-2 border rounded-3 text-center bg-white shadow-xs">
                                    <span class="small text-muted">IMC: </span>
                                    <span class="fw-bold text-primary">@((consultaActiva?.SignosVitales?.BMI)?.ToString("0.0") ?? "--.-")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7 ps-md-4">
