@model MediTech.Backend.Models.Paciente
@{
    ViewData["Title"] = "Perfil del Paciente";
    var fullName = Model.Persona != null 
        ? $"{Model.Persona.PrimerNombre} {Model.Persona.SegundoNombre} {Model.Persona.PrimerApellido} {Model.Persona.SegundoApellido}".Replace("  ", " ").Trim()
        : "Paciente";
    var initials = Model.Persona != null 
        ? ((Model.Persona.PrimerNombre?.Length > 0 ? Model.Persona.PrimerNombre[0].ToString() : "") +
           (Model.Persona.PrimerApellido?.Length > 0 ? Model.Persona.PrimerApellido[0].ToString() : "")).ToUpper()
        : "P";
    var age = Model.Persona?.FechaNacimiento != null ? (int)((DateTime.Now - Model.Persona.FechaNacimiento.Value).TotalDays / 365.25) : 0;
}

<style>
    .profile-header {
        background: #FFFFFF;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    @@media (max-width: 575.98px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
            padding: 32px 20px;
        }
    }
    .profile-avatar {
        width: 80px; height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: 700;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3);
    }
    .profile-info h3 { font-weight: 700; color: #1E293B; margin-bottom: 6px; }
    .profile-info .meta { font-size: 0.85rem; color: #64748B; line-height: 1.6; }

    .info-card {
        background: #FFFFFF;
        border-radius: 14px;
        border: 1px solid #E2E8F0;
        padding: 24px;
        margin-bottom: 20px;
    }
    .info-card h5 {
        font-weight: 700;
        color: #1E293B;
        margin-bottom: 18px;
        padding-bottom: 10px;
        border-bottom: 1px solid #F1F5F9;
    }

    .info-row {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid #F8FAFC;
    }
    @@media (max-width: 480px) {
        .info-row { flex-direction: column; gap: 2px; }
        .info-label { width: 100%; margin-bottom: 2px; }
    }
    .info-row:last-child { border-bottom: none; }
    .info-label {
        width: 160px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #64748B;
        flex-shrink: 0;
    }
    .info-value {
        flex: 1;
        font-size: 0.88rem;
        color: #1E293B;
    }
    .badge-active { background: #D1FAE5; color: #065F46; }
    .badge-inactive { background: #FEE2E2; color: #991B1B; }
</style>

<div class="page-header page-header-premium mb-4">
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-3" style="border-radius:12px;">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
    <a href="@Url.Action("Edit", new { id = Model.IdPaciente })" class="btn btn-primary-premium shadow-sm px-4">
        <i class="fas fa-edit me-1"></i> <span class="d-none d-sm-inline">Editar Perfil</span><span class="d-sm-none">Editar</span>
    </a>
</div>

<div class="profile-header">
    <div class="profile-avatar">@initials</div>
    <div class="profile-info">
        <h3>@fullName</h3>
        <div class="meta">
            <i class="fas fa-id-card me-1"></i> @(Model.Persona?.NumIdentificacion ?? "Sin identificación")
            &nbsp;&bull;&nbsp;
            <i class="fas fa-phone me-1"></i> @(Model.Persona?.Telefono ?? "Sin teléfono")
            &nbsp;&bull;&nbsp;
            <span class="@(Model.IdEstado == 1 ? "badge-active" : "badge-inactive")" style="font-size:0.72rem; padding:2px 8px; border-radius:12px;">
                @(Model.IdEstado == 1 ? "Activo" : "Inactivo")
            </span>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="info-card">
            <h5><i class="fas fa-user me-2" style="color:#3B82F6;"></i>Información Personal</h5>
            <div class="info-row"><div class="info-label">Primer Nombre</div><div class="info-value">@(Model.Persona?.PrimerNombre ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Segundo Nombre</div><div class="info-value">@(Model.Persona?.SegundoNombre ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Primer Apellido</div><div class="info-value">@(Model.Persona?.PrimerApellido ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Segundo Apellido</div><div class="info-value">@(Model.Persona?.SegundoApellido ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Sexo</div><div class="info-value">@(Model.Persona?.Genero?.DescGenero ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Fecha Nacimiento</div><div class="info-value">@(Model.Persona?.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—") @(age > 0 ? $"({age} años)" : "")</div></div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="info-card">
            <h5><i class="fas fa-address-book me-2" style="color:#10B981;"></i>Contacto y Otros</h5>
            <div class="info-row"><div class="info-label">Identificación</div><div class="info-value">@(Model.Persona?.NumIdentificacion ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Teléfono</div><div class="info-value">@(Model.Persona?.Telefono ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Dirección</div><div class="info-value">@(Model.Persona?.Direccion ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Ocupación</div><div class="info-value">@(Model.Ocupacion ?? "—")</div></div>
            <div class="info-row"><div class="info-label">Fecha Registro</div><div class="info-value">@(Model.FechaRegistro?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div></div>
        </div>
    </div>
</div>

