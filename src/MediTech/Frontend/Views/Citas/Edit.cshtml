@model MediTech.Backend.Models.Cita
@{
    ViewData["Title"] = "Editar Cita";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm me-3" style="border-radius: 8px;">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <h4 class="mb-0 fw-bold"><i class="fas fa-calendar-edit me-2 text-primary"></i>Modificar Cita</h4>
                </div>

                <form asp-action="Edit">
                    <input type="hidden" asp-for="IdCita" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size: 0.85rem; border-radius: 8px;"></div>

                    <div class="row g-3">
                        <div class="col-md-8 position-relative">
                            <label asp-for="IdPaciente" class="form-label small fw-bold text-secondary">Paciente</label>
                            
                            @{
                                var currentPacienteName = Model.Paciente?.Persona != null 
                                    ? $"{Model.Paciente.Persona.PrimerNombre} {Model.Paciente.Persona.PrimerApellido} - {Model.Paciente.Persona.NumIdentificacion}" 
                                    : "";
                            }
                            <input type="text" id="editPacienteSearch" class="form-control" placeholder="Buscar paciente..." autocomplete="off" value="@currentPacienteName" required>
                            <input type="hidden" asp-for="IdPaciente" id="editPacienteHidden" />
                            <div id="editPacienteResults" class="list-group position-absolute w-100 shadow" style="display: none; z-index: 1050; max-height: 200px; overflow-y: auto;"></div>
                            
                            <span asp-validation-for="IdPaciente" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="IdEstado" class="form-label small fw-bold text-secondary">Estado</label>
                            <select asp-for="IdEstado" class="form-select" asp-items="ViewBag.Estados"></select>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="IdTratamiento" class="form-label small fw-bold text-secondary">Tratamiento / Servicio</label>
                            <select asp-for="IdTratamiento" class="form-select" asp-items="ViewBag.Tratamientos">
                                <option value="">-- Seleccione un Tratamiento --</option>
                            </select>
                            <span asp-validation-for="IdTratamiento" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Telefono" class="form-label small fw-bold text-secondary">Teléfono de Contacto <span class="text-danger">*</span></label>
                            <input asp-for="Telefono" type="tel" class="form-control" placeholder="Ej: 8888-8888" required />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Fecha" class="form-label small fw-bold text-secondary">Fecha</label>
                            <input asp-for="Fecha" type="date" class="form-control" />
                            <span asp-validation-for="Fecha" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="HoraInicio" class="form-label small fw-bold text-secondary">Hora Inicio</label>
                            <input asp-for="HoraInicio" type="time" class="form-control" />
                            <span asp-validation-for="HoraInicio" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="HoraFin" class="form-label small fw-bold text-secondary">Hora Fin</label>
                            <input asp-for="HoraFin" type="time" class="form-control" />
                            <span asp-validation-for="HoraFin" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Observaciones" class="form-label small fw-bold text-secondary">Observaciones</label>
                            <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Observaciones" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                        <div>
                        </div>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius: 8px;">
                            <i class="fas fa-save me-1"></i> Actualizar Cambios
                        </button>
                    </div>
                </form>
                
                <hr class="my-4">
                
                <div class="d-flex justify-content-between align-items-center bg-light p-3 border-start border-danger border-4" style="border-radius: 4px;">
                    <div>
                        <h6 class="mb-1 fw-bold text-danger">Zona de Peligro</h6>
                        <p class="mb-0 small text-muted">Eliminar esta cita permanentemente de la agenda.</p>
                    </div>
                    <form asp-action="Delete" method="post" id="deleteForm">
                        <input type="hidden" name="id" value="@Model.IdCita" />
                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmarEliminacionEdit()">
                            <i class="fas fa-trash me-1"></i> Eliminar Cita
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const eSearch = document.getElementById('editPacienteSearch');
            const eHidden = document.getElementById('editPacienteHidden');
            const eResults = document.getElementById('editPacienteResults');
            let searchTimeout;

            eSearch?.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                eHidden.value = ''; // clear hidden value if they type
                const term = this.value.trim();

                if (term.length < 2) {
                    eResults.style.display = 'none';
                    return;
                }

                searchTimeout = setTimeout(() => {
                    fetch(`/Citas/BuscarPacientes?term=${encodeURIComponent(term)}`)
                        .then(r => r.json())
                        .then(data => {
                            let html = '';
                            if (data.length > 0) {
                                data.forEach(p => {
                                    html += `
                                        <a href="javascript:void(0)" class="list-group-item list-group-item-action py-2" data-id="${p.id}" data-name="${p.label}">
                                            <i class="fas fa-user-circle me-2 text-secondary"></i> ${p.label}
                                        </a>
                                    `;
                                });
                            } else {
                                html = '<div class="list-group-item text-muted"><i class="fas fa-search"></i> No se encontraron resultados</div>';
                            }
                            eResults.innerHTML = html;
                            eResults.style.display = 'block';

                            // Attach click events
                            eResults.querySelectorAll('a').forEach(item => {
                                item.addEventListener('click', function() {
                                    eHidden.value = this.dataset.id;
                                    eSearch.value = this.dataset.name;
                                    eResults.style.display = 'none';
                                });
                            });
                        });
                }, 300);
            });

            document.addEventListener('click', function(e) {
                if (eResults && !eResults.contains(e.target) && e.target !== eSearch) {
                    eResults.style.display = 'none';
                }
            });
        });

        function confirmarEliminacionEdit() {
            MediConfirm.show({
                title: '¿Eliminar cita?',
                message: 'Esta acción eliminará la cita permanentemente de la agenda.',
                variant: 'danger',
                confirmText: 'Sí, eliminar cita',
                cancelText: 'Volver'
            }).then(confirmed => {
                if (confirmed) {
                    document.getElementById('deleteForm')?.submit();
                }
            });
        }
    </script>
}

