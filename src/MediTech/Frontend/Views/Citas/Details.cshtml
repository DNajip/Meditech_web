@model MediTech.Backend.Models.Cita
@{
    ViewData["Title"] = "Detalle de Cita";
}

<style>
    .detail-card {
        background: #FFFFFF;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }
    .detail-header {
        background: #F8FAFC;
        padding: 24px;
        border-bottom: 1px solid #E2E8F0;
    }
    .detail-body { padding: 32px; }
    .info-label { font-size: 0.75rem; color: #64748B; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .info-value { font-size: 1.05rem; color: #1E293B; font-weight: 500; margin-bottom: 20px; }
    .sync-panel {
        background: #F0FDF4;
        border: 1px solid #DCFCE7;
        padding: 16px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
</style>

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm me-3" style="border-radius: 8px;">
                    <i class="fas fa-arrow-left"></i> Volver a la Agenda
                </a>
                <h4 class="mb-0 fw-bold">Consulta Médica</h4>
            </div>
            <div class="d-flex gap-2">
                @if (Model.IdEstado == 1)
                {
                    <form asp-action="Cancel" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.IdCita" />
                        <button type="button" class="btn btn-outline-danger" style="border-radius: 8px;" onclick="confirmarCancelacionDetails()">
                            <i class="fas fa-times-circle me-1"></i> Cancelar Cita
                        </button>
                    </form>
                    <form asp-action="MarcarAtendida" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.IdCita" />
                        <button type="submit" class="btn btn-success" style="border-radius: 8px;">
                            <i class="fas fa-check-circle me-1"></i> Confirmar Llegada
                        </button>
                    </form>
                }
                <a href="@Url.Action("Edit", new { id = Model.IdCita })" class="btn btn-primary" style="border-radius: 8px;">
                    <i class="fas fa-edit me-1"></i> Editar Cita
                </a>
            </div>
        </div>

        <div class="detail-card">
            <div class="detail-header d-flex justify-content-between align-items-start">
                <div>
                   <h2 class="mb-1 fw-bold text-primary">@Model.Paciente?.Persona?.PrimerNombre @Model.Paciente?.Persona?.PrimerApellido</h2>
                   <p class="text-muted mb-0"><i class="fas fa-id-card me-1"></i> Identificación: @Model.Paciente?.Persona?.NumIdentificacion</p>
                </div>
                <span class="badge @(Model.IdEstado == 1 ? "bg-primary-subtle text-primary" : "bg-success-subtle text-success")" style="font-size: 0.8rem; padding: 6px 16px; border-radius: 20px;">
                    @(Model.Estado?.DescEstado ?? "Estado Desconocido")
                </span>
            </div>

            <div class="detail-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-label">Tratamiento Agendado</div>
                        <div class="info-value">
                            <i class="fas fa-stethoscope me-2 text-info"></i>
                            @(Model.Tratamiento?.NombreTratamiento ?? "Consulta General")
                        </div>

                        <div class="info-label">Fecha de la Cita</div>
                        <div class="info-value">
                            <i class="fas fa-calendar-day me-2 text-warning"></i>
                            @Model.Fecha.ToString("dddd, dd 'de' MMMM 'de' yyyy")
                        </div>

                        <div class="info-label">Horario Reservado</div>
                        <div class="info-value">
                            <i class="fas fa-clock me-2 text-primary"></i>
                            @DateTime.Today.Add(Model.HoraInicio).ToString("HH:mm") — @DateTime.Today.Add(Model.HoraFin).ToString("HH:mm")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-label">Teléfono de Contacto</div>
                        <div class="info-value">
                            <i class="fas fa-phone me-2 text-success"></i>
                            @(Model.Telefono ?? Model.Paciente?.Persona?.Telefono ?? "—")
                        </div>

                        <div class="info-label">Observaciones Adicionales</div>
                        <div class="info-value" style="font-size: 0.95rem; color: #475569; line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.Observaciones) ? "El médico no ha agregado notas adicionales." : Model.Observaciones)
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-4 border-top">

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarCancelacionDetails() {
            MediConfirm.show({
                title: '¿Desea cancelar esta cita?',
                message: 'Esta acción no se puede deshacer y la cita se marcará como cancelada.',
                variant: 'danger',
                confirmText: 'Sí, cancelar cita',
                cancelText: 'Volver'
            }).then(confirmed => {
                if (confirmed) {
                    const form = document.querySelector('form[asp-action="Cancel"]');
                    if (form) form.submit();
                }
            });
        }
    </script>
}

