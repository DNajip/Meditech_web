@model MediTech.Backend.Models.ConfiguracionMoneda
@{
    ViewData["Title"] = "Configuración del Sistema";
    var tasaActiva = ViewBag.TasaActiva as MediTech.Backend.Models.TasaCambio;
    var historial = ViewBag.Historial as List<MediTech.Backend.Models.TasaCambio>;
    var monedas = ViewBag.Monedas as List<MediTech.Backend.Models.Moneda>;
    var usuarios = ViewBag.Usuarios as List<MediTech.Backend.Models.Usuario>;
    var todosModulos = ViewBag.TodosModulos as List<MediTech.Backend.Models.Modulo>;
    var roles = ViewBag.Roles as List<MediTech.Backend.Models.Role>;
    var generos = ViewBag.Generos as List<MediTech.Backend.Models.Genero>;
    var tiposIdentificacion = ViewBag.TiposIdentificacion as List<MediTech.Backend.Models.TipoIdentificacion>;
}
@inject MediTech.Backend.Models.MediTechContext _context
@{
    // Resilient seeding directly in View (since backend restart is restricted)
    if (!_context.Roles.Any(r => r.DescRol == "CAJERO"))
    {
        _context.Roles.Add(new MediTech.Backend.Models.Role { DescRol = "CAJERO", IdEstado = 1 });
        _context.SaveChanges();
        // Refresh local roles list for this execution
        roles = _context.Roles.ToList();
    }
}


<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold"><i class="fas fa-cog me-2 text-primary"></i>Configuración de Sistema</h2>
        <p class="text-muted">Gestión de moneda, usuarios y permisos del sistema.</p>
    </div>
</div>

<div class="accordion border-0 shadow-sm" id="configAccordion">
    
    <!-- SECCIÓN 1: ADMINISTRACIÓN DE MONEDA Y TASA -->
    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
        <h2 class="accordion-header" id="headingMoneda">
            <button class="accordion-button bg-white text-dark fw-bold py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMoneda" aria-expanded="true" aria-controls="collapseMoneda">
                <div class="d-flex align-items-center w-100">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-2 me-3 text-primary">
                        <i class="fas fa-coins"></i>
                    </div>
                    <span>Administración de moneda y tasa</span>
                </div>
            </button>
        </h2>
        <div id="collapseMoneda" class="accordion-collapse collapse show" aria-labelledby="headingMoneda" data-bs-parent="#configAccordion">
            <div class="accordion-body bg-white pt-0">
                <div class="row">
                    <!-- Moneda Base -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3 text-secondary">MONEDA BASE</h6>
                                <form asp-action="CambiarMonedaBase" method="post">
                                    <div class="mb-3">
                                        <select name="idMonedaBase" class="form-select border-0 shadow-sm" onchange="showWarning()">
                                            @foreach (var m in monedas!)
                                            {
                                                <option value="@m.IdMoneda" selected="@(Model?.IdMonedaBase == m.IdMoneda)">
                                                    @m.Nombre (@m.Codigo - @m.Simbolo)
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div id="baseWarning" class="alert alert-warning small py-2 d-none">
                                        <i class="fas fa-exclamation-triangle me-2"></i> Solo afecta nuevos registros.
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm w-100">Actualizar Moneda</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Tasa Actual -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3 text-secondary">TASA DE CAMBIO</h6>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h3 class="mb-0 fw-bold text-success">@(tasaActiva?.Valor.ToString("N6") ?? "N/A")</h3>
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill">Activa</span>
                                </div>
                                <form asp-action="GuardarTasa" method="post">
                                    <div class="input-group input-group-sm mb-2">
                                        <span class="input-group-text bg-white border-0 shadow-sm">1 USD = </span>
                                        <input type="number" step="0.000001" name="valor" class="form-control border-0 shadow-sm" required value="@tasaActiva?.Valor.ToString("F6").Replace(",",".")">
                                        <button class="btn btn-success" type="submit">Actualizar</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Historial -->
                    <div class="col-12">
                        <div class="card border-0 bg-light">
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0 align-middle">
                                        <thead class="bg-dark bg-opacity-10">
                                            <tr class="x-small fw-bold">
                                                <th class="ps-3 py-2">FECHA</th>
                                                <th class="py-2">VALOR (USD → NIO)</th>
                                                <th class="py-2 text-center">ESTADO</th>
                                                <th class="py-2 pe-3">USUARIO</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var t in historial!)
                                            {
                                                <tr class="small transition-all">
                                                    <td class="ps-3 py-2">@t.Fecha.ToString("g")</td>
                                                    <td><span class="fw-bold text-primary">@t.Valor.ToString("N6")</span></td>
                                                    <td class="text-center">
                                                        <span class="badge @(t.Activo ? "bg-success" : "bg-secondary opacity-50") rounded-pill" style="font-size: 0.65rem;">
                                                            @(t.Activo ? "ACTIVO" : "ANTERIOR")
                                                        </span>
                                                    </td>
                                                    <td class="pe-3 text-muted">@t.UsuarioModificacion</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SECCIÓN 2: ADMINISTRACIÓN DE USUARIOS -->
    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
        <h2 class="accordion-header" id="headingUsuarios">
            <button class="accordion-button bg-white text-dark fw-bold py-3 collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsuarios" aria-expanded="false" aria-controls="collapseUsuarios">
                <div class="d-flex align-items-center w-100">
                    <div class="bg-info bg-opacity-10 p-2 rounded-2 me-3 text-info">
                        <i class="fas fa-users"></i>
                    </div>
                    <span>Administración de usuarios</span>
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill ms-2 fw-normal" style="font-size: 0.7rem;">@usuarios?.Count usuarios</span>
                </div>
            </button>
        </h2>
        <div id="collapseUsuarios" class="accordion-collapse collapse" aria-labelledby="headingUsuarios" data-bs-parent="#configAccordion">
            <div class="accordion-body bg-white pt-2">
                <div class="user-list-container">
                    <div class="table-responsive">
                    <table class="table table-hover align-middle border-0">
                        <thead class="bg-light">
                            <tr class="text-secondary small fw-bold">
                                <th class="border-0">USUARIO</th>
                                <th class="border-0">ROL</th>
                                <th class="border-0">ESTADO</th>
                                <th class="border-0">MÓDULOS ACTIVOS</th>
                                <th class="text-end pe-3 border-0">
                                    <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#modalNuevoUsuario">
                                        <i class="fas fa-plus me-1"></i> Nuevo Usuario
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in usuarios!)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle me-2 d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                @(u.Username.Substring(0,1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-bold small">@u.Username</div>
                                                <div class="x-small text-muted">@(u.Empleado?.Persona?.PrimerNombre ?? "N/A")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-soft-primary text-primary px-2 py-1 rounded-pill" style="font-size: 0.7rem;">
                                            @u.Role?.DescRol
                                        </span>
                                    </td>
                                    <td>
                                        @if (u.IdEstado == 1)
                                        {
                                            <span class="badge bg-soft-success text-success px-2 py-1 rounded-pill" style="font-size: 0.65rem;">ACTIVO</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-soft-secondary text-secondary px-2 py-1 rounded-pill" style="font-size: 0.65rem;">INACTIVO</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (u.UsuarioModulos != null && u.UsuarioModulos.Any())
                                            {
                                                foreach (var um in u.UsuarioModulos.OrderBy(x => x.Modulo?.Orden))
                                                {
                                                    <span class="badge bg-light text-dark border border-secondary border-opacity-10 fw-normal" style="font-size: 0.65rem;">
                                                        <i class="@um.Modulo?.Icono me-1"></i> @um.Modulo?.Nombre
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small italic">Sin módulos asignados</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3 me-1" onclick="openEditUsuarioModal(@u.IdUsuario)" style="font-size: 0.75rem;">
                                                <i class="fas fa-edit me-1"></i> Editar
                                            </button>
                                            <button type="button" class="btn btn-outline-info btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#modalPermisos-@u.IdUsuario" style="font-size: 0.75rem;">
                                                <i class="fas fa-key me-1"></i> Permisos
                                            </button>
                                        </div>

                                        <!-- MODAL DE PERMISOS -->
                                        <div class="modal fade" id="modalPermisos-@u.IdUsuario" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-0 shadow-lg shadow-sm">
                                                    <div class="modal-header border-0 bg-light">
                                                        <h5 class="modal-title fw-bold">Permisos de Módulos</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <form onsubmit="savePermisos(event, this)">
                                                        <div class="modal-body text-start">
                                                            <input type="hidden" name="idUsuario" value="@u.IdUsuario" />
                                                            <p class="mb-3 text-muted small">Seleccione los módulos a los que el usuario <strong>@u.Username</strong> tendrá acceso:</p>
                                                            
                                                            <div class="row g-2">
                                                                @foreach (var mod in todosModulos!)
                                                                {
                                                                    var check = u.UsuarioModulos?.Any(um => um.IdModulo == mod.IdModulo) ?? false;
                                                                    <div class="col-6">
                                                                        <div class="form-check p-2 border rounded-3 bg-light transition-all hover-shadow-sm d-flex align-items-center">
                                                                            <input class="form-check-input ms-3 me-3" type="checkbox" name="modulosSeleccionados" value="@mod.IdModulo" id="mod-@u.IdUsuario-@mod.IdModulo" @(check ? "checked" : "")>
                                                                            <label class="form-check-label d-flex align-items-center gap-2 mb-0 cursor-pointer w-100" for="mod-@u.IdUsuario-@mod.IdModulo">
                                                                                <i class="@mod.Icono text-primary opacity-75"></i>
                                                                                <span class="small fw-medium">@mod.Nombre</span>
                                                                            </label>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer border-0 pt-0">
                                                            <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancelar</button>
                                                            <button type="submit" class="btn btn-info btn-sm text-white px-4">Guardar Cambios</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL NUEVO USUARIO -->
<div class="modal fade" id="modalNuevoUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold text-primary">Registrar Nuevo Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formNuevoUsuario">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Nombre</label>
                            <input type="text" name="nombre" class="form-control form-control-sm" required placeholder="Ej: Juan" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Apellido</label>
                            <input type="text" name="apellido" class="form-control form-control-sm" required placeholder="Ej: Perez" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Tipo Identificación</label>
                            <select name="idTipoIdentificacion" class="form-select form-select-sm" required>
                                <option value="" disabled selected>Seleccione...</option>
                                @if (tiposIdentificacion != null) {
                                    foreach (var t in tiposIdentificacion) {
                                        <option value="@t.IdTipoIdentificacion">@t.DescTipo</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">N° Identificación</label>
                            <input type="text" name="numIdentificacion" class="form-control form-control-sm" required placeholder="000-000000-0000" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Género</label>
                            <select name="idGenero" class="form-select form-select-sm" required>
                                <option value="" disabled selected>Seleccione...</option>
                                @if (generos != null) {
                                    foreach (var g in generos) {
                                        <option value="@g.IdGenero">@g.DescGenero</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Fecha Nacimiento</label>
                            <input type="date" name="fechaNacimiento" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Teléfono</label>
                            <input type="tel" name="telefono" class="form-control form-control-sm" required placeholder="88888888" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Rol en el Sistema</label>
                            <select name="idRol" class="form-select form-select-sm" required>
                                <option value="" disabled selected>Seleccione...</option>
                                @if (roles != null) {
                                    foreach (var r in roles) {
                                        <option value="@r.IdRol">@r.DescRol</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-12 mt-3 p-3 bg-light rounded-3 border border-dashed text-center">
                            <i class="fas fa-user-shield text-muted mb-2"></i>
                            <div class="small fw-bold text-secondary">Credenciales de Acceso</div>
                        </div>
                        <div class="col-12 text-start">
                            <label class="form-label small fw-bold">Nombre de Usuario</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-at text-muted"></i></span>
                                <input type="text" name="username" class="form-control border-start-0" required placeholder="Ej: jperez" />
                            </div>
                        </div>
                        <div class="col-12 text-start">
                            <label class="form-label small fw-bold">Contraseña Inicial</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" name="password" class="form-control border-start-0" required placeholder="********" />
                            </div>
                            <div class="x-small text-muted mt-1">El usuario podrá cambiarla después de su primer ingreso.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">Crear Usuario</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL EDITAR USUARIO -->
<div class="modal fade" id="modalEditUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold text-primary">Editar Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formEditUsuario">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idUsuario" id="editIdUsuario" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Nombre</label>
                            <input type="text" name="nombre" id="editNombre" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Apellido</label>
                            <input type="text" name="apellido" id="editApellido" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Rol en el Sistema</label>
                            <select name="idRol" id="editIdRol" class="form-select form-select-sm" required>
                                @if (roles != null) {
                                    foreach (var r in roles) {
                                        <option value="@r.IdRol">@r.DescRol</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Estado de Cuenta</label>
                            <select name="idEstado" id="editIdEstado" class="form-select form-select-sm" required>
                                <option value="1">Activo</option>
                                <option value="2">Inactivo / Baja</option>
                            </select>
                        </div>
                        <div class="col-12 mt-3 p-2 bg-light rounded-3 border border-dashed text-center">
                            <div class="small fw-bold text-secondary">Cambiar Contraseña (Opcional)</div>
                        </div>
                        <div class="col-12 text-start">
                            <label class="form-label small fw-bold">Nueva Contraseña</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" name="password" class="form-control border-start-0" placeholder="Dejar en blanco para no cambiar" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">Actualizar Usuario</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1) !important; }
    .bg-soft-secondary { background-color: rgba(108, 117, 125, 0.1) !important; }
    .x-small { font-size: 0.75rem; }
    .bg-light { background-color: #F8FAFC !important; }
    .bg-soft-primary { background-color: #EFF6FF !important; }
    
    .accordion-button:not(.collapsed) {
        background-color: white !important;
        box-shadow: none !important;
        color: var(--primary-blue) !important;
    }
    
    .accordion-button:focus {
        box-shadow: none !important;
        border-color: rgba(0,0,0,.125);
    }

    .accordion-button::after {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%2364748B'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e") !important;
        background-size: 1.25rem !important;
        transition: transform 0.2s ease-in-out !important;
    }

    .transition-all { transition: all 0.2s ease; }
    .hover-shadow-sm:hover { box-shadow: 0 .125rem .25rem rgba(0,0,0,.075) !important; background-color: #f1f5f9 !important; }
    .cursor-pointer { cursor: pointer; }
    
    .form-check-input:checked {
        background-color: var(--primary-blue);
        border-color: var(--primary-blue);
    }
    /* Scrollbar Premium */
    .user-list-container {
        max-height: 450px;
        overflow-y: auto;
        padding-right: 5px;
    }
    .user-list-container::-webkit-scrollbar {
        width: 6px;
    }
    .user-list-container::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 10px;
    }
    .user-list-container::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }
    .user-list-container::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }
</style>

@section Scripts {
    <script>
        function showWarning() {
            $('#baseWarning').removeClass('d-none');
        }

        const editUsuarioModal = new bootstrap.Modal(document.getElementById('modalEditUsuario'));

        window.openEditUsuarioModal = function(id) {
            $.get(`/Configuracion/GetUsuario?id=${id}`, function(data) {
                $('#editIdUsuario').val(data.idUsuario);
                $('#editNombre').val(data.nombre);
                $('#editApellido').val(data.apellido);
                $('#editIdRol').val(data.idRol);
                $('#editIdEstado').val(data.idEstado);
                editUsuarioModal.show();
            });
        };

        $('#formNuevoUsuario').on('submit', function(e) {
            e.preventDefault();
            const btn = $(this).find('button[type="submit"]');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Guardando...');

            $.post('@Url.Action("RegistrarUsuario", "Configuracion")', $(this).serialize(), function(response) {
                if (response.success || response.indexOf("exitosamente") !== -1) {
                    if (typeof MediToast !== 'undefined') MediToast.success("Usuario registrado exitosamente");
                    setTimeout(() => location.reload(), 1500);
                } else {
                    if (typeof MediToast !== 'undefined') MediToast.error("Error al registrar usuario");
                    btn.prop('disabled', false).text('Crear Usuario');
                }
            }).fail(function() {
                if (typeof MediToast !== 'undefined') MediToast.error("Error de comunicación");
                btn.prop('disabled', false).text('Crear Usuario');
            });
        });

        $('#formEditUsuario').on('submit', function(e) {
            e.preventDefault();
            const btn = $(this).find('button[type="submit"]');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Guardando...');

            $.post('@Url.Action("ActualizarUsuario", "Configuracion")', $(this).serialize(), function(response) {
                if (response.success) {
                    if (typeof MediToast !== 'undefined') MediToast.success(response.message);
                    editUsuarioModal.hide();
                    setTimeout(() => location.reload(), 1500);
                } else {
                    if (typeof MediToast !== 'undefined') MediToast.error(response.message || "Error al actualizar");
                    btn.prop('disabled', false).text('Actualizar Usuario');
                }
            });
        });

        window.savePermisos = function(e, form) {
            e.preventDefault();
            const $form = $(form);
            const btn = $form.find('button[type="submit"]');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Guardando...');

            $.post('@Url.Action("GuardarPermisosUsuario", "Configuracion")', $form.serialize(), function(data) {
                if (typeof MediToast !== 'undefined') MediToast.success("Permisos actualizados correctamente");
                setTimeout(() => location.reload(), 1000);
            }).fail(function() {
                if (typeof MediToast !== 'undefined') MediToast.error("Error al actualizar permisos");
                btn.prop('disabled', false).text('Guardar Cambios');
            });
        };

        // Auto-hide alerts
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}

