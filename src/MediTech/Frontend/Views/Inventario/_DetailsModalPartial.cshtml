@model MediTech.Backend.Models.Producto

<div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
        <div class="modal-header bg-transparent border-0 pt-4 px-4 d-flex align-items-center">
            <div class="icon-shape bg-soft-primary rounded-circle me-3 p-3">
                <i class="fas fa-boxes text-primary fs-4"></i>
            </div>
            <div>
                <h4 class="modal-title fw-bold text-dark mb-0">Detalles de Producto</h4>
                <p class="text-muted small mb-0">Ficha técnica e historial del producto</p>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4 pt-2">
            <div class="row g-4">
                <!-- Sidebar Info -->
                <div class="col-lg-4">
                    <div class="card card-premium border-0 shadow-sm mb-4">
                        <div class="card-body p-4 text-center">
                            <div class="icon-shape bg-soft-primary rounded-circle mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                                <i class="fas fa-box text-primary"></i>
                            </div>
                            <h3 class="fw-bold mb-1">@Model.Nombre</h3>
                            <p class="text-muted">@Model.Descripcion</p>
                            <hr>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Precio:</span>
                                <span class="fw-bold fs-5">@((ViewBag.MonedaBase as MediTech.Backend.Models.Moneda)?.Simbolo ?? "$") @Model.Precio?.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Stock Actual:</span>
                                <span class="fw-bold badge @(Model.Stock <= Model.StockMinimo ? "bg-warning" : "bg-success") p-2 px-3">@Model.Stock</span>
                            </div>
                        </div>
                    </div>

                    <div class="card card-premium border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="fw-bold text-uppercase small ls-1 mb-3">Acciones Rápidas</h6>
                            <div class="d-grid gap-2">
                                <button type="button" onclick="$('#detailsModalContainer').modal('hide'); openAjusteModal(@Model.IdProducto)" class="btn btn-info text-white">
                                    <i class="fas fa-exchange-alt me-2"></i>Ajustar Stock
                                </button>
                                <button type="button" onclick="$('#detailsModalContainer').modal('hide'); openEditModal(@Model.IdProducto)" class="btn btn-outline-primary">
                                    <i class="fas fa-edit me-2"></i>Editar Datos
                                </button>
                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Volver a la Lista</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- History Content -->
                <div class="col-lg-8">
                    <div class="card card-premium border-0 shadow-sm h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">Historial de Movimientos</h5>
                            <span class="badge bg-light text-dark">@ViewBag.TotalCount registros totales</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="ps-4">Fecha</th>
                                            <th>Tipo</th>
                                            <th>Cantidad</th>
                                            <th>Observación</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!Model.Movimientos.Any())
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-5">
                                                    <i class="fas fa-history text-muted fs-1 d-block mb-3"></i>
                                                    <span class="text-muted italic">No hay movimientos registrados para este producto.</span>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            foreach (var mov in Model.Movimientos)
                                            {
                                                var typeClass = mov.TipoMovimiento == "INGRESO" || mov.TipoMovimiento == "COMPRA" || mov.TipoMovimiento == "AJUSTE_POS" ? "text-success" : "text-danger";
                                                var icon = mov.TipoMovimiento == "INGRESO" || mov.TipoMovimiento == "COMPRA" || mov.TipoMovimiento == "AJUSTE_POS" ? "fa-arrow-up" : "fa-arrow-down";

                                                <tr>
                                                    <td class="ps-4">
                                                        <div class="small fw-bold">@mov.FechaMovimiento.ToString("dd/MM/yyyy")</div>
                                                        <div class="text-muted" style="font-size: 0.75rem;">@mov.FechaMovimiento.ToString("HH:mm")</div>
                                                    </td>
                                                    <td>
                                                        <span class="fw-bold @typeClass small">
                                                            <i class="fas @icon me-1"></i> @mov.TipoMovimiento
                                                        </span>
                                                    </td>
                                                    <td class="fw-bold">@mov.Cantidad</td>
                                                    <td class="text-muted small">@mov.Observacion</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                        <!-- Paginación con Bootstrap y AJAX -->
                        @if (ViewBag.TotalPages > 1)
                        {
                            <div class="card-footer bg-white border-0 py-3">
                                <nav aria-label="Page navigation">
                                    <ul class="pagination pagination-sm justify-content-center mb-0">
                                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                            <button class="page-link shadow-none border-0 bg-light rounded-start" onclick="openDetailsModal(@Model.IdProducto, @(ViewBag.CurrentPage - 1))">
                                                <i class="fas fa-chevron-left small"></i>
                                            </button>
                                        </li>
                                        
                                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                        {
                                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                                <button class="page-link shadow-none border-0 @(ViewBag.CurrentPage == i ? "bg-primary text-white" : "bg-light text-dark mx-1") @(ViewBag.CurrentPage == i ? "" : "rounded")" onclick="openDetailsModal(@Model.IdProducto, @i)">@i</button>
                                            </li>
                                        }

                                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                            <button class="page-link shadow-none border-0 bg-light rounded-end" onclick="openDetailsModal(@Model.IdProducto, @(ViewBag.CurrentPage + 1))">
                                                <i class="fas fa-chevron-right small"></i>
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
