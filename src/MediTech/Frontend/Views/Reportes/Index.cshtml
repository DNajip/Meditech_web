@using MediTech.Backend.Dtos
@{
    ViewData["Title"] = "Dashboard de Control";
    var caja = ViewBag.Caja as CajaAuditoriaDto;
    var operativo = ViewBag.Operativo as OperativoCoreDto;
    var inventario = ViewBag.Inventario as InventarioControlDto;
}

<div class="container-fluid py-4" style="background-color: #F8FAFC; min-height: 100vh;">
    <!-- Header Premium -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Centro de Control MediTech</h1>
            <p class="text-muted small mb-0"><i class="fas fa-chart-line me-1"></i> Inteligencia operativa y financiera en tiempo real</p>
        </div>
        
        <div class="d-flex flex-wrap gap-2 align-items-center bg-white p-2 rounded-3 shadow-sm border">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-light text-dark border-0 btn-sm px-3 fw-medium" onclick="setQuickRange('today')">Hoy</button>
                <button type="button" class="btn btn-outline-light text-dark border-0 btn-sm px-3 fw-medium" onclick="setQuickRange('week')">Semana</button>
                <button type="button" class="btn btn-outline-light text-dark border-0 btn-sm px-3 fw-medium" onclick="setQuickRange('month')">Mes</button>
                <button type="button" class="btn btn-outline-light text-dark border-0 btn-sm px-3 fw-medium" onclick="setQuickRange('year')">Año</button>
            </div>
            <div class="vr mx-2 text-light"></div>
            <div class="d-flex gap-2">
                <input type="date" id="reportInicio" class="form-control form-control-sm border-0 bg-light" value="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")" style="width: 130px;">
                <input type="date" id="reportFin" class="form-control form-control-sm border-0 bg-light" value="@DateTime.Today.ToString("yyyy-MM-dd")" style="width: 130px;">
                <button class="btn btn-primary btn-sm px-3 rounded-2" onclick="refreshDashboard()">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Nav Tabs Pillars -->
    <ul class="nav nav-pills nav-fill bg-white p-1 rounded-3 shadow-sm mb-4 border" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active py-2 fw-bold d-flex align-items-center justify-content-center gap-2" id="pills-financial-tab" data-bs-toggle="pill" data-bs-target="#pills-financial" type="button" role="tab">
                <i class="fas fa-wallet"></i> 1. Financiero
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link py-2 fw-bold d-flex align-items-center justify-content-center gap-2" id="pills-ops-tab" data-bs-toggle="pill" data-bs-target="#pills-ops" type="button" role="tab">
                <i class="fas fa-user-md"></i> 2. Operativo
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link py-2 fw-bold d-flex align-items-center justify-content-center gap-2" id="pills-inv-tab" data-bs-toggle="pill" data-bs-target="#pills-inv" type="button" role="tab">
                <i class="fas fa-boxes"></i> 3. Inventario
            </button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">
        <!-- PILLAR 1: FINANCIERO -->
        <div class="tab-pane fade show active" id="pills-financial" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-body p-4 bg-primary text-white">
                            <h6 class="text-white-50 text-uppercase small fw-bold mb-3">Total Ingresos (Base)</h6>
                            <h2 class="display-5 fw-bold mb-0" id="finTotalIngresos">@caja?.TotalIngresosBase.ToString("C2")</h2>
                            <p class="small mb-0 mt-2 text-white-50"><span id="finTotalTrans">@caja?.TotalTransacciones</span> transacciones procesadas</p>
                        </div>
                        <div class="card-footer bg-white border-0 p-4">
                            <button class="btn btn-outline-primary w-100 fw-bold py-2 rounded-3" onclick="exportData('ingresos')">
                                <i class="fas fa-file-excel me-2"></i>Exportar Auditoría Caja
                            </button>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white border-0 pt-4 px-4">
                            <h6 class="fw-bold mb-0 text-dark">Diferencias de Turno</h6>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3 mb-3 p-3 rounded-3 bg-light">
                                <div class="icon-circle bg-danger text-white rounded-pill d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </div>
                                <div>
                                    <p class="text-muted small mb-0">Desfase Total</p>
                                    <h5 class="fw-bold mb-0 text-danger" id="finTotalDif">@caja?.TotalDiferencias.ToString("C2")</h5>
                                </div>
                            </div>
                            <button class="btn btn-outline-danger w-100 btn-sm rounded-pill fw-bold" onclick="openCierreModal()">
                                <i class="fas fa-file-pdf me-2"></i>Generar PDF de Cierre
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">Desglose por Método de Pago</h6>
                            <i class="fas fa-piggy-bank text-muted"></i>
                        </div>
                        <div class="card-body p-4">
                            <div class="row h-100 align-items-center">
                                <div class="col-md-6">
                                    <div style="height: 250px;">
                                        <canvas id="chartMetodos"></canvas>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex flex-column gap-3" id="listMetodos">
                                        @foreach (var m in caja?.DesglosePorMetodo ?? new())
                                        {
                                            <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge rounded-circle p-1 bg-primary"></span>
                                                    <span class="fw-medium">@m.Metodo</span>
                                                </div>
                                                <div class="text-end">
                                                    <div class="fw-bold">@m.Total.ToString("C2")</div>
                                                    <div class="text-muted x-small">@m.Cantidad ops (@m.Porcentaje.ToString("N1")%)</div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PILLAR 2: OPERATIVO -->
        <div class="tab-pane fade" id="pills-ops" role="tabpanel">
            <div class="row g-4">
                <!-- Stats Row -->
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                        <h6 class="text-muted small fw-bold text-uppercase mb-2">Citas Totales</h6>
                        <h2 class="fw-bold text-dark mb-0" id="opsTotalCitas">@operativo?.TotalCitas</h2>
                        <div class="mt-3 badge bg-soft-primary text-primary px-3 py-2 rounded-pill">Eficiencia Agenda</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                        <h6 class="text-muted small fw-bold text-uppercase mb-2">Atendidas</h6>
                        <h2 class="fw-bold text-success mb-0" id="opsAtendidas">@operativo?.CitasAtendidas</h2>
                        <div class="mt-3 text-muted x-small fw-medium">Ingresos Confirmados</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                        <h6 class="text-muted small fw-bold text-uppercase mb-2">Tasa No-Show</h6>
                        <h2 class="fw-bold text-danger mb-0" id="opsNoShow">@operativo?.TasaNoShow.ToString("N1")%</h2>
                        <div class="mt-3 text-muted x-small fw-medium">Citas Caceladas/Perdidas</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                        <h6 class="text-muted small fw-bold text-uppercase mb-2">Prospectos Conv.</h6>
                        <h2 class="fw-bold text-indigo mb-0" id="opsProspects">@operativo?.ProspectosConvertidos</h2>
                        <div class="mt-3 text-muted x-small fw-medium">Nuevos Pacientes</div>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">Rendimiento por Medico (Citas Atendidas)</h6>
                        </div>
                        <div class="card-body p-4">
                            <div style="height: 300px;">
                                <canvas id="chartMedicos"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-4 px-4">
                            <h6 class="fw-bold mb-0">Estatus de Agenda</h6>
                        </div>
                        <div class="card-body p-4">
                            <div style="height: 200px;">
                                <canvas id="chartEstados"></canvas>
                            </div>
                            <div class="mt-4 pt-3 border-top">
                                <button class="btn btn-primary w-100 rounded-3 fw-bold" onclick="exportData('citas')">
                                    <i class="fas fa-download me-2"></i>Exportar Listado Citas
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PILLAR 3: INVENTARIO -->
        <div class="tab-pane fade" id="pills-inv" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between">
                            <h6 class="fw-bold mb-0 text-dark">Top 5 Tratamientos Demandados</h6>
                            <span class="badge bg-soft-success text-success border border-success border-opacity-25 rounded-pill px-3">Más Vendidos</span>
                        </div>
                        <div class="card-body p-4">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle border-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="border-0 small text-muted">Tratamiento</th>
                                            <th class="border-0 small text-muted text-end">Vendidos</th>
                                            <th class="border-0 small text-muted text-end">Ingresos Est.</th>
                                        </tr>
                                    </thead>
                                    <tbody id="listTopTratamientos">
                                        @foreach (var s in inventario?.TratamientosMasVendidos ?? new())
                                        {
                                            <tr>
                                                <td class="fw-bold py-3">@s.Nombre</td>
                                                <td class="text-end fw-medium">@s.Cantidad</td>
                                                <td class="text-end text-success fw-bold">@s.TotalIngresos.ToString("C2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 bg-dark text-white mb-4">
                        <div class="card-body p-4">
                            <h6 class="text-white-50 text-uppercase small fw-bold mb-3">Valorización Inventario</h6>
                            <h2 class="fw-bold mb-0 text-white" id="invTotalValor">@inventario?.ValorTotalStock.ToString("C2")</h2>
                            <p class="small mb-0 mt-2 text-white-50">@inventario?.TotalReferencias referencias registradas</p>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between">
                            <h6 class="fw-bold mb-0 text-dark">Productos Críticos</h6>
                            <span class="badge bg-danger rounded-pill" id="invCountCriticos">@inventario?.ItemsCriticos</span>
                        </div>
                        <div class="card-body p-4">
                            <div id="listAlertasStock">
                                @foreach (var p in inventario?.AlertasStock ?? new())
                                {
                                    <div class="d-flex justify-content-between align-items-center p-2 border-bottom mb-2">
                                        <div class="small fw-bold text-dark">@p.Nombre</div>
                                        <div class="badge bg-soft-danger text-danger">Stock: @p.StockActual / Mín: @p.StockMinimo</div>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-outline-dark w-100 mt-3 rounded-2 fw-bold" onclick="exportData('inventario')">
                                <i class="fas fa-file-excel me-2"></i>Exportar Control Activos
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para ID de Turno -->
<div class="modal fade" id="turnoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-body p-4 text-center">
                <div class="icon-shape bg-soft-danger text-danger rounded-circle mx-auto mb-3" style="width: 60px; height: 60px; display:flex; align-items:center; justify-content:center;">
                    <i class="fas fa-file-pdf fs-4"></i>
                </div>
                <h5 class="fw-bold text-dark">Auditoría de Turno</h5>
                <p class="text-muted small">Ingrese el ID del turno para generar el reporte profesional.</p>
                <div class="bg-light p-3 rounded-4 mb-3">
                    <input type="number" id="turnoIdInput" class="form-control text-center fs-4 fw-bold border-0 bg-transparent" placeholder="000" />
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-danger py-2 rounded-3 fw-bold" onclick="generateCierrePdf()">
                        <i class="fas fa-download me-2"></i>Descargar PDF
                    </button>
                    <button class="btn btn-link text-muted btn-sm text-decoration-none" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let chartMetodos, chartMedicos, chartEstados;

        document.addEventListener('DOMContentLoaded', function() {
            initCharts();
            // Initial render uses server-side data from ViewBag, no need to refresh right away unless dates change
        });

        function initCharts() {
            // Chart Métodos (Financial)
            const ctxMet = document.getElementById('chartMetodos').getContext('2d');
            chartMetodos = new Chart(ctxMet, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(caja?.DesglosePorMetodo.Select(x => x.Metodo))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(caja?.DesglosePorMetodo.Select(x => x.Total))),
                        backgroundColor: ['#4F46E5', '#10B981', '#F59E0B', '#EF4444', '#6366F1'],
                        borderWidth: 0,
                        cutout: '70%'
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });

            // Chart Medicos (Operativo)
            const ctxMed = document.getElementById('chartMedicos').getContext('2d');
            chartMedicos = new Chart(ctxMed, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(operativo?.RendimientoMedicos.Select(x => x.NombreMedico))),
                    datasets: [{
                        label: 'Citas Atendidas',
                        data: @Html.Raw(Json.Serialize(operativo?.RendimientoMedicos.Select(x => x.CitasAtendidas))),
                        backgroundColor: '#4F46E5',
                        borderRadius: 6
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { borderDash: [5, 5] } } } }
            });

            // Chart Estados (Operativo)
            const ctxEst = document.getElementById('chartEstados').getContext('2d');
            chartEstados = new Chart(ctxEst, {
                type: 'pie',
                data: {
                    labels: @Html.Raw(Json.Serialize(operativo?.DistribucionEstados.Select(x => x.Estado))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(operativo?.DistribucionEstados.Select(x => x.Cantidad))),
                        backgroundColor: @Html.Raw(Json.Serialize(operativo?.DistribucionEstados.Select(x => x.Color))),
                        borderWidth: 0
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } } } }
            });
        }

        function setQuickRange(range) {
            const end = new Date();
            let start = new Date();

            switch(range) {
                case 'today': break;
                case 'week': start.setDate(end.getDate() - 7); break;
                case 'month': start.setMonth(end.getMonth() - 1); break;
                case 'year': start.setFullYear(end.getFullYear() - 1); break;
            }

            document.getElementById('reportInicio').value = start.toISOString().split('T')[0];
            document.getElementById('reportFin').value = end.toISOString().split('T')[0];
            refreshDashboard();
        }

        async function refreshDashboard() {
            const inicio = document.getElementById('reportInicio').value;
            const fin = document.getElementById('reportFin').value;
            
            try {
                const res = await fetch(`/Reportes/GetReportData?inicio=${inicio}&fin=${fin}`);
                const data = await res.json();
                
                if (data.success) {
                    updateFinancialUI(data.caja);
                    updateOperativoUI(data.operativo);
                    updateInventarioUI(data.inventario);
                }
            } catch (err) {
                console.error("Error refreshing dashboard", err);
            }
        }

        function updateFinancialUI(c) {
            document.getElementById('finTotalIngresos').innerText = formatCurrency(c.totalIngresosBase);
            document.getElementById('finTotalTrans').innerText = c.totalTransacciones;
            document.getElementById('finTotalDif').innerText = formatCurrency(c.totalDiferencias);
            
            // List
            let listHtml = "";
            c.desglosePorMetodo.forEach(m => {
                listHtml += `<div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                                <div class="d-flex align-items-center gap-2"><span class="badge rounded-circle p-1 bg-primary"></span><span class="fw-medium">${m.metodo}</span></div>
                                <div class="text-end"><div class="fw-bold">${formatCurrency(m.total)}</div><div class="text-muted x-small">${m.cantidad} ops (${m.porcentaje.toFixed(1)}%)</div></div>
                             </div>`;
            });
            document.getElementById('listMetodos').innerHTML = listHtml;
            
            // Chart
            chartMetodos.data.labels = c.desglosePorMetodo.map(x => x.metodo);
            chartMetodos.data.datasets[0].data = c.desglosePorMetodo.map(x => x.total);
            chartMetodos.update();
        }

        function updateOperativoUI(o) {
            document.getElementById('opsTotalCitas').innerText = o.totalCitas;
            document.getElementById('opsAtendidas').innerText = o.citasAtendidas;
            document.getElementById('opsNoShow').innerText = o.tasaNoShow.toFixed(1) + "%";
            document.getElementById('opsProspects').innerText = o.prospectosConvertidos;
            
            chartMedicos.data.labels = o.rendimientoMedicos.map(x => x.nombreMedico);
            chartMedicos.data.datasets[0].data = o.rendimientoMedicos.map(x => x.citasAtendidas);
            chartMedicos.update();
            
            chartEstados.data.labels = o.distribucionEstados.map(x => x.estado);
            chartEstados.data.datasets[0].data = o.distribucionEstados.map(x => x.cantidad);
            chartEstados.data.datasets[0].backgroundColor = o.distribucionEstados.map(x => x.color);
            chartEstados.update();
        }

        function updateInventarioUI(i) {
            document.getElementById('invTotalValor').innerText = formatCurrency(i.valorTotalStock);
            document.getElementById('invCountCriticos').innerText = i.itemsCriticos;
            
            let topHtml = "";
            i.tratamientosMasVendidos.forEach(s => {
                topHtml += `<tr><td class="fw-bold py-3">${s.nombre}</td><td class="text-end fw-medium">${s.cantidad}</td><td class="text-end text-success fw-bold">${formatCurrency(s.totalIngresos)}</td></tr>`;
            });
            document.getElementById('listTopTratamientos').innerHTML = topHtml;
            
            let critHtml = "";
            i.alertasStock.forEach(p => {
                critHtml += `<div class="d-flex justify-content-between align-items-center p-2 border-bottom mb-2"><div class="small fw-bold text-dark">${p.nombre}</div><div class="badge bg-soft-danger text-danger">Stock: ${p.stockActual} / Mín: ${p.stockMinimo}</div></div>`;
            });
            document.getElementById('listAlertasStock').innerHTML = critHtml;
        }

        function formatCurrency(val) {
            return new Intl.NumberFormat('es-NI', { style: 'currency', currency: 'NIO' }).format(val);
        }

        function openCierreModal() {
            new bootstrap.Modal(document.getElementById('turnoModal')).show();
        }

        function generateCierrePdf() {
            const id = document.getElementById('turnoIdInput').value;
            if (id) window.location.href = `/Reportes/ExportarCierrePDF?idTurno=${id}`;
        }

        function exportData(type) {
            const start = document.getElementById('reportInicio').value;
            const end = document.getElementById('reportFin').value;
            let url = "";
            if (type === 'ingresos') url = `/Reportes/ExportarIngresosExcel?inicio=${start}&fin=${end}`;
            if (type === 'citas') url = `/Reportes/ExportarCitasExcel?inicio=${start}&fin=${end}`;
            if (type === 'inventario') url = `/Reportes/ExportarInventarioExcel`;
            if (url) window.location.href = url;
        }
    </script>
}

<style>
    .bg-soft-primary { background: rgba(79, 70, 229, 0.1); }
    .bg-soft-danger { background: rgba(239, 68, 68, 0.1); }
    .bg-soft-success { background: rgba(16, 185, 129, 0.1); }
    .text-indigo { color: #4F46E5; }
    .x-small { font-size: 0.75rem; }
    
    .nav-pills .nav-link { color: #64748B; transition: all 0.2s; border-radius: 8px; }
    .nav-pills .nav-link.active { background-color: #4F46E5 !important; color: white !important; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2); }
    .nav-pills .nav-link:hover:not(.active) { background-color: #F1F5F9; color: #1E293B; }
    
    .card { border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s; }
    .card:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; }
    
    .icon-circle { flex-shrink: 0; }
    .table thead th { font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

    input[type="date"]::-webkit-calendar-picker-indicator {
        opacity: 0.5;
        cursor: pointer;
    }
</style>
